---
// cv.astro — Liquid Glass CV — inspired by nikdelvin/liquid-glass
import '@fontsource/google-sans-flex';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Curriculum Vitae — Tinnaphop Sonsang" />
		<title>CV — Tinnaphop Sonsang</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

		<style>
			/* ============================================================
			   RESET & BASE
			============================================================ */
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

			:root {
				--font: 'Inter', 'Google Sans Flex', system-ui, sans-serif;
				--bg-from: #0a0015;
				--bg-mid:  #050820;
				--bg-to:   #000d0a;
				--text:    rgba(255,255,255,0.92);
				--text-dim: rgba(255,255,255,0.55);
				--text-dimmer: rgba(255,255,255,0.32);
				--accent:  #a8edea;
				--accent2: #fed6e3;
			}

			html, body {
				width: 100%;
				min-height: 100vh;
				background: var(--bg-from);
				font-family: var(--font);
				color: var(--text);
				overflow-x: hidden;
				-webkit-font-smoothing: antialiased;
			}

			a { color: inherit; text-decoration: none; }

			/* ============================================================
			   ANIMATED GRADIENT BACKGROUND
			============================================================ */
			.bg-scene {
				position: fixed;
				inset: 0;
				z-index: 0;
				overflow: hidden;
				background-color: #030207;
			}

			/* Butterfly Wings */
			.wing {
				position: absolute;
				bottom: -15vh;
				width: 60vw;
				height: 105vh; /* Expands to almost touch the top navbar */
				filter: blur(95px);
				mix-blend-mode: screen;
				opacity: 0.9;
				will-change: transform, background-position;
				background-size: 150% 150%;
			}
			.wing-left {
				right: 50%;
				transform-origin: bottom right;
				/* Red to Yellow (RY) */
				background-image: radial-gradient(ellipse at 100% 100%, rgba(239, 68, 68, 0.75) 0%, rgba(234, 179, 8, 0.35) 45%, rgba(239, 68, 68, 0.1) 75%, transparent 100%);
				background-position: 100% 100%;
				animation: flap-left 10s ease-in-out infinite alternate;
			}
			.wing-right {
				left: 50%;
				transform-origin: bottom left;
				/* Green to Blue (GB) */
				background-image: radial-gradient(ellipse at 0% 100%, rgba(59, 130, 246, 0.7) 0%, rgba(34, 197, 94, 0.35) 45%, rgba(59, 130, 246, 0.1) 75%, transparent 100%);
				background-position: 0% 100%;
				animation: flap-right 10s ease-in-out infinite alternate;
			}

			/* Center body highlight */
			.butterfly-body {
				position: absolute;
				bottom: -50px;
				left: 50%;
				transform: translateX(-50%);
				width: 200px;
				height: 250px;
				background: radial-gradient(ellipse at 50% 100%, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
				filter: blur(30px);
				mix-blend-mode: screen;
				pointer-events: none;
			}

			@keyframes flap-left {
				0% {
					transform: rotate(-24deg) scale3d(0.95, 0.95, 1) skewX(-3deg);
					background-position: 100% 100%;
					opacity: 0.8;
				}
				100% {
					transform: rotate(-16deg) scale3d(1.05, 1.05, 1) skewX(2deg);
					background-position: 80% 90%;
					opacity: 0.95;
				}
			}
			@keyframes flap-right {
				0% {
					transform: rotate(24deg) scale3d(0.95, 0.95, 1) skewX(3deg);
					background-position: 0% 100%;
					opacity: 0.8;
				}
				100% {
					transform: rotate(16deg) scale3d(1.05, 1.05, 1) skewX(-2deg);
					background-position: 20% 90%;
					opacity: 0.95;
				}
			}





			/* Vignette */
			.bg-vignette {
				position: absolute;
				inset: 0;
				background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 30%, rgba(0,0,0,.6) 80%, rgba(0,0,0,.95) 100%);
				pointer-events: none;
			}

			/* ============================================================
			   LIQUID GLASS — CSS + SVG Filter
			   Based on nikdelvin/liquid-glass technique
			============================================================ */

			/* Hidden SVG filter definitions */
			.lg-filters { position: absolute; width: 0; height: 0; pointer-events: none; }

			/* Base glass element */
			.lg {
				position: relative;
				overflow: hidden;
				border-radius: 20px;
				transition: transform .3s cubic-bezier(.2,.8,.2,1), box-shadow .3s;
			}

			/* The SVG displacement layer */
			.lg::before {
				content: '';
				position: absolute;
				inset: -4px;
				z-index: 2;
				border-radius: inherit;
				filter: url(#liquid-glass-distort);
				/* This creates the refraction/distortion illusion */
				background: transparent;
				pointer-events: none;
			}

			/* Backdrop blur layer */
			.lg-blur {
				position: absolute;
				inset: 0;
				z-index: 0;
				backdrop-filter: blur(24px) saturate(1.6) brightness(1.1);
				-webkit-backdrop-filter: blur(24px) saturate(1.6) brightness(1.1);
				border-radius: inherit;
			}

			/* Glass tint overlay */
			.lg-tint {
				position: absolute;
				inset: 0;
				z-index: 1;
				background: rgba(255,255,255,0.06);
				border-radius: inherit;
			}

			/* Border shimmer */
			.lg-border {
				position: absolute;
				inset: 0;
				z-index: 3;
				border-radius: inherit;
				border: 1px solid rgba(255,255,255,0.18);
				/* Gradient border effect */
				background: transparent;
				/* Top-left bright corner shimmer */
				box-shadow:
					inset 0 1px 0 rgba(255,255,255,0.25),
					inset 1px 0 0 rgba(255,255,255,0.12),
					0 8px 40px rgba(0,0,0,0.4),
					0 2px 8px rgba(0,0,0,0.3);
				pointer-events: none;
			}

			/* Content sits above all layers */
			.lg-content {
				position: relative;
				z-index: 4;
			}

			/* Hover lift effect */
			.lg:hover {
				transform: translateY(-2px);
				box-shadow: 0 16px 60px rgba(0,0,0,0.5), 0 4px 16px rgba(0,0,0,0.3);
			}
			.lg:hover .lg-border {
				border-color: rgba(255,255,255,0.28);
				box-shadow:
					inset 0 1px 0 rgba(255,255,255,0.35),
					inset 1px 0 0 rgba(255,255,255,0.18),
					0 16px 60px rgba(0,0,0,0.5),
					0 2px 8px rgba(0,0,0,0.3);
			}

			/* Chromatic aberration shimmer on hover */
			.lg::after {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 5;
				background: linear-gradient(135deg, rgba(168,237,234,0.08) 0%, transparent 40%, rgba(254,214,227,0.05) 100%);
				border-radius: inherit;
				opacity: 0;
				transition: opacity .3s;
				pointer-events: none;
			}
			.lg:hover::after { opacity: 1; }

			/* ============================================================
			   PILL GLASS — smaller variant for skills
			============================================================ */
			.lg-pill {
				display: inline-flex;
				align-items: center;
				padding: 4px 12px;
				border-radius: 100px;
				font-size: 11px;
				font-weight: 500;
				letter-spacing: 0.2px;
				color: rgba(255,255,255,0.85);
				position: relative;
				overflow: hidden;
				backdrop-filter: blur(12px) saturate(1.4);
				-webkit-backdrop-filter: blur(12px) saturate(1.4);
				background: rgba(255,255,255,0.07);
				border: 1px solid rgba(255,255,255,0.14);
				box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 2px 8px rgba(0,0,0,0.2);
				transition: all .2s;
			}
			.lg-pill:hover {
				background: rgba(255,255,255,0.13);
				border-color: rgba(255,255,255,0.25);
				transform: translateY(-1px);
			}

			.cv-nav {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				z-index: 100;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 12px 24px;
				border-radius: 0;
				backdrop-filter: blur(32px) saturate(1.8) brightness(1.15);
				-webkit-backdrop-filter: blur(32px) saturate(1.8) brightness(1.15);
				background: rgba(10, 5, 20, 0.6);
				border: none;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				box-shadow: 0 4px 30px rgba(0,0,0,0.5);
				white-space: nowrap;
			}
			.nav-back-btn {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 5px 14px;
				border-radius: 100px;
				font-size: 12.5px;
				font-weight: 500;
				color: rgba(255,255,255,0.75);
				transition: all .2s;
				cursor: pointer;
				text-decoration: none;
			}
			.nav-back-btn:hover {
				background: rgba(255,255,255,0.1);
				color: #fff;
			}
			.nav-back-btn svg { opacity: .7; }
			.nav-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.12); margin: 0 4px; }
			.nav-brand {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 5px 14px;
				font-size: 12.5px;
				font-weight: 600;
				color: rgba(255,255,255,0.9);
				letter-spacing: -0.2px;
			}
			.nav-section-links {
				display: flex;
				align-items: center;
				gap: 2px;
				margin-left: 4px;
			}
			.nav-link {
				padding: 5px 12px;
				border-radius: 100px;
				font-size: 12px;
				color: rgba(255,255,255,0.55);
				transition: all .2s;
				cursor: pointer;
			}
			.nav-link:hover, .nav-link.active {
				background: rgba(255,255,255,0.1);
				color: rgba(255,255,255,0.9);
			}

			/* ============================================================
			   LAYOUT
			============================================================ */
			.cv-page {
				position: relative;
				z-index: 1;
				min-height: calc(100vh - 54px);
				padding: 96px 24px 80px;
				animation: page-open .45s cubic-bezier(.1,.9,.2,1) both;
			}
			@keyframes page-open {
				from { opacity:0; transform: scale(.98) translateY(12px); }
				to   { opacity:1; transform: scale(1) translateY(0); }
			}

			.cv-container {
				max-width: 860px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 16px;
			}

			/* ============================================================
			   HERO CARD
			============================================================ */
			.hero-card {
				padding: 40px 40px 36px;
			}
			.hero-avatar-row {
				display: flex;
				align-items: center;
				gap: 20px;
				margin-bottom: 24px;
			}
			.hero-avatar {
				width: 72px;
				height: 72px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent), var(--accent2));
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 28px;
				font-weight: 700;
				color: #000;
				letter-spacing: -1px;
				flex-shrink: 0;
				box-shadow: 0 4px 20px rgba(168,237,234,0.35);
			}
			.hero-title-block { flex: 1; }
			.hero-name {
				font-size: 2rem;
				font-weight: 700;
				letter-spacing: -0.8px;
				line-height: 1.1;
				background: linear-gradient(135deg, #fff 0%, rgba(168,237,234,.9) 60%, rgba(254,214,227,.8) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				margin-bottom: 6px;
			}
			.hero-role {
				font-size: .95rem;
				color: var(--text-dim);
				font-weight: 400;
			}
			.hero-contact {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				align-items: center;
			}
			.contact-item {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 5px 14px;
				border-radius: 100px;
				font-size: 12px;
				color: rgba(255,255,255,0.7);
				backdrop-filter: blur(16px);
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.11);
				transition: all .2s;
				cursor: pointer;
			}
			.contact-item:hover {
				background: rgba(255,255,255,0.12);
				color: #fff;
				border-color: rgba(255,255,255,0.22);
			}
			.contact-item svg { opacity: .6; flex-shrink: 0; }

			/* ============================================================
			   SECTION CARDS
			============================================================ */
			.section-card {
				padding: 32px 36px;
			}
			.section-header {
				display: flex;
				align-items: center;
				gap: 10px;
				margin-bottom: 24px;
			}
			.section-icon {
				width: 28px;
				height: 28px;
				border-radius: 8px;
				background: rgba(255,255,255,0.08);
				border: 1px solid rgba(255,255,255,0.12);
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
			}
			.section-icon svg { opacity: .75; }
			.section-label {
				font-size: 11px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 1.2px;
				color: var(--text-dimmer);
			}

			/* ============================================================
			   SUMMARY
			============================================================ */
			.summary-text {
				font-size: .93rem;
				line-height: 1.75;
				color: var(--text-dim);
				max-width: 640px;
			}

			/* ============================================================
			   TIMELINE ENTRIES
			============================================================ */
			.entries { display: flex; flex-direction: column; gap: 0; }
			.entry {
				position: relative;
				padding: 20px 0 20px 28px;
				border-left: 1px solid rgba(255,255,255,0.1);
			}
			.entry:last-child { padding-bottom: 0; border-left: 1px solid transparent; }
			.entry-dot {
				position: absolute;
				left: -4.5px;
				top: 24px;
				width: 9px;
				height: 9px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent), var(--accent2));
				box-shadow: 0 0 8px rgba(168,237,234,0.5);
			}
			.entry-head {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 12px;
				margin-bottom: 3px;
			}
			.entry-title {
				font-size: .88rem;
				font-weight: 600;
				color: rgba(255,255,255,0.9);
			}
			.entry-date {
				font-size: .75rem;
				color: var(--text-dimmer);
				white-space: nowrap;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.08);
				border-radius: 100px;
				padding: 2px 10px;
			}
			.entry-org {
				font-size: .8rem;
				color: var(--accent);
				margin-bottom: 10px;
				opacity: .85;
			}
			.entry-sub {
				font-size: .78rem;
				font-weight: 600;
				color: rgba(255,255,255,0.75);
				margin: 10px 0 6px;
			}
			.bullets {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 4px;
			}
			.bullets li {
				font-size: .8rem;
				color: var(--text-dim);
				line-height: 1.55;
				padding-left: 14px;
				position: relative;
			}
			.bullets li::before {
				content: '›';
				position: absolute;
				left: 0;
				color: rgba(168,237,234,0.6);
				font-size: 1rem;
				line-height: 1.3;
			}

			/* ============================================================
			   SKILLS
			============================================================ */
			.skills-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 12px;
			}
			.skill-group-card {
				padding: 16px 18px;
				border-radius: 14px;
				backdrop-filter: blur(20px);
				background: rgba(255,255,255,0.04);
				border: 1px solid rgba(255,255,255,0.09);
				transition: all .25s;
			}
			.skill-group-card:hover {
				background: rgba(255,255,255,0.08);
				border-color: rgba(255,255,255,0.16);
				transform: translateY(-2px);
			}
			.skill-group-label {
				font-size: 11px;
				font-weight: 600;
				color: var(--text-dimmer);
				text-transform: uppercase;
				letter-spacing: .6px;
				margin-bottom: 10px;
			}
			.pills-wrap {
				display: flex;
				flex-wrap: wrap;
				gap: 5px;
			}

			/* Two-column layout for larger screens */
			@media (min-width: 720px) {
				.two-col {
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 16px;
				}
				.two-col .section-card:first-child { grid-column: 1; }
				.two-col .section-card:last-child  { grid-column: 2; }
			}

			/* ============================================================
			   RESPONSIVE
			============================================================ */
			@media (max-width: 640px) {
				.cv-nav { padding: 8px 12px; }
				.nav-section-links { display: none; }
				.hero-card { padding: 28px 24px 24px; }
				.section-card { padding: 24px 22px; }
				.hero-name { font-size: 1.6rem; }
				.skills-grid { grid-template-columns: 1fr; }
				.entry-head { flex-direction: column; gap: 4px; }
			}
		</style>

		<!-- SVG filter for Liquid Glass distortion -->
		<svg class="lg-filters" xmlns="http://www.w3.org/2000/svg">
			<defs>
				<filter id="liquid-glass-distort" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
					<feTurbulence type="fractalNoise" baseFrequency="0.012 0.008" numOctaves="3" seed="2" result="noise" />
					<feColorMatrix type="saturate" values="3" in="noise" result="coloredNoise" />
					<feDisplacementMap in="SourceGraphic" in2="coloredNoise" scale="14" xChannelSelector="R" yChannelSelector="G" result="displaced" />
					<feGaussianBlur in="displaced" stdDeviation="0.5" result="blurred" />
					<feComposite in="blurred" in2="SourceGraphic" operator="in" />
				</filter>
			</defs>
		</svg>
	</head>

	<body>
		<!-- Background scene -->
		<div class="bg-scene">
			<div class="wing wing-left"></div>
			<div class="wing wing-right"></div>
			<div class="butterfly-body"></div>
			<div class="bg-vignette"></div>
		</div>

		<!-- Floating Nav -->
		<nav class="cv-nav" id="cv-nav">
			<a href="/" class="nav-back-btn" id="nav-back">
				<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M19 12H5M12 5l-7 7 7 7"/>
				</svg>
				Back
			</a>
			<div class="nav-divider"></div>
			<div class="nav-brand">
				<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:.7">
					<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/>
				</svg>
				CV
			</div>
			<div class="nav-divider"></div>
			<div class="nav-section-links">
				<a href="#hero"       class="nav-link active" data-section="hero">Overview</a>
				<a href="#summary"    class="nav-link"        data-section="summary">Summary</a>
				<a href="#education"  class="nav-link"        data-section="education">Education</a>
				<a href="#skills"     class="nav-link"        data-section="skills">Skills</a>
				<a href="#experience" class="nav-link"        data-section="experience">Experience</a>
				<a href="#projects"   class="nav-link"        data-section="projects">Projects</a>
			</div>
		</nav>

		<div class="cv-page">
			<div class="cv-container">

				<!-- ====== HERO ====== -->
				<div class="lg hero-card" id="hero">
					<div class="lg-blur"></div>
					<div class="lg-tint"></div>
					<div class="lg-border"></div>
					<div class="lg-content">
						<div class="hero-avatar-row">
							<div class="hero-avatar">TS</div>
							<div class="hero-title-block">
								<h1 class="hero-name">Tinnaphop Sonsang</h1>
								<p class="hero-role">Computer Engineering &amp; AI Graduate</p>
							</div>
						</div>
						<div class="hero-contact">
							<a href="mailto:tinnaphop.moss@gmail.com" class="contact-item">
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
								tinnaphop.moss@gmail.com
