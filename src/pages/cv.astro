		<script>
			// ── Page exit transition ──
			const backBtn = document.getElementById("backBtn");
			if (backBtn) {
				backBtn.addEventListener("click", (e) => {
					e.preventDefault();
					document.body.classList.add("is-exiting");
					setTimeout(() => {
						window.location.href = backBtn.getAttribute("href");
					}, 280);
				});
			}

			// ── Scroll-spy & Smooth scroll ──
			(function() {
				const workspace = document.querySelector('.wbc-workspace');
				const sections = document.querySelectorAll('#summary, #education, #experience, #skills, #projects');
				const navLinks = document.querySelectorAll('.sidebar-nav-link');

				if (!workspace) return;

				workspace.addEventListener('scroll', () => {
					let current = '';
					sections.forEach(s => {
						const top = s.offsetTop - workspace.offsetTop;
						if (workspace.scrollTop >= top - 40) {
							current = s.getAttribute('id');
						}
					});
					navLinks.forEach(l => {
						l.classList.toggle('active', l.getAttribute('href') === `#${current}`);
					});
				});

				navLinks.forEach(a => {
					a.addEventListener('click', e => {
						const targetId = a.getAttribute('href');
						const targetEl = document.querySelector(targetId);
						if (targetEl) {
							e.preventDefault();
							workspace.scrollTo({
								top: targetEl.offsetTop - workspace.offsetTop + 1,
								behavior: 'smooth'
							});
						}
					});
				});
			})();
		</script>
