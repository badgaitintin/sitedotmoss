					showbackground: false,
					tickcolor: "#fff",
					titlefont: { size: 10, color: "#9ca3af" },
					tickfont: { size: 9, color: "#94a3b8" },
				},
				zaxis: {
					title: "Release Year",
					gridcolor: "rgba(255, 255, 255, 0.08)",
					zerolinecolor: "rgba(255, 255, 255, 0.15)",
					showbackground: false,
					tickcolor: "#fff",
					titlefont: { size: 10, color: "#9ca3af" },
					tickfont: { size: 9, color: "#94a3b8" },
				},
				camera: {
					eye: { x: 1.5, y: 1.5, z: 1.2 },
				},
			},
			showlegend: true,
			legend: {
				x: 0.02,
				y: 0.98,
				font: { size: 9, color: "#fff" },
				bgcolor: "rgba(13, 17, 30, 0.8)",
				bordercolor: "rgba(255,255,255,0.08)",
				borderwidth: 1,
			},
		};

		const config = {
			responsive: true,
			displayModeBar: false,
		};

		window.Plotly.newPlot("plotly-galaxy-3d", traces, layout, config);

		// Connect click event
		gd.on("plotly_click", function (data) {
			if (data.points && data.points.length > 0) {
				const pt = data.points[0];
				if (pt.customdata !== undefined) {
					state.trackIndex = pt.customdata;
					renderGalaxy();
				}
			}
		});
	}

	// ── TAB 3: Personal Rating render ──
	let selectedRatingAlbum = null;
	let isFirstRatingRender = true;

	function renderRatingTab() {
		const container = document.getElementById("album-cards-container");
		if (!container) return;

		// Map to ensure every track has an album field, fallback to "Confessions II"
		const allTracksWithAlbum = (window.PERSONAL_RATING || []).map((t) => ({
			...t,
			album: t.album || "Confessions II",
		}));

		// Extract unique albums
		const albums = Array.from(
			new Set(allTracksWithAlbum.map((t) => t.album)),
		);

		// If first render, default to the first album being open
		if (isFirstRatingRender && albums.length > 0) {
			selectedRatingAlbum = albums[0];
			isFirstRatingRender = false;
		}

		// Build the HTML for all album cards
		let cardsHtml = "";

		albums.forEach((albumName) => {
			const albumTracks = allTracksWithAlbum.filter(
				(t) => t.album === albumName,
			);
			const isActive = selectedRatingAlbum === albumName;

			let favHtml = "";
			let goodHtml = "";
			let notfavHtml = "";

			// Group tracks for this specific album
			albumTracks
				.sort((a, b) => b.bias_score - a.bias_score)
				.forEach((t) => {
					const html = `
							<div style="display: flex; align-items: center; justify-content: space-between; padding: 4px 6px; border-bottom: 1px dashed rgba(0,0,0,0.05); transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.2)'" onmouseout="this.style.backgroundColor='transparent'">
								<span style="font-weight: 700; font-size: 0.72rem; color: var(--bh-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 175px;" title="${t.track}">${t.track}</span>
								<span style="font-size: 0.62rem; color: var(--bh-muted); flex-shrink: 0;">Bias: <strong style="color: var(--bh-text); font-size: 0.68rem;">${t.bias_score}</strong></span>
							</div>
						`;
					if (t.label === "My Favorite") favHtml += html;
					else if (t.label === "So Far, So Good") goodHtml += html;
					else notfavHtml += html;
				});

			cardsHtml += `
						<div class="album-card ${isActive ? "active" : ""}" data-album="${albumName}">
							<div class="album-card-header">
								<div class="album-card-info">
									<span class="album-card-title">${albumName}</span>
									<span class="album-card-subtitle">${albumTracks.length} tracks rated</span>
								</div>
								<svg class="album-card-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<polyline points="6 9 12 15 18 9"></polyline>
								</svg>
							</div>
							<div class="album-card-body">
								<div class="rating-group-sec" style="border-left: 4px solid #10B981;">
									<span class="rating-group-title-sec" style="color: #10B981;">My Favorite</span>
									<div class="rating-group-tracks-sec">${favHtml || '<span style="font-size:0.7rem; color:var(--bh-muted); font-style:italic;">None</span>'}</div>
								</div>
								<div class="rating-group-sec" style="border-left: 4px solid #F59E0B;">
									<span class="rating-group-title-sec" style="color: #F59E0B;">So Far, So Good</span>
									<div class="rating-group-tracks-sec">${goodHtml || '<span style="font-size:0.7rem; color:var(--bh-muted); font-style:italic;">None</span>'}</div>
								</div>
								<div class="rating-group-sec" style="border-left: 4px solid #EF4444;">
									<span class="rating-group-title-sec" style="color: #EF4444;">Not My Favorite</span>
									<div class="rating-group-tracks-sec">${notfavHtml || '<span style="font-size:0.7rem; color:var(--bh-muted); font-style:italic;">None</span>'}</div>
								</div>
							</div>
						</div>
					`;
		});

		container.innerHTML = cardsHtml;

		// Attach click listeners to the headers for expand/collapse toggle
		container.querySelectorAll(".album-card-header").forEach((header) => {
			header.addEventListener("click", () => {
				const card = header.parentElement;
				const albumName = card.dataset.album;

				if (selectedRatingAlbum === albumName) {
					// If clicking the currently active one, we collapse it (showing all tracks in the 3D plot)
					selectedRatingAlbum = null;
				} else {
					// Open the clicked one, closing the others (accordion style)
					selectedRatingAlbum = albumName;
				}

				renderRatingTab();
			});
		});

		// Now filter ratings for the Plotly 3D scatter chart
		const ratings = selectedRatingAlbum
			? allTracksWithAlbum.filter((t) => t.album === selectedRatingAlbum)
			: allTracksWithAlbum;

		// Render 3D Plotly Map
		const gd = document.getElementById("plotly-3d-map");
		if (gd && window.Plotly) {
			const groups = [
				{ label: "My Favorite", color: "#10B981", border: "#047857" },
				{
					label: "So Far, So Good",
					color: "#F59E0B",
					border: "#B45309",
				},
				{
					label: "Not My Favorite",
					color: "#EF4444",
					border: "#B91C1C",
				},
			];

			const traces = [];

			groups.forEach((g) => {
				const groupTracks = ratings.filter((t) => t.label === g.label);
				if (groupTracks.length === 0) return;

				// Scatter trace
				traces.push({
					x: groupTracks.map((t) => t.pc1),
					y: groupTracks.map((t) => t.pc2),
					z: groupTracks.map((t) => t.bias_score),
					mode: "markers+text",
					type: "scatter3d",
					name: g.label,
					text: groupTracks.map((t) => t.track),
					textposition: "top center",
					textfont: { size: 8, color: "#cbd5e1" },
					marker: {
						size: 5,
						color: g.color,
						line: { color: g.border, width: 1 },
					},
					hoverinfo: "text",
					hovertext: groupTracks.map(
						(t) =>
							`${t.track}<br>${selectedRatingAlbum ? "" : `Album: ${t.album}<br>`}PC1: ${t.pc1.toFixed(3)}<br>PC2: ${t.pc2.toFixed(3)}<br>Bias Score: ${t.bias_score}`,
					),
				});

				// Ellipsoid mesh trace (only when we plot a single album's tracks)
				if (selectedRatingAlbum && groupTracks.length >= 3) {
					const meshTrace = getEllipsoidTrace(groupTracks, g.color);
					if (meshTrace) {
						traces.push(meshTrace);
					}
				}
			});

			const layout = {
				margin: { l: 0, r: 0, b: 0, t: 0 },
				paper_bgcolor: "rgba(0,0,0,0)",
				plot_bgcolor: "rgba(0,0,0,0)",
				scene: {
					xaxis: {
						title: "PC1 - style (84% var)",
						gridcolor: "rgba(255, 255, 255, 0.1)",
						zerolinecolor: "rgba(255, 255, 255, 0.2)",
						backgroundcolor: "rgba(0,0,0,0)",
						showbackground: false,
						tickcolor: "#cbd5e1",
						titlefont: { size: 10, color: "#cbd5e1" },
						tickfont: { size: 9, color: "#94a3b8" },
					},
					yaxis: {
						title: "PC2 - style (8% var)",
						gridcolor: "rgba(255, 255, 255, 0.1)",
						zerolinecolor: "rgba(255, 255, 255, 0.2)",
						backgroundcolor: "rgba(0,0,0,0)",
						showbackground: false,
						tickcolor: "#cbd5e1",
						titlefont: { size: 10, color: "#cbd5e1" },
						tickfont: { size: 9, color: "#94a3b8" },
					},
					zaxis: {
						title: "Personal Bias Score",
						gridcolor: "rgba(255, 255, 255, 0.1)",
						zerolinecolor: "rgba(255, 255, 255, 0.2)",
						backgroundcolor: "rgba(0,0,0,0)",
						showbackground: false,
						tickcolor: "#cbd5e1",
						titlefont: { size: 10, color: "#cbd5e1" },
						tickfont: { size: 9, color: "#94a3b8" },
					},
					camera: {
						eye: { x: 1.5, y: 1.5, z: 1.2 },
					},
				},
				showlegend: true,
				legend: {
					x: 0,
					y: 1,
					font: { size: 9, color: "#cbd5e1" },
					bgcolor: "rgba(30, 41, 59, 0.8)",
					bordercolor: "rgba(255,255,255,0.1)",
					borderwidth: 1,
				},
			};

			const config = {
				responsive: true,
				displayModeBar: false,
			};

			window.Plotly.newPlot("plotly-3d-map", traces, layout, config);
		}
	}

	// Initialize default rendering
	renderPersonasTab();
	renderRatingTab();
</script>

<script is:inline>
	const dotBgs = [
		"/m1.jpg", "/m2.jpg", "/m3.avif", "/m4.jpg", "/m5.jpg",
		"/m6.jpg", "/m7.webp", "/m8.jpg", "/m9.jpg", "/m10.jpg",
		"/m11.jpg", "/m12.webp", "/m13.webp", "/m14.webp", "/m15.jpg"
	];
	const dotCanvas = document.getElementById('dotMatrixCanvas');
	if (dotCanvas) {
		const dotCtx = dotCanvas.getContext('2d', { alpha: false, willReadFrequently: true });
		let dotOffCanvas = document.createElement('canvas');
		let dotOffCtx = dotOffCanvas.getContext('2d', { willReadFrequently: true });
		let dotCurrentImg = new Image();
		const DOT_CELL_SIZE = 4; 

		let dots = [];
		let animationFrameId = null;

		function initDots() {
			dots = [];
			const cols = Math.ceil(dotCanvas.width / DOT_CELL_SIZE);
			const rows = Math.ceil(dotCanvas.height / DOT_CELL_SIZE);
			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					dots.push({
						x: c * DOT_CELL_SIZE,
						y: r * DOT_CELL_SIZE,
						radius: 0, r: 255, g: 255, b: 255,
						trd: 0, tr: 255, tg: 255, tb: 255
					});
				}
			}
		}

		function dotResize() {
			dotCanvas.width = window.innerWidth;
			dotCanvas.height = window.innerHeight;
			initDots();
			if (dotCurrentImg.src) {
				updateDotTargets(dotCurrentImg);
				if (!animationFrameId) renderLoop();
			}
		}
		window.addEventListener('resize', dotResize);
		dotResize();

		function updateDotTargets(img) {
			if (!img.complete || img.naturalWidth === 0) return;
			const w = dotCanvas.width;
			const h = dotCanvas.height;
			
			dotOffCanvas.width = w;
			dotOffCanvas.height = h;
			dotOffCtx.clearRect(0, 0, w, h);

			const imgRatio = img.naturalWidth / img.naturalHeight;
			const canvasRatio = w / h;
			let drawW, drawH, drawX, drawY;

			if (canvasRatio > imgRatio) {
				drawW = w;
				drawH = w / imgRatio;
				drawX = 0;
				drawY = (h - drawH) / 2;
			} else {
				drawW = h * imgRatio;
				drawH = h;
				drawX = (w - drawW) / 2;
				drawY = 0;
			}
			dotOffCtx.drawImage(img, drawX, drawY, drawW, drawH);
			const imgData = dotOffCtx.getImageData(0, 0, w, h).data;

			for (let i = 0; i < dots.length; i++) {
				const d = dots[i];
				const idx = (d.y * w + d.x) * 4;
				if (idx < imgData.length - 2) {
					d.tr = imgData[idx];
					d.tg = imgData[idx+1];
					d.tb = imgData[idx+2];
					const brightness = 0.299 * d.tr + 0.587 * d.tg + 0.114 * d.tb;
					d.trd = ((255 - brightness) / 255) * (DOT_CELL_SIZE / 2);
				}
			}
		}

		function renderLoop() {
			const w = dotCanvas.width;
			const h = dotCanvas.height;
			dotCtx.fillStyle = "#ffffff";
			dotCtx.fillRect(0, 0, w, h);

			let needsMoreFrames = false;

			for (let i = 0; i < dots.length; i++) {
				const d = dots[i];
				
				const dr = d.trd - d.radius;
				const dR = d.tr - d.r;
				const dG = d.tg - d.g;
				const dB = d.tb - d.b;

				if (Math.abs(dr) > 0.1 || Math.abs(dR) > 1 || Math.abs(dG) > 1 || Math.abs(dB) > 1) {
					needsMoreFrames = true;
				}

				d.radius += dr * 0.06;
				d.r += dR * 0.06;
				d.g += dG * 0.06;
				d.b += dB * 0.06;

				if (d.radius > 0.5) {
					dotCtx.fillStyle = `rgb(${d.r|0}, ${d.g|0}, ${d.b|0})`;
					dotCtx.fillRect(d.x + DOT_CELL_SIZE/2 - d.radius, d.y + DOT_CELL_SIZE/2 - d.radius, d.radius * 2, d.radius * 2);
				}
			}

			if (needsMoreFrames) {
				animationFrameId = requestAnimationFrame(renderLoop);
			} else {
				animationFrameId = null;
			}
		}

		function loadNextDotImage() {
			const src = dotBgs[Math.floor(Math.random() * dotBgs.length)];
			const img = new Image();
			img.crossOrigin = "Anonymous";
			img.onload = () => {
				dotCurrentImg = img;
				updateDotTargets(img);
				if (!animationFrameId) renderLoop();
			};
			img.src = src;
		}

		loadNextDotImage();
		setInterval(loadNextDotImage, 20000); 
	}
</script>
