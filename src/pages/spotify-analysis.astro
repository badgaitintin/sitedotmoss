<script type="module">
	// Jacobi algorithm for 3x3 symmetric matrix eigenvalues & eigenvectors
	function jacobi3x3(A) {
		let V = [
			[1, 0, 0],
			[0, 1, 0],
			[0, 0, 1],
		];
		let d = [A[0][0], A[1][1], A[2][2]];
		let A_mut = [
			[A[0][0], A[0][1], A[0][2]],
			[A[1][0], A[1][1], A[1][2]],
			[A[2][0], A[2][1], A[2][2]],
		];
		for (let iter = 0; iter < 50; iter++) {
			let p = 0,
				q = 1;
			let maxVal = Math.abs(A_mut[0][1]);
			if (Math.abs(A_mut[0][2]) > maxVal) {
				p = 0;
				q = 2;
				maxVal = Math.abs(A_mut[0][2]);
			}
			if (Math.abs(A_mut[1][2]) > maxVal) {
				p = 1;
				q = 2;
				maxVal = Math.abs(A_mut[1][2]);
			}
			if (maxVal < 1e-9) break;

			let theta = (0.5 * (d[q] - d[p])) / A_mut[p][q];
			let t = 1.0 / (Math.abs(theta) + Math.sqrt(1.0 + theta * theta));
			if (theta < 0) t = -t;
			let c = 1.0 / Math.sqrt(1.0 + t * t);
			let s = t * c;
			let tau = s / (1.0 + c);

			let h = t * A_mut[p][q];
			d[p] -= h;
			d[q] += h;
			A_mut[p][q] = 0;

			for (let i = 0; i < 3; i++) {
				if (i !== p && i !== q) {
					let g = A_mut[i][p];
					let j = A_mut[i][q];
					A_mut[i][p] = c * g - s * j;
					A_mut[i][q] = s * g + c * j;
					A_mut[p][i] = A_mut[i][p];
					A_mut[q][i] = A_mut[i][q];
				}
			}
			for (let i = 0; i < 3; i++) {
				let g = V[i][p];
				let j = V[i][q];
				V[i][p] = c * g - s * j;
				V[i][q] = s * g + c * j;
			}
		}
		return { eigenvalues: d, eigenvectors: V };
	}

	function getEllipsoidTrace(clusterTracks, color) {
		if (clusterTracks.length < 3) return null;

		const mean = [0, 0, 0];
		clusterTracks.forEach((t) => {
			mean[0] += t.pc1;
			mean[1] += t.pc2;
			mean[2] += t.bias_score;
		});
		mean[0] /= clusterTracks.length;
		mean[1] /= clusterTracks.length;
		mean[2] /= clusterTracks.length;

		const cov = [
			[0, 0, 0],
			[0, 0, 0],
			[0, 0, 0],
		];
		clusterTracks.forEach((t) => {
			const dx = t.pc1 - mean[0];
			const dy = t.pc2 - mean[1];
			const dz = t.bias_score - mean[2];
			cov[0][0] += dx * dx;
			cov[0][1] += dx * dy;
			cov[0][2] += dx * dz;
			cov[1][1] += dy * dy;
			cov[1][2] += dy * dz;
			cov[2][2] += dz * dz;
		});
		cov[1][0] = cov[0][1];
		cov[2][0] = cov[0][2];
		cov[2][1] = cov[1][2];

		const n = clusterTracks.length;
		for (let r = 0; r < 3; r++) {
			for (let c = 0; c < 3; c++) {
				cov[r][c] /= n - 1;
			}
		}

		const { eigenvalues, eigenvectors } = jacobi3x3(cov);

		const scale = 1.6;
		const s0 = scale * Math.sqrt(Math.max(0, eigenvalues[0]));
		const s1 = scale * Math.sqrt(Math.max(0, eigenvalues[1]));
		const s2 = scale * Math.sqrt(Math.max(0, eigenvalues[2]));

		const uSteps = 15;
		const vSteps = 15;
		const xArr = [];
		const yArr = [];
		const zArr = [];

		for (let i = 0; i <= uSteps; i++) {
			const theta = (i / uSteps) * 2 * Math.PI;
			for (let j = 0; j <= vSteps; j++) {
				const phi = (j / vSteps) * Math.PI;

				const ux = Math.cos(theta) * Math.sin(phi);
				const uy = Math.sin(theta) * Math.sin(phi);
				const uz = Math.cos(phi);

				const sx = ux * s0;
				const sy = uy * s1;
				const sz = uz * s2;

				const rx =
					eigenvectors[0][0] * sx +
					eigenvectors[0][1] * sy +
					eigenvectors[0][2] * sz;
				const ry =
					eigenvectors[1][0] * sx +
					eigenvectors[1][1] * sy +
					eigenvectors[1][2] * sz;
				const rz =
					eigenvectors[2][0] * sx +
					eigenvectors[2][1] * sy +
					eigenvectors[2][2] * sz;

				xArr.push(mean[0] + rx);
				yArr.push(mean[1] + ry);
				zArr.push(mean[2] + rz);
			}
		}

		return {
			type: "mesh3d",
			x: xArr,
			y: yArr,
			z: zArr,
			alphahull: 0,
			opacity: 0.08,
			color: color,
			showlegend: false,
			hoverinfo: "skip",
		};
	}

	const CLUSTERS = window.CLUSTER_SUMMARY;

	// Deduplicate tracks by canonical name
	const RAW_TRACKS = window.MUSIC_GALAXY.filter(
		(t) => t.release_year <= 2020,
	);
	const TRACKS = [];
	const seenNames = new Set();
	for (const t of RAW_TRACKS) {
		const canonicalName = t.name.toLowerCase().trim();
		if (!seenNames.has(canonicalName)) {
			seenNames.add(canonicalName);
			TRACKS.push(t);
		}
	}

	// ── Dynamically build cluster metadata from json ──
	const CLUSTER_META = {};
	CLUSTERS.forEach((c) => {
		CLUSTER_META[c.cluster] = {
			name: c.name || `Cluster ${c.cluster}`,
			description: c.description || "",
			color: c.color || "#888",
			image: c.image || "/assets/spotify/thediscodynamo-1.jpg",
		};
	});

	const AUDIO_FEATURE_KEYS = [
		"danceability",
		"energy",
		"valence",
		"acousticness",
		"speechiness",
	];

	// ── Track similarity engine ──
	class FeatureSpace {
		constructor(tracks) {
			this.tracks = tracks;
			const vectors = tracks.map((t) =>
				AUDIO_FEATURE_KEYS.map((k) => Number(t[k])),
			);
			const norms = vectors.map((v) =>
				Math.sqrt(v.reduce((sum, val) => sum + val * val, 0)),
			);
			const size = tracks.length;

			this.matrix = Array.from({ length: size }, (_, r) =>
				Array.from({ length: size }, (_, c) => (r === c ? 1 : 0)),
			);

			for (let r = 0; r < size; r++) {
				for (let c = r + 1; c < size; c++) {
					const rNorm = norms[r];
					const cNorm = norms[c];
					if (rNorm === 0 || cNorm === 0) continue;

					let dot = 0;
					const rVec = vectors[r];
					const cVec = vectors[c];
					for (let i = 0; i < rVec.length; i++)
						dot += rVec[i] * cVec[i];

					const sim = dot / (rNorm * cNorm);
					this.matrix[r][c] = sim;
					this.matrix[c][r] = sim;
				}
			}
		}

		getCentrality() {
			const size = this.matrix.length;
			if (size <= 1) return Array.from({ length: size }, () => 0);
			return this.matrix.map((row, rIdx) => {
				const sum =
					row.reduce((total, val) => total + val, 0) - row[rIdx];
				return sum / (size - 1);
			});
		}

		getTopSimilar(trackIndex, limit = 5) {
			const row = this.matrix[trackIndex];
			if (!row) return [];
			return row
				.map((similarity, index) => ({ index, similarity }))
				.filter((item) => item.index !== trackIndex)
				.sort((a, b) => b.similarity - a.similarity)
				.slice(0, limit);
		}
	}

	// Precompute all values
	const space = new FeatureSpace(TRACKS);
	const centrality = space.getCentrality();

	// Clamp min-max centrality
	const minCentrality = Math.min(...centrality);
	const maxCentrality = Math.max(...centrality);
	const popularityProxy = centrality.map((val) => {
		if (maxCentrality === minCentrality) return 0.5;
		return Math.min(
			1,
			Math.max(
				0,
				(val - minCentrality) / (maxCentrality - minCentrality),
			),
		);
	});

	// Weighted impact computed dynamically
	const clusterWeightedImpact = (() => {
		const map = {};
		CLUSTERS.forEach((c) => {
			map[c.cluster] = { sum: 0, count: 0 };
		});
		TRACKS.forEach((t, i) => {
			if (map[t.cluster]) {
				const weight = popularityProxy[i] * 0.85 + 0.15;
				map[t.cluster].sum += weight;
				map[t.cluster].count += 1;
			}
		});
		const total =
			Object.values(map).reduce((sum, item) => sum + item.sum, 0) || 1;
		return Object.keys(map).reduce((res, key) => {
			res[key] = {
				share: map[key].sum / total,
				count: map[key].count,
			};
			return res;
		}, {});
	})();

