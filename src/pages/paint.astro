	}

	// EYEDROPPER
	function pickColor(x,y) {
		const d=ctx.getImageData(x,y,1,1).data;
		setFgColor(rgbToHex(d[0],d[1],d[2]));
		toast(`<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m2 22 1-1h3l9-9"/><path d="M3 21v-3l9-9"/><path d="m15 6 3.4-3.4a2.1 2.1 0 1 1 3 3L18 9l.4.4a2.1 2.1 0 1 1-3 3l-3.8-3.8-2.1 2.1"/></svg> Color picked: ${state.fgColor}`);
	}

	// COLOR
	function setFgColor(hex) {
		if(hex && hex.replace('#','').length===6) { hex = '#'+hex.replace('#',''); }
		if(!hex || hex.length < 4) return;
		state.fgColor = hex;
		const fgEl = document.getElementById('cp-fg-swatch');
		if(fgEl) fgEl.style.background = hex;
		const nfg = document.getElementById('native-fg');
		if(nfg) nfg.value = hex;
		// Update tray swatch
		const ts = document.getElementById('tray-swatch-fg');
		if(ts) ts.style.background = hex;
		if(typeof picker !== 'undefined' && picker.target==='fg') syncPickerFromHex(hex);
	}
	function setBgColor(hex) {
		if(hex && hex.replace('#','').length===6) { hex = '#'+hex.replace('#',''); }
		if(!hex || hex.length < 4) return;
		state.bgColor = hex;
		const bgEl = document.getElementById('cp-bg-swatch');
		if(bgEl) bgEl.style.background = hex;
		const nbg = document.getElementById('native-bg');
		if(nbg) nbg.value = hex;
		// Update tray swatch
		const ts = document.getElementById('tray-swatch-bg');
		if(ts) ts.style.background = hex;
		if(typeof picker !== 'undefined' && picker.target==='bg') syncPickerFromHex(hex);
	}

	// ============================================================
	//  HSV COLOR PICKER
	// ============================================================
	const picker = { h:0, s:0, v:1, target:'fg', dragSq:false, dragHue:false };

	const cpSqCanvas  = document.getElementById('cp-sq-canvas');
	const cpHueCanvas = document.getElementById('cp-hue-canvas');
	const cpSqCursor  = document.getElementById('cp-sq-cursor');
	const cpHueThumb  = document.getElementById('cp-hue-thumb');
	const cpSqCtx     = cpSqCanvas.getContext('2d');
	const cpHueCtx    = cpHueCanvas.getContext('2d');

	function hsvToRgb(h,s,v){
		h/=360; let r,g,b;
		const i=Math.floor(h*6),f=h*6-i,p=v*(1-s),q=v*(1-f*s),t=v*(1-(1-f)*s);
		switch(i%6){case 0:r=v;g=t;b=p;break;case 1:r=q;g=v;b=p;break;case 2:r=p;g=v;b=t;break;case 3:r=p;g=q;b=v;break;case 4:r=t;g=p;b=v;break;case 5:r=v;g=p;b=q;break;}
		return{r:Math.round(r*255),g:Math.round(g*255),b:Math.round(b*255)};
	}
	function rgbToHsv(r,g,b){
		r/=255;g/=255;b/=255;
		const max=Math.max(r,g,b),min=Math.min(r,g,b),d=max-min;
		let h=0,s=max===0?0:d/max,val=max;
		if(max!==min){switch(max){case r:h=((g-b)/d+(g<b?6:0))/6;break;case g:h=((b-r)/d+2)/6;break;case b:h=((r-g)/d+4)/6;break;}}
		return{h:h*360,s,v:val};
	}

	function drawSqGradient(){
		const w=cpSqCanvas.offsetWidth||195, h=cpSqCanvas.offsetHeight||140;
		cpSqCanvas.width=w; cpSqCanvas.height=h;
		const rgb=hsvToRgb(picker.h,1,1);
		const hStr=`rgb(${rgb.r},${rgb.g},${rgb.b})`;
		const gH=cpSqCtx.createLinearGradient(0,0,w,0);
		gH.addColorStop(0,'#fff'); gH.addColorStop(1,hStr);
		cpSqCtx.fillStyle=gH; cpSqCtx.fillRect(0,0,w,h);
		const gV=cpSqCtx.createLinearGradient(0,0,0,h);
		gV.addColorStop(0,'rgba(0,0,0,0)'); gV.addColorStop(1,'#000');
		cpSqCtx.fillStyle=gV; cpSqCtx.fillRect(0,0,w,h);
		cpSqCursor.style.left=(picker.s*w)+'px';
		cpSqCursor.style.top=((1-picker.v)*h)+'px';
	}
	function drawHueGradient(){
		const w=cpHueCanvas.offsetWidth||195, h=12;
		cpHueCanvas.width=w; cpHueCanvas.height=h;
		const g=cpHueCtx.createLinearGradient(0,0,w,0);
		['#f00','#ff0','#0f0','#0ff','#00f','#f0f','#f00'].forEach((c,i)=>g.addColorStop(i/6,c));
		cpHueCtx.fillStyle=g; cpHueCtx.fillRect(0,0,w,h);
		cpHueThumb.style.left=((picker.h/360)*w)+'px';
		const hRgb=hsvToRgb(picker.h,1,1);
		cpHueThumb.style.background=`rgb(${hRgb.r},${hRgb.g},${hRgb.b})`;
	}

	function applyPickerColor(){
		const rgb=hsvToRgb(picker.h,picker.s,picker.v);
		const hex=rgbToHex(rgb.r,rgb.g,rgb.b);
		document.getElementById('cp-hex').value=hex.replace('#','');
		document.getElementById('cp-r').value=rgb.r;
		document.getElementById('cp-g').value=rgb.g;
		document.getElementById('cp-b').value=rgb.b;
		if(picker.target==='fg'){state.fgColor=hex;document.getElementById('cp-fg-swatch').style.background=hex;document.getElementById('native-fg').value=hex;}
		else{state.bgColor=hex;document.getElementById('cp-bg-swatch').style.background=hex;document.getElementById('native-bg').value=hex;}
		drawSqGradient();
		drawHueGradient();
	}
	function syncPickerFromHex(hex){
		const rgb=hexToRgb(hex);
		const hsv=rgbToHsv(rgb.r,rgb.g,rgb.b);
		picker.h=hsv.h; picker.s=hsv.s; picker.v=hsv.v;
		document.getElementById('cp-hex').value=hex.replace('#','');
		document.getElementById('cp-r').value=rgb.r;
		document.getElementById('cp-g').value=rgb.g;
		document.getElementById('cp-b').value=rgb.b;
		drawSqGradient(); drawHueGradient();
	}

	function handleSqInteract(clientX, clientY){
		const rect=cpSqCanvas.getBoundingClientRect();
		picker.s=clamp((clientX-rect.left)/rect.width,0,1);
		picker.v=1-clamp((clientY-rect.top)/rect.height,0,1);
		applyPickerColor();
	}
	function handleHueInteract(clientX){
		const rect=cpHueCanvas.getBoundingClientRect();
		picker.h=clamp((clientX-rect.left)/rect.width,0,1)*360;
		applyPickerColor();
	}

	// Mouse drag on SV square
	cpSqCanvas.addEventListener('mousedown',e=>{e.stopPropagation();picker.dragSq=true;handleSqInteract(e.clientX,e.clientY);});
	cpHueCanvas.addEventListener('mousedown',e=>{e.stopPropagation();picker.dragHue=true;handleHueInteract(e.clientX);});
	document.addEventListener('mousemove',e=>{if(picker.dragSq)handleSqInteract(e.clientX,e.clientY);if(picker.dragHue)handleHueInteract(e.clientX);});
	document.addEventListener('mouseup',()=>{picker.dragSq=false;picker.dragHue=false;});
	// Touch on SV square
	cpSqCanvas.addEventListener('touchstart',e=>{e.preventDefault();e.stopPropagation();picker.dragSq=true;const t=e.touches[0];handleSqInteract(t.clientX,t.clientY);},{passive:false});
	cpSqCanvas.addEventListener('touchmove',e=>{e.preventDefault();if(picker.dragSq){const t=e.touches[0];handleSqInteract(t.clientX,t.clientY);}},{passive:false});
	cpSqCanvas.addEventListener('touchend',e=>{e.preventDefault();picker.dragSq=false;},{passive:false});
	cpHueCanvas.addEventListener('touchstart',e=>{e.preventDefault();e.stopPropagation();picker.dragHue=true;const t=e.touches[0];handleHueInteract(t.clientX);},{passive:false});
	cpHueCanvas.addEventListener('touchmove',e=>{e.preventDefault();if(picker.dragHue){const t=e.touches[0];handleHueInteract(t.clientX);}},{passive:false});
	cpHueCanvas.addEventListener('touchend',e=>{e.preventDefault();picker.dragHue=false;},{passive:false});

	// FG/BG tabs
	function setPickerTarget(target){
		picker.target=target;
		document.getElementById('cp-tab-fg').classList.toggle('active',target==='fg');
		document.getElementById('cp-tab-bg').classList.toggle('active',target==='bg');
		document.getElementById('cp-fg-swatch').classList.toggle('cp-active',target==='fg');
		document.getElementById('cp-bg-swatch').classList.toggle('cp-active',target==='bg');
		const hex=target==='fg'?state.fgColor:state.bgColor;
		syncPickerFromHex(hex);
	}
	document.getElementById('cp-tab-fg').addEventListener('click',()=>setPickerTarget('fg'));
	document.getElementById('cp-tab-bg').addEventListener('click',()=>setPickerTarget('bg'));
	document.getElementById('cp-fg-swatch').addEventListener('click',()=>setPickerTarget('fg'));
	document.getElementById('cp-bg-swatch').addEventListener('click',()=>setPickerTarget('bg'));

	// Swap / Reset
	document.getElementById('cp-swap').addEventListener('click',()=>{const t=state.fgColor;setFgColor(state.bgColor);setBgColor(t);});
	document.getElementById('cp-reset').addEventListener('click',()=>{setFgColor('#ffffff');setBgColor('#000000');});

	// Hex input
	document.getElementById('cp-hex').addEventListener('change',e=>{
		const v=e.target.value.replace('#','');
		if(!/^[0-9a-fA-F]{6}$/.test(v))return;
		if(picker.target==='fg')setFgColor('#'+v);else setBgColor('#'+v);
	});
	// RGB inputs
	['cp-r','cp-g','cp-b'].forEach(id=>{
		document.getElementById(id).addEventListener('change',()=>{
			const r=clamp(+document.getElementById('cp-r').value,0,255);
			const g=clamp(+document.getElementById('cp-g').value,0,255);
			const b=clamp(+document.getElementById('cp-b').value,0,255);
			const hex=rgbToHex(r,g,b);
			if(picker.target==='fg')setFgColor(hex);else setBgColor(hex);
		});
	});

	// Native pickers
	document.getElementById('native-fg').addEventListener('input',e=>setFgColor(e.target.value));
	document.getElementById('native-bg').addEventListener('input',e=>setBgColor(e.target.value));

	// Long-press on FG/BG swatch opens native picker
	let swatchHold=null;
	['cp-fg-swatch','cp-bg-swatch'].forEach(id=>{
		const el=document.getElementById(id);
		el.addEventListener('mousedown',e=>{
			swatchHold=setTimeout(()=>{
				const nid=id==='cp-fg-swatch'?'native-fg':'native-bg';
				document.getElementById(nid).click();
			},400);
		});
		el.addEventListener('mouseup',()=>{clearTimeout(swatchHold);});
		el.addEventListener('mouseleave',()=>{clearTimeout(swatchHold);});
	});

	// Palette
	const swatchGrid=document.getElementById('swatch-grid');
	PALETTE.forEach(col=>{
		const cell=document.createElement('div');
		cell.className='swatch-cell'; cell.style.background=col; cell.title=col;
		cell.addEventListener('click',e=>{if(e.altKey||picker.target==='bg')setBgColor(col);else setFgColor(col);});
		swatchGrid.appendChild(cell);
	});

	// Init picker
	function initPicker(){
		drawSqGradient();
		drawHueGradient();
	}
	window.addEventListener('resize',()=>{drawSqGradient();drawHueGradient();});

	// ============================================================
	//  FILTERS
	// ============================================================
	function applyGaussianBlur(radius) {
		pushUndo();
		const lctx=activeCtx();
		const w=state.canvasW, h=state.canvasH;
		const src=lctx.getImageData(0,0,w,h);
		const dst=lctx.createImageData(w,h);
		const sd=src.data, dd=dst.data;
		const r=Math.round(radius), size=2*r+1;
		const kernel=[]; let sum=0;
		for(let i=0;i<size;i++){const g=Math.exp(-(i-r)*(i-r)/(2*r*r));kernel.push(g);sum+=g;}
		const k=kernel.map(v=>v/sum);
		const tmp=new Float32Array(w*h*4);
		// horizontal pass
		for(let y=0;y<h;y++){
			for(let x=0;x<w;x++){
				let R=0,G=0,B=0,A=0;
				for(let ki=0;ki<size;ki++){
					const sx=clamp(x+ki-r,0,w-1);
					const si=(y*w+sx)*4;
					const kv=k[ki];
					R+=sd[si]*kv; G+=sd[si+1]*kv; B+=sd[si+2]*kv; A+=sd[si+3]*kv;
				}
				const di=(y*w+x)*4;
				tmp[di]=R; tmp[di+1]=G; tmp[di+2]=B; tmp[di+3]=A;
			}
		}
		// vertical pass
		for(let y=0;y<h;y++){
			for(let x=0;x<w;x++){
				let R=0,G=0,B=0,A=0;
				for(let ki=0;ki<size;ki++){
					const sy=clamp(y+ki-r,0,h-1);
					const si=(sy*w+x)*4;
					const kv=k[ki];
					R+=tmp[si]*kv; G+=tmp[si+1]*kv; B+=tmp[si+2]*kv; A+=tmp[si+3]*kv;
				}
				const di=(y*w+x)*4;
				dd[di]=R; dd[di+1]=G; dd[di+2]=B; dd[di+3]=A;
			}
		}
		lctx.putImageData(dst,0,0);
		renderAllLayers(); updateLayerThumbs();
		toast('Blur applied');
	}

	function applySharpen() {
		pushUndo();
		const lctx=activeCtx();
		const w=state.canvasW, h=state.canvasH;
		const src=lctx.getImageData(0,0,w,h);
		const dst=lctx.createImageData(w,h);
		const sd=src.data, dd=dst.data;
		const kernel=[0,-1,0,-1,5,-1,0,-1,0];
		for(let y=1;y<h-1;y++){
			for(let x=1;x<w-1;x++){
				let R=0,G=0,B=0;
				for(let ky=0;ky<3;ky++){
					for(let kx=0;kx<3;kx++){
						const si=((y+ky-1)*w+(x+kx-1))*4;
						const kv=kernel[ky*3+kx];
						R+=sd[si]*kv; G+=sd[si+1]*kv; B+=sd[si+2]*kv;
					}
				}
				const di=(y*w+x)*4;
				dd[di]=clamp(R,0,255); dd[di+1]=clamp(G,0,255); dd[di+2]=clamp(B,0,255); dd[di+3]=sd[di+3];
			}
		}
		lctx.putImageData(dst,0,0);
		renderAllLayers(); updateLayerThumbs();
		toast('Sharpen applied');
	}

	function applyNoise(amount) {
		pushUndo();
		const lctx=activeCtx();
		const id=lctx.getImageData(0,0,state.canvasW,state.canvasH);
		const d=id.data;
		for(let i=0;i<d.length;i+=4){
			const n=(Math.random()-0.5)*amount*2;
			d[i]=clamp(d[i]+n,0,255); d[i+1]=clamp(d[i+1]+n,0,255); d[i+2]=clamp(d[i+2]+n,0,255);
		}
		lctx.putImageData(id,0,0);
		renderAllLayers(); updateLayerThumbs();
		toast('Noise applied');
	}

	function applyPixelate(blockSize) {
		pushUndo();
		const lctx=activeCtx();
		const w=state.canvasW, h=state.canvasH;
		const id=lctx.getImageData(0,0,w,h);
		const d=id.data;
		for(let y=0;y<h;y+=blockSize){
			for(let x=0;x<w;x+=blockSize){
				const si=(y*w+x)*4;
				const r=d[si],g=d[si+1],b=d[si+2],a=d[si+3];
				for(let by=0;by<blockSize&&y+by<h;by++){
					for(let bx=0;bx<blockSize&&x+bx<w;bx++){
						const di=((y+by)*w+(x+bx))*4;
						d[di]=r;d[di+1]=g;d[di+2]=b;d[di+3]=a;
					}
				}
			}
		}
		lctx.putImageData(id,0,0);
		renderAllLayers(); updateLayerThumbs();
		toast('Pixelate applied');
	}

	// ============================================================
	//  CANVAS EVENTS
	// ============================================================
	let lassoPoints=[];

	canvasArea.addEventListener('mousedown', (e) => {
		if(e.button===1||state.spaceDown) {
			state.isPanning=true;
			state.startX=e.clientX-state.panX;
			state.startY=e.clientY-state.panY;
			canvasArea.style.cursor='grabbing'; return;
		}
		if(e.button!==0) return;
		const {x,y}=evToCanvas(e);
		const t=state.tool;
		state.isDrawing=true; state.startX=x; state.startY=y; state.lastX=x; state.lastY=y;

		if(t==='brush'||t==='pencil'||t==='eraser') {
			pushUndo();
			const lctx=activeCtx(); lctx.save();
			if(t==='eraser') {
				lctx.globalCompositeOperation='destination-out';
				lctx.globalAlpha=state.brushOpacity/100;
				if(state.brushMode==='soft') drawSoftBrush(lctx,x,y,state.brushSize);
				else { lctx.fillStyle='rgba(0,0,0,1)'; lctx.beginPath(); if(state.brushMode==='square') lctx.fillRect(x-state.brushSize/2,y-state.brushSize/2,state.brushSize,state.brushSize); else {lctx.arc(x,y,state.brushSize/2,0,Math.PI*2);lctx.fill();} }
			} else if(t==='pencil') {
				lctx.globalCompositeOperation='source-over'; drawPencilSegment(lctx,x,y,x,y);
			} else {
				lctx.globalCompositeOperation='source-over'; setBrushStyle(lctx);
				if(state.brushMode==='soft') drawSoftBrush(lctx,x,y,state.brushSize);
				else { lctx.beginPath(); lctx.arc(x,y,state.brushSize/2,0,Math.PI*2); lctx.fill(); }
			}
			lctx.restore(); renderAllLayers();
		}
		if(t==='fill')       { pushUndo(); floodFill(activeCtx(),x,y,state.fgColor); renderAllLayers(); updateLayerThumbs(); }
		if(t==='eyedropper') { pickColor(x,y); }
		if(t==='move')       { pushUndo(); startMove(x,y); }
		if(t==='zoom')       { zoomAt(e.altKey?1/1.3:1.3, e.clientX, e.clientY); }
		if(t==='lasso')      { pushUndo(); lassoPoints=[{x,y}]; state.selection=null; sctx.clearRect(0,0,state.canvasW,state.canvasH); }
	});

	canvasArea.addEventListener('mousemove', (e) => {
		const {x,y}=evToCanvas(e);
		cursorIndicator.textContent=`${clamp(x,0,state.canvasW-1)}, ${clamp(y,0,state.canvasH-1)}`;

		if(state.isPanning) {
			state.panX=e.clientX-state.startX;
			state.panY=e.clientY-state.startY;
			applyViewport(); return;
		}
		if(!state.isDrawing) { updateCursorStyle(e); return; }
		const t=state.tool;

		if(t==='brush'||t==='eraser') {
			const lctx=activeCtx(); lctx.save();
			if(t==='eraser') {
				lctx.globalCompositeOperation='destination-out'; lctx.globalAlpha=state.brushOpacity/100;
				if(state.brushMode==='soft') {
					const steps=Math.ceil(Math.hypot(x-state.lastX,y-state.lastY));
					for(let s=0;s<=steps;s++) drawSoftBrush(lctx,state.lastX+(x-state.lastX)*s/steps,state.lastY+(y-state.lastY)*s/steps,state.brushSize);
				} else { lctx.strokeStyle='rgba(0,0,0,1)'; lctx.lineWidth=state.brushSize; lctx.lineCap=state.brushMode==='square'?'square':'round'; drawLine(lctx,state.lastX,state.lastY,x,y); }
			} else {
				lctx.globalCompositeOperation='source-over';
				if(state.brushMode==='soft') {
					const steps=Math.ceil(Math.hypot(x-state.lastX,y-state.lastY));
					for(let s=0;s<=steps;s++) drawSoftBrush(lctx,state.lastX+(x-state.lastX)*s/steps,state.lastY+(y-state.lastY)*s/steps,state.brushSize);
				} else { setBrushStyle(lctx); drawLine(lctx,state.lastX,state.lastY,x,y); }
			}
			lctx.restore(); renderAllLayers();
		}
		if(t==='pencil')  { drawPencilSegment(activeCtx(),state.lastX,state.lastY,x,y); renderAllLayers(); }
		if(t==='rect'||t==='ellipse'||t==='line') { drawShapeOverlay(state.startX,state.startY,x,y,t); renderAllLayers(); ctx.drawImage(overlayCanvas,0,0); }
		if(t==='select')  { const rx=Math.min(state.startX,x),ry=Math.min(state.startY,y); state.selection={x:rx,y:ry,w:Math.abs(x-state.startX),h:Math.abs(y-state.startY)}; drawSelection(); }
		if(t==='move')    { doMove(x,y); }
		if(t==='lasso')   {
			lassoPoints.push({x,y}); sctx.clearRect(0,0,state.canvasW,state.canvasH); sctx.save();
			sctx.strokeStyle='rgba(255,255,255,0.8)'; sctx.lineWidth=1; sctx.setLineDash([4,3]);
			sctx.beginPath(); lassoPoints.forEach((p,i)=>i===0?sctx.moveTo(p.x,p.y):sctx.lineTo(p.x,p.y)); sctx.stroke(); sctx.restore();
		}
		if(t==='gradient') { drawGradientOverlay(state.startX,state.startY,x,y); renderAllLayers(); ctx.drawImage(overlayCanvas,0,0); }
		state.lastX=x; state.lastY=y;
	});

	canvasArea.addEventListener('mouseup', (e) => {
		if(state.isPanning) { state.isPanning=false; updateCursorStyle(e); return; }
		if(!state.isDrawing) return;
		state.isDrawing=false;
		const {x,y}=evToCanvas(e); const t=state.tool;

		if(t==='rect'||t==='ellipse'||t==='line') { drawShapeOverlay(state.startX,state.startY,x,y,t); commitOverlay(); }
		if(t==='gradient') {
			if(Math.hypot(x-state.startX,y-state.startY)>2) { pushUndo(); drawGradient(state.startX,state.startY,x,y); renderAllLayers(); updateLayerThumbs(); }
			octx.clearRect(0,0,state.canvasW,state.canvasH);
		}
		if(t==='move')    { state.moveLayerSnapshot=null; updateLayerThumbs(); }
		if(t==='lasso'&&lassoPoints.length>3) {
			const xs=lassoPoints.map(p=>p.x),ys=lassoPoints.map(p=>p.y);
			const sx=Math.min(...xs),sy=Math.min(...ys);
			state.selection={x:sx,y:sy,w:Math.max(...xs)-sx,h:Math.max(...ys)-sy};
			lassoPoints=[]; startSelectionAnim();
		}
		if(t==='select') {
			if(state.selection&&state.selection.w>2&&state.selection.h>2) startSelectionAnim();
			else { state.selection=null; sctx.clearRect(0,0,state.canvasW,state.canvasH); }
		}
		if(t==='brush'||t==='pencil'||t==='eraser') updateLayerThumbs();
	});

	canvasArea.addEventListener('click', (e) => {
		const {x,y}=evToCanvas(e);
		if(state.tool==='text') { state.textPos={x,y}; openModal('modal-text'); }
	});

	canvasArea.addEventListener('mouseleave',()=>{ if(state.isPanning){state.isPanning=false; updateCursorStyle();} });
	canvasArea.addEventListener('wheel',(e)=>{
		e.preventDefault();
		zoomAt(e.deltaY<0?1.12:1/1.12, e.clientX, e.clientY);
	},{passive:false});
	canvasArea.addEventListener('contextmenu',e=>e.preventDefault());

	// ============================================================
	//  TOUCH EVENTS — single finger = draw, two fingers = pan + pinch zoom
	// ============================================================
	let activeTouches = {};
	let lastPinchDist = null;
	let touchStartCX = 0, touchStartCY = 0;

	function clientToCanvas(clientX, clientY) {
		const rect = mainCanvas.getBoundingClientRect();
		return { x: Math.floor((clientX-rect.left)/state.zoom), y: Math.floor((clientY-rect.top)/state.zoom) };
	}
	function getTouches() { return Object.values(activeTouches); }

	canvasArea.addEventListener('touchstart', e => {
		e.preventDefault();
		Array.from(e.changedTouches).forEach(t => { activeTouches[t.identifier] = {x:t.clientX,y:t.clientY}; });
		const count = getTouches().length;
		if(count === 1) {
			const t = e.changedTouches[0];
			const evt = { clientX:t.clientX, clientY:t.clientY, button:0, altKey:false, stopPropagation:()=>{} };
			// Simulate mousedown
			const md = new MouseEvent('mousedown', {clientX:t.clientX, clientY:t.clientY, button:0, bubbles:true});
			canvasArea.dispatchEvent(md);
		} else if(count === 2) {
			// End single-touch drawing if in progress
			if(state.isDrawing) { state.isDrawing = false; }
			const touches = getTouches();
			lastPinchDist = Math.hypot(touches[1].x-touches[0].x, touches[1].y-touches[0].y);
			touchStartCX = (touches[0].x+touches[1].x)/2 - state.panX;
			touchStartCY = (touches[0].y+touches[1].y)/2 - state.panY;
			state.isPanning = false; // will handle manually below
		}
	}, {passive:false});

	canvasArea.addEventListener('touchmove', e => {
		e.preventDefault();
		Array.from(e.changedTouches).forEach(t => { if(activeTouches[t.identifier]) activeTouches[t.identifier] = {x:t.clientX,y:t.clientY}; });
		const count = getTouches().length;
		if(count === 1 && lastPinchDist === null) {
			const t = e.changedTouches[0];
			const mm = new MouseEvent('mousemove', {clientX:t.clientX, clientY:t.clientY, buttons:1, bubbles:true});
			canvasArea.dispatchEvent(mm);
		} else if(count >= 2) {
			const touches = getTouches();
			const cx = (touches[0].x+touches[1].x)/2;
			const cy = (touches[0].y+touches[1].y)/2;
			const dist = Math.hypot(touches[1].x-touches[0].x, touches[1].y-touches[0].y);
			// Pan
			state.panX = cx - touchStartCX;
			state.panY = cy - touchStartCY;
			// Pinch zoom
			if(lastPinchDist && dist > 0) {
				const factor = dist / lastPinchDist;
				const rect = canvasArea.getBoundingClientRect();
				const ax = cx - rect.left, ay = cy - rect.top;
				const nz = clamp(state.zoom*factor, 0.04, 32);
				state.panX = ax - (ax-state.panX)*(nz/state.zoom);
				state.panY = ay - (ay-state.panY)*(nz/state.zoom);
				state.zoom = nz;
				touchStartCX = cx - state.panX;
				touchStartCY = cy - state.panY;
			}
			lastPinchDist = dist;
			applyViewport();
		}
	}, {passive:false});

	canvasArea.addEventListener('touchend', e => {
		e.preventDefault();
		Array.from(e.changedTouches).forEach(t => { delete activeTouches[t.identifier]; });
		const count = getTouches().length;
		if(count === 0) {
			lastPinchDist = null;
			if(state.isDrawing) {
				const t = e.changedTouches[0];
				const mu = new MouseEvent('mouseup', {clientX:t.clientX, clientY:t.clientY, button:0, bubbles:true});
				canvasArea.dispatchEvent(mu);
			}
		}
	}, {passive:false});
	canvasArea.addEventListener('touchcancel', e => {
		Array.from(e.changedTouches).forEach(t => { delete activeTouches[t.identifier]; });
		lastPinchDist = null; state.isDrawing = false; state.isPanning = false;
	}, {passive:false});

	function updateCursorStyle(e) {
		const m={brush:'crosshair',pencil:'crosshair',eraser:'crosshair',fill:'cell',
			eyedropper:'crosshair',gradient:'crosshair',rect:'crosshair',ellipse:'crosshair',
			line:'crosshair',text:'text',select:'crosshair',move:'move',
			lasso:'crosshair',zoom:e&&e.altKey?'zoom-out':'zoom-in',hand:'grab'};
		canvasArea.style.cursor=m[state.tool]||'default';
	}

	// ============================================================
	//  TOOLS
	// ============================================================
	const optMap={
		brush:['opt-brush','opt-brush-mode'], pencil:['opt-brush'],
		eraser:['opt-brush','opt-brush-mode'],
		rect:['opt-shape'], ellipse:['opt-shape'], line:['opt-shape'],
		text:['opt-text'], select:['opt-select'], lasso:['opt-select'],
		gradient:['opt-gradient'], zoom:['opt-zoom'],
		fill:[], eyedropper:[], move:[], hand:[],
	};
	const trayOptions = document.getElementById('tray-options');
	function selectTool(tool) {
		state.tool=tool;
		document.querySelectorAll('.tool-btn').forEach(b=>b.classList.toggle('active',b.dataset.tool===tool));
		document.querySelectorAll('.opt-section').forEach(s=>s.classList.remove('visible'));
		const sections = optMap[tool]||[];
		(sections).forEach(id=>{const el=document.getElementById(id);if(el)el.classList.add('visible');});
		// Show/hide the tray-options bar
		trayOptions.style.display = sections.length > 0 ? 'flex' : 'none';
		updateCursorStyle();
	}
	document.querySelectorAll('.tool-btn').forEach(btn=>btn.addEventListener('click',()=>selectTool(btn.dataset.tool)));

	// ============================================================
	//  OPTION BAR CONTROLS
	// ============================================================
	const brushSizeEl=document.getElementById('brush-size');
	const brushSizeVal=document.getElementById('brush-size-val');
	brushSizeEl.addEventListener('input',()=>{state.brushSize=+brushSizeEl.value;brushSizeVal.textContent=state.brushSize+'px';});

	const brushOpacEl=document.getElementById('brush-opacity');
	const brushOpacVal=document.getElementById('brush-opacity-val');
	brushOpacEl.addEventListener('input',()=>{state.brushOpacity=+brushOpacEl.value;brushOpacVal.textContent=state.brushOpacity+'%';});

	const shapeStrokeSz=document.getElementById('shape-stroke-size');
	const shapeStrokeVal=document.getElementById('shape-stroke-val');
	shapeStrokeSz.addEventListener('input',()=>{state.strokeSize=+shapeStrokeSz.value;shapeStrokeVal.textContent=state.strokeSize+'px';});

	const textSizeEl=document.getElementById('text-size');
	const textSizeVal=document.getElementById('text-size-val');
	textSizeEl.addEventListener('input',()=>{state.textSize=+textSizeEl.value;textSizeVal.textContent=state.textSize+'px';});

	['round','square','soft'].forEach(m=>{
		document.getElementById('mode-'+m).addEventListener('click',()=>{
			state.brushMode=m;
			['round','square','soft'].forEach(n=>document.getElementById('mode-'+n).classList.toggle('active',n===m));
		});
	});
	['fill','stroke','both'].forEach(m=>{
		document.getElementById('shape-'+m).addEventListener('click',()=>{
			state.shapeMode=m;
			['fill','stroke','both'].forEach(n=>document.getElementById('shape-'+n).classList.toggle('active',n===m));
		});
	});
	document.getElementById('text-font').addEventListener('change',e=>{state.textFont=e.target.value;});
	document.getElementById('text-bold').addEventListener('click',function(){state.textBold=!state.textBold;this.classList.toggle('active',state.textBold);});
	document.getElementById('text-italic').addEventListener('click',function(){state.textItalic=!state.textItalic;this.classList.toggle('active',state.textItalic);});
	document.getElementById('gradient-type').addEventListener('change',e=>{state.gradientType=e.target.value;});

	// Zoom btns
	const zca=()=>{const r=canvasArea.getBoundingClientRect();return{x:r.left+r.width/2,y:r.top+r.height/2};};
	document.getElementById('zoom-in-btn').addEventListener('click',()=>{const c=zca();zoomAt(1.3,c.x,c.y);});
	document.getElementById('zoom-out-btn').addEventListener('click',()=>{const c=zca();zoomAt(1/1.3,c.x,c.y);});
	document.getElementById('zoom-fit-btn').addEventListener('click',fitToScreen);
	document.getElementById('zoom-100-btn').addEventListener('click',()=>{const r=canvasArea.getBoundingClientRect();const cx=r.left+r.width/2,cy=r.top+r.height/2;state.zoom=1;state.panX=cx-state.canvasW/2;state.panY=cy-state.canvasH/2;applyViewport();});
	document.getElementById('zoom-plus-ind').addEventListener('click',()=>{const c=zca();zoomAt(1.25,c.x,c.y);});
	document.getElementById('zoom-minus-ind').addEventListener('click',()=>{const c=zca();zoomAt(1/1.25,c.x,c.y);});

	// Select opts
	document.getElementById('action-crop-sel').addEventListener('click',()=>{if(state.selection)cropToSelection();});
	document.getElementById('action-copy-sel').addEventListener('click',()=>{if(!state.selection)return;const{x,y,w,h}=state.selection;state.clipboardData=ctx.getImageData(x,y,w,h);toast('Copied selection');});
	document.getElementById('action-cut-sel').addEventListener('click',()=>{
		if(!state.selection)return;const{x,y,w,h}=state.selection;
		state.clipboardData=ctx.getImageData(x,y,w,h);pushUndo();activeCtx().clearRect(x,y,w,h);renderAllLayers();updateLayerThumbs();toast('Cut selection');
	});
	document.getElementById('action-deselect').addEventListener('click',()=>{state.selection=null;sctx.clearRect(0,0,state.canvasW,state.canvasH);cancelAnimationFrame(selAnimFrame);});

	function cropToSelection() {
		const{x,y,w,h}=state.selection;pushUndo();
		state.layers=state.layers.map(l=>{
			const o=document.createElement('canvas');o.width=w;o.height=h;
			const c=o.getContext('2d');c.drawImage(l.canvas,-x,-y);
			return{canvas:o,ctx:c,name:l.name,visible:l.visible,opacity:l.opacity||100};
		});
		state.canvasW=w;state.canvasH=h;
		[mainCanvas,overlayCanvas,selCanvas,checkerCanvas].forEach(c=>{c.width=w;c.height=h;});
		shadowEl.style.width=w+'px';shadowEl.style.height=h+'px';
		drawCheckerboard();state.selection=null;sctx.clearRect(0,0,w,h);
		renderLayersPanel();renderAllLayers();fitToScreen();
		infoSize.textContent=`${w} × ${h}`;toast(`Cropped to ${w}×${h}`);
	}

	// ============================================================
	//  MENUS
	// ============================================================
	function setupMenu(btnId,dropId) {
		const btn=document.getElementById(btnId),drop=document.getElementById(dropId);
		btn.addEventListener('click',e=>{
			e.stopPropagation();
			const isOpen=drop.classList.toggle('is-open');
			btn.classList.toggle('is-open',isOpen);
			document.querySelectorAll('.dropdown').forEach(d=>{if(d!==drop)d.classList.remove('is-open');});
			document.querySelectorAll('.nav-menu-btn').forEach(b=>{if(b!==btn)b.classList.remove('is-open');});
		});
	}
	['file','edit','image','layer','select','filter','view'].forEach(m=>setupMenu('btn-menu-'+m,'dropdown-'+m));
	document.addEventListener('click',()=>{
		document.querySelectorAll('.dropdown').forEach(d=>d.classList.remove('is-open'));
		document.querySelectorAll('.nav-menu-btn').forEach(b=>b.classList.remove('is-open'));
	});
	document.querySelectorAll('.dropdown').forEach(d=>d.addEventListener('click',e=>e.stopPropagation()));
	function closeDropdowns(){document.querySelectorAll('.dropdown').forEach(d=>d.classList.remove('is-open'));document.querySelectorAll('.nav-menu-btn').forEach(b=>b.classList.remove('is-open'));}

	// FILE
	document.getElementById('action-new').addEventListener('click',()=>{openModal('modal-new');closeDropdowns();});
	document.getElementById('action-open').addEventListener('click',()=>{fileInput.click();closeDropdowns();});
	document.getElementById('action-save-png').addEventListener('click',()=>{exportImage('png');closeDropdowns();});
	document.getElementById('action-save-jpg').addEventListener('click',()=>{exportImage('jpeg');closeDropdowns();});
	document.getElementById('action-flatten').addEventListener('click',()=>{flattenLayers();closeDropdowns();});

	fileInput.addEventListener('change',e=>{
		const file=e.target.files[0];if(!file)return;
		const url=URL.createObjectURL(file);
		const img=new Image();
		img.onload=()=>{
			state.layers=[];state.activeLayerIdx=0;state.canvasW=img.width;state.canvasH=img.height;
			[mainCanvas,overlayCanvas,selCanvas,checkerCanvas].forEach(c=>{c.width=img.width;c.height=img.height;});
			shadowEl.style.width=img.width+'px';shadowEl.style.height=img.height+'px';
			drawCheckerboard();addLayer('Background');activeCtx().drawImage(img,0,0);
			renderAllLayers();updateLayerThumbs();fitToScreen();
			infoSize.textContent=`${img.width} × ${img.height}`;
			state.undoStack=[];state.redoStack=[];updateUndoButtons();
			toast(`Opened: ${file.name}`);URL.revokeObjectURL(url);
		};img.src=url;e.target.value='';
	});

	function exportImage(format) {
		flattenToTemp(temp=>{
			const a=document.createElement('a');
			a.download='paint-export.'+(format==='jpeg'?'jpg':'png');
			a.href=temp.toDataURL('image/'+format,format==='jpeg'?0.95:1);
			a.click();toast(`Exported as ${format.toUpperCase()}`);
		});
	}
	function flattenToTemp(cb) {
		const t=document.createElement('canvas');t.width=state.canvasW;t.height=state.canvasH;
		const tc=t.getContext('2d');
		for(let i=state.layers.length-1;i>=0;i--){if(state.layers[i].visible){tc.save();tc.globalAlpha=(state.layers[i].opacity||100)/100;tc.drawImage(state.layers[i].canvas,0,0);tc.restore();}}
		cb(t);
	}
	function flattenLayers() {
		pushUndo();flattenToTemp(temp=>{
			const o=document.createElement('canvas');o.width=state.canvasW;o.height=state.canvasH;
			const c=o.getContext('2d');c.drawImage(temp,0,0);
			state.layers=[{canvas:o,ctx:c,name:'Flattened',visible:true,opacity:100}];
			state.activeLayerIdx=0;
			renderLayersPanel();renderAllLayers();updateLayerThumbs();updateInfo();toast('Layers flattened');
		});
	}

	// EDIT
	document.getElementById('action-undo').addEventListener('click',()=>{undo();closeDropdowns();});
	document.getElementById('action-redo').addEventListener('click',()=>{redo();closeDropdowns();});
	document.getElementById('btn-undo').addEventListener('click',undo);
	document.getElementById('btn-redo').addEventListener('click',redo);
	document.getElementById('action-copy').addEventListener('click',()=>{
		if(state.selection){const{x,y,w,h}=state.selection;state.clipboardData=ctx.getImageData(x,y,w,h);}
		else state.clipboardData=activeCtx().getImageData(0,0,state.canvasW,state.canvasH);
		toast('Copied');closeDropdowns();
	});
	document.getElementById('action-paste').addEventListener('click',()=>{
		if(!state.clipboardData){toast('Nothing to paste');return;}
		pushUndo();addLayer('Pasted');activeCtx().putImageData(state.clipboardData,0,0);
		renderAllLayers();updateLayerThumbs();toast('Pasted');closeDropdowns();
	});
	document.getElementById('action-cut').addEventListener('click',()=>{
		if(state.selection){const{x,y,w,h}=state.selection;state.clipboardData=ctx.getImageData(x,y,w,h);pushUndo();activeCtx().clearRect(x,y,w,h);}
		else{state.clipboardData=activeCtx().getImageData(0,0,state.canvasW,state.canvasH);pushUndo();activeCtx().clearRect(0,0,state.canvasW,state.canvasH);}
		renderAllLayers();updateLayerThumbs();toast('Cut');closeDropdowns();
	});
	document.getElementById('action-clear').addEventListener('click',()=>{pushUndo();activeCtx().clearRect(0,0,state.canvasW,state.canvasH);renderAllLayers();updateLayerThumbs();closeDropdowns();});
	document.getElementById('action-fill-canvas').addEventListener('click',()=>{
		pushUndo();const lctx=activeCtx();lctx.save();lctx.fillStyle=state.fgColor;lctx.globalAlpha=state.brushOpacity/100;
		lctx.fillRect(0,0,state.canvasW,state.canvasH);lctx.restore();renderAllLayers();updateLayerThumbs();closeDropdowns();
	});

	// IMAGE
	document.getElementById('action-resize').addEventListener('click',()=>{document.getElementById('resize-w').value=state.canvasW;document.getElementById('resize-h').value=state.canvasH;openModal('modal-resize');closeDropdowns();});
	document.getElementById('action-flip-h').addEventListener('click',()=>{
		pushUndo();state.layers.forEach(l=>{
			const t=document.createElement('canvas');t.width=state.canvasW;t.height=state.canvasH;
			const tc=t.getContext('2d');tc.save();tc.scale(-1,1);tc.drawImage(l.canvas,-state.canvasW,0);tc.restore();
			l.ctx.clearRect(0,0,state.canvasW,state.canvasH);l.ctx.drawImage(t,0,0);
		});renderAllLayers();updateLayerThumbs();closeDropdowns();toast('Flipped Horizontal');
	});
	document.getElementById('action-flip-v').addEventListener('click',()=>{
		pushUndo();state.layers.forEach(l=>{
			const t=document.createElement('canvas');t.width=state.canvasW;t.height=state.canvasH;
			const tc=t.getContext('2d');tc.save();tc.scale(1,-1);tc.drawImage(l.canvas,0,-state.canvasH);tc.restore();
			l.ctx.clearRect(0,0,state.canvasW,state.canvasH);l.ctx.drawImage(t,0,0);
		});renderAllLayers();updateLayerThumbs();closeDropdowns();toast('Flipped Vertical');
	});
	document.getElementById('action-grayscale').addEventListener('click',()=>{
		pushUndo();state.layers.forEach(l=>{
			const id=l.ctx.getImageData(0,0,state.canvasW,state.canvasH),d=id.data;
			for(let i=0;i<d.length;i+=4){const g=0.299*d[i]+0.587*d[i+1]+0.114*d[i+2];d[i]=d[i+1]=d[i+2]=g;}
			l.ctx.putImageData(id,0,0);
		});renderAllLayers();updateLayerThumbs();closeDropdowns();toast('Grayscale applied');
	});
	document.getElementById('action-invert').addEventListener('click',()=>{
		pushUndo();state.layers.forEach(l=>{
			const id=l.ctx.getImageData(0,0,state.canvasW,state.canvasH),d=id.data;
			for(let i=0;i<d.length;i+=4){d[i]=255-d[i];d[i+1]=255-d[i+1];d[i+2]=255-d[i+2];}
			l.ctx.putImageData(id,0,0);
		});renderAllLayers();updateLayerThumbs();closeDropdowns();toast('Colors inverted');
	});

	// LAYER MENU
	document.getElementById('ml-new').addEventListener('click',()=>{addLayer('Layer '+(state.layers.length+1));closeDropdowns();});
	document.getElementById('ml-dup').addEventListener('click',()=>{
		pushUndo();const src=activeLayer();
		const o=document.createElement('canvas');o.width=state.canvasW;o.height=state.canvasH;
		const c=o.getContext('2d');c.drawImage(src.canvas,0,0);
		state.layers.splice(state.activeLayerIdx,0,{canvas:o,ctx:c,name:src.name+' copy',visible:true,opacity:src.opacity||100});
		renderLayersPanel();renderAllLayers();updateLayerThumbs();updateInfo();closeDropdowns();
	});
	document.getElementById('ml-del').addEventListener('click',()=>{
		if(state.layers.length<=1){toast('Cannot delete the last layer');return;}
		pushUndo();state.layers.splice(state.activeLayerIdx,1);
		state.activeLayerIdx=Math.min(state.activeLayerIdx,state.layers.length-1);
		renderLayersPanel();renderAllLayers();updateInfo();closeDropdowns();
	});
	document.getElementById('ml-merge-down').addEventListener('click',()=>{
		const i=state.activeLayerIdx;
		if(i>=state.layers.length-1){toast('No layer below to merge');return;}
		pushUndo();
		const top=state.layers[i],bot=state.layers[i+1];
		bot.ctx.save();bot.ctx.globalAlpha=(top.opacity||100)/100;bot.ctx.drawImage(top.canvas,0,0);bot.ctx.restore();
		state.layers.splice(i,1);state.activeLayerIdx=i<state.layers.length?i:i-1;
		renderLayersPanel();renderAllLayers();updateInfo();closeDropdowns();toast('Merged down');
	});
	document.getElementById('ml-flatten').addEventListener('click',()=>{flattenLayers();closeDropdowns();});

	// SELECT MENU
	document.getElementById('sel-all').addEventListener('click',()=>{state.selection={x:0,y:0,w:state.canvasW,h:state.canvasH};startSelectionAnim();selectTool('select');closeDropdowns();});
	document.getElementById('sel-deselect').addEventListener('click',()=>{state.selection=null;sctx.clearRect(0,0,state.canvasW,state.canvasH);cancelAnimationFrame(selAnimFrame);closeDropdowns();});
	document.getElementById('sel-copy').addEventListener('click',()=>{document.getElementById('action-copy-sel').click();closeDropdowns();});
	document.getElementById('sel-cut').addEventListener('click',()=>{document.getElementById('action-cut-sel').click();closeDropdowns();});
	document.getElementById('sel-crop').addEventListener('click',()=>{if(state.selection)cropToSelection();closeDropdowns();});

	// FILTER MENU
	document.getElementById('filter-blur').addEventListener('click',()=>{openModal('modal-blur');closeDropdowns();});
	document.getElementById('filter-sharpen').addEventListener('click',()=>{applySharpen();closeDropdowns();});
	document.getElementById('filter-noise').addEventListener('click',()=>{openModal('modal-noise');closeDropdowns();});
	document.getElementById('filter-pixelate').addEventListener('click',()=>{openModal('modal-pixelate');closeDropdowns();});

	// VIEW MENU
	document.getElementById('view-zoom-in').addEventListener('click',()=>{const c=zca();zoomAt(1.3,c.x,c.y);closeDropdowns();});
	document.getElementById('view-zoom-out').addEventListener('click',()=>{const c=zca();zoomAt(1/1.3,c.x,c.y);closeDropdowns();});
	document.getElementById('view-fit').addEventListener('click',()=>{fitToScreen();closeDropdowns();});
	document.getElementById('view-100').addEventListener('click',()=>{document.getElementById('zoom-100-btn').click();closeDropdowns();});

	// LAYER PANEL BTNS
	document.getElementById('btn-layer-add').addEventListener('click',()=>addLayer('Layer '+(state.layers.length+1)));
	document.getElementById('btn-layer-dup').addEventListener('click',()=>document.getElementById('ml-dup').click());
	document.getElementById('btn-layer-del').addEventListener('click',()=>{
		if(state.layers.length<=1){toast('Cannot delete the last layer');return;}
		pushUndo();state.layers.splice(state.activeLayerIdx,1);
		state.activeLayerIdx=Math.min(state.activeLayerIdx,state.layers.length-1);
		renderLayersPanel();renderAllLayers();updateInfo();
	});

	// ============================================================
	//  COLOR
	// ============================================================
	// (Picker setup and palette setup are done above, near setFgColor/setBgColor)
	// Old hex/swap event handlers — replaced by picker system above
	// Swap via keyboard still works (see keyboard section below)

	// ============================================================
	//  MODALS
	// ============================================================
	function openModal(id){document.getElementById(id).classList.add('open');}
	function closeModal(id){document.getElementById(id).classList.remove('open');}

	document.querySelectorAll('.modal-preset').forEach(btn=>btn.addEventListener('click',()=>{
		document.getElementById('new-w').value=btn.dataset.w;
		document.getElementById('new-h').value=btn.dataset.h;
	}));
	document.getElementById('modal-new-cancel').addEventListener('click',()=>closeModal('modal-new'));
	document.getElementById('modal-new-ok').addEventListener('click',()=>{
		const w=clamp(+document.getElementById('new-w').value,1,8000);
		const h=clamp(+document.getElementById('new-h').value,1,8000);
		const bg=document.getElementById('new-bg').value;
		closeModal('modal-new');initCanvas(w,h,bg);toast(`New ${w}×${h} canvas`);
	});

	document.getElementById('modal-resize-cancel').addEventListener('click',()=>closeModal('modal-resize'));
	document.getElementById('modal-resize-ok').addEventListener('click',()=>{
		const nw=clamp(+document.getElementById('resize-w').value,1,8000);
		const nh=clamp(+document.getElementById('resize-h').value,1,8000);
		pushUndo();
		state.layers=state.layers.map(l=>{
			const o=document.createElement('canvas');o.width=nw;o.height=nh;
			const c=o.getContext('2d');c.drawImage(l.canvas,0,0);
			return{canvas:o,ctx:c,name:l.name,visible:l.visible,opacity:l.opacity||100};
		});
		state.canvasW=nw;state.canvasH=nh;
		[mainCanvas,overlayCanvas,selCanvas,checkerCanvas].forEach(c=>{c.width=nw;c.height=nh;});
		shadowEl.style.width=nw+'px';shadowEl.style.height=nh+'px';
		drawCheckerboard();renderLayersPanel();renderAllLayers();fitToScreen();
		infoSize.textContent=`${nw} × ${nh}`;closeModal('modal-resize');toast(`Resized to ${nw}×${nh}`);
	});

	document.getElementById('modal-text-cancel').addEventListener('click',()=>closeModal('modal-text'));
	document.getElementById('modal-text-ok').addEventListener('click',()=>{
		const text=document.getElementById('text-input-val').value;
		if(!text.trim()){closeModal('modal-text');return;}
		const pos=state.textPos||{x:20,y:state.textSize+20};
		pushUndo();placeText(text,pos.x,pos.y+state.textSize);
		closeModal('modal-text');document.getElementById('text-input-val').value='';toast('Text placed');
	});
	document.getElementById('text-input-val').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('modal-text-ok').click();});

	// Blur modal
	const blurSlider=document.getElementById('blur-radius-slider');
	const blurVal=document.getElementById('blur-radius-val');
	blurSlider.addEventListener('input',()=>blurVal.textContent=blurSlider.value+'px');
	document.getElementById('modal-blur-cancel').addEventListener('click',()=>closeModal('modal-blur'));
	document.getElementById('modal-blur-ok').addEventListener('click',()=>{applyGaussianBlur(+blurSlider.value);closeModal('modal-blur');});

	// Noise modal
	const noiseAmt=document.getElementById('noise-amount');
	const noiseVal=document.getElementById('noise-amount-val');
	noiseAmt.addEventListener('input',()=>noiseVal.textContent=noiseAmt.value);
	document.getElementById('modal-noise-cancel').addEventListener('click',()=>closeModal('modal-noise'));
	document.getElementById('modal-noise-ok').addEventListener('click',()=>{applyNoise(+noiseAmt.value);closeModal('modal-noise');});

	// Pixelate modal
	const pixSz=document.getElementById('pixelate-size');
	const pixVal=document.getElementById('pixelate-size-val');
	pixSz.addEventListener('input',()=>pixVal.textContent=pixSz.value+'px');
	document.getElementById('modal-pixelate-cancel').addEventListener('click',()=>closeModal('modal-pixelate'));
	document.getElementById('modal-pixelate-ok').addEventListener('click',()=>{applyPixelate(+pixSz.value);closeModal('modal-pixelate');});

	document.querySelectorAll('.modal-overlay').forEach(ov=>ov.addEventListener('click',e=>{if(e.target===ov)ov.classList.remove('open');}));

	// ============================================================
	//  KEYBOARD
	// ============================================================
	document.addEventListener('keydown',e=>{
		const tgt=e.target;
		if(tgt.tagName==='INPUT'||tgt.tagName==='TEXTAREA'||tgt.tagName==='SELECT'||tgt.isContentEditable)return;
		if(e.code==='Space'){state.spaceDown=true;canvasArea.style.cursor='grab';e.preventDefault();return;}
		if(e.ctrlKey||e.metaKey){
			switch(e.key.toLowerCase()){
				case 'z':e.shiftKey?redo():undo();e.preventDefault();break;
				case 'y':redo();e.preventDefault();break;
				case 's':exportImage('png');e.preventDefault();break;
				case 'n':openModal('modal-new');e.preventDefault();break;
				case 'o':fileInput.click();e.preventDefault();break;
				case 'c':document.getElementById('action-copy').click();break;
				case 'v':document.getElementById('action-paste').click();break;
				case 'x':document.getElementById('action-cut').click();break;
				case 'a':document.getElementById('sel-all').click();e.preventDefault();break;
				case 'd':state.selection=null;sctx.clearRect(0,0,state.canvasW,state.canvasH);cancelAnimationFrame(selAnimFrame);e.preventDefault();break;
				case 'i':document.getElementById('action-invert').click();e.preventDefault();break;
				case 'j':document.getElementById('ml-dup').click();e.preventDefault();break;
				case 'e':if(e.shiftKey)document.getElementById('ml-flatten').click();else document.getElementById('ml-merge-down').click();e.preventDefault();break;
				case '0':fitToScreen();e.preventDefault();break;
				case '1':{const r=canvasArea.getBoundingClientRect();state.zoom=1;state.panX=r.left+r.width/2-state.canvasW/2;state.panY=r.top+r.height/2-state.canvasH/2;applyViewport();e.preventDefault();break;}
			}
			return;
		}
		const toolKeys={b:'brush',p:'pencil',e:'eraser',g:'fill',i:'eyedropper',d:'gradient',r:'rect',o:'ellipse',l:'line',t:'text',m:'select',v:'move',q:'lasso',z:'zoom',h:'hand'};
		if(toolKeys[e.key.toLowerCase()]){selectTool(toolKeys[e.key.toLowerCase()]);return;}
		if(e.key==='x'){const t=state.fgColor;setFgColor(state.bgColor);setBgColor(t);}
		if(e.key==='Escape'){
			state.selection=null;sctx.clearRect(0,0,state.canvasW,state.canvasH);cancelAnimationFrame(selAnimFrame);
			document.querySelectorAll('.modal-overlay').forEach(m=>m.classList.remove('open'));
		}
		if(e.key==='Delete'){pushUndo();if(state.selection){const{x,y,w,h}=state.selection;activeCtx().clearRect(x,y,w,h);}else{activeCtx().clearRect(0,0,state.canvasW,state.canvasH);}renderAllLayers();updateLayerThumbs();}
		if(e.key==='+'||e.key==='='){const c=zca();zoomAt(1.25,c.x,c.y);}
		if(e.key==='-'){const c=zca();zoomAt(1/1.25,c.x,c.y);}
		if(e.key==='['){state.brushSize=Math.max(1,state.brushSize-2);brushSizeEl.value=state.brushSize;brushSizeVal.textContent=state.brushSize+'px';}
		if(e.key===']'){state.brushSize=Math.min(200,state.brushSize+2);brushSizeEl.value=state.brushSize;brushSizeVal.textContent=state.brushSize+'px';}
	});
	document.addEventListener('keyup',e=>{if(e.code==='Space'){state.spaceDown=false;updateCursorStyle();}});

	// ============================================================
	//  INIT
	// ============================================================
	setFgColor('#ffffff');
	setBgColor('#000000');
	selectTool('brush');
	// Init the HSV picker (draws gradients on first load)
	setTimeout(()=>{ initPicker(); syncPickerFromHex('#ffffff'); }, 50);
	initCanvas(800,600,'white');

	// Color popup toggle
	const colorPopup = document.getElementById('color-popup');
	document.getElementById('tray-color-btn').addEventListener('click', (e) => {
		e.stopPropagation();
		colorPopup.classList.toggle('open');
		if(colorPopup.classList.contains('open')) {
			setTimeout(()=>{ drawSqGradient(); drawHueGradient(); }, 30);
		}
	});
	document.getElementById('color-popup-close').addEventListener('click', () => {
		colorPopup.classList.remove('open');
	});
	document.addEventListener('click', (e) => {
		if(!colorPopup.contains(e.target) && e.target.id !== 'tray-color-btn') {
			colorPopup.classList.remove('open');
		}
	});
	colorPopup.addEventListener('click', e => e.stopPropagation());

	// Initial tray-options visibility
	trayOptions.style.display = 'flex'; // brush is initial tool, has options

	// Layer strip toggle
	const layerStripHeader = document.getElementById('layer-strip-header');
	const layersCollapse   = document.getElementById('layers-collapse');
	const layerStripToggle = document.getElementById('layer-strip-toggle');
	if(layerStripHeader) {
		layerStripHeader.addEventListener('click', () => {
			const isOpen = layersCollapse.classList.toggle('open');
			layerStripHeader.classList.toggle('expanded', isOpen);
			layerStripToggle.classList.toggle('open', isOpen);
		});
	}

	// Init Lucide icons
	if(typeof lucide !== 'undefined') lucide.createIcons();

})();
</script>
</body>
</html>
