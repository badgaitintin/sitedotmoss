		<!-- Palette swatches -->
		<div class="swatch-grid" id="swatch-grid"></div>

		<!-- Hidden native pickers -->
		<input type="color" id="native-fg" value="#ffffff" />
		<input type="color" id="native-bg" value="#000000" />
	</div>

	<!-- ====== ZOOM INDICATOR ====== -->
