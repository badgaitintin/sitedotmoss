			const STD   = [0.229, 0.224, 0.225];
			const MIN_DEPTH = 0.1;
			const MAX_DEPTH = 100.0;

			// ── State ────────────────────────────────────────────
			let session      = null;
			let modelLoading = false;
			let modelInputDims = [1, 3, 320, 1024]; // Updated after session load from actual metadata
			let leftImage    = null;   // HTMLImageElement
			let rightImage   = null;
			let stereoMode   = false;
			let lastDisp     = null;   // Float32Array
			let lastDispW    = 1024;   // Width of the last disparity output tensor
			let lastDispH    = 320;    // Height of the last disparity output tensor
