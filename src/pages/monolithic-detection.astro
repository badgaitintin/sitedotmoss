			// ── Colormap LUTs ────────────────────────────────────
			// Each LUT is an array of 256 [R, G, B] entries (0-255)
			function makeInfernoLUT() {
				// Inferno colormap keypoints
				const stops = [
					[0.0,  [0,   0,   4]],
					[0.13, [27,  12,  65]],
					[0.25, [74,  12,  107]],
					[0.38, [120, 28,  109]],
					[0.50, [165, 44,  96]],
					[0.63, [207, 71,  70]],
					[0.75, [237, 121, 38]],
					[0.88, [251, 180, 26]],
					[1.0,  [252, 255, 164]],
				];
				return buildLUT(stops);
			}
			function makePlasmaLUT() {
				const stops = [
					[0.0,  [13,  8,  135]],
					[0.13, [70,  3,  159]],
					[0.25, [114, 1,  168]],
					[0.38, [156, 23, 158]],
					[0.50, [189, 55, 134]],
					[0.63, [216, 87, 107]],
					[0.75, [237, 121, 83]],
					[0.88, [253, 180, 98]],
					[1.0,  [240, 249, 33]],
				];
				return buildLUT(stops);
			}
			function makeViridisLUT() {
				const stops = [
					[0.0,  [68,  1,  84]],
					[0.25, [59,  82,  139]],
					[0.50, [33,  145, 140]],
					[0.75, [94,  201, 98]],
					[1.0,  [253, 231, 37]],
				];
				return buildLUT(stops);
			}
			function makeTurboLUT() {
				const stops = [
					[0.0,  [48,  18,  59]],
					[0.12, [65,  69,  171]],
					[0.25, [70,  117, 237]],
					[0.38, [57,  167, 245]],
					[0.50, [29,  209, 196]],
					[0.63, [55,  246, 172]],
					[0.75, [149, 249, 90]],
					[0.88, [233, 245, 58]],
					[1.0,  [197, 42,  3]],
				];
				return buildLUT(stops);
			}

			function buildLUT(stops) {
				const lut = new Array(256);
				for (let i = 0; i < 256; i++) {
					const t = i / 255;
					// find surrounding stops
					let lo = stops[0], hi = stops[stops.length - 1];
					for (let s = 0; s < stops.length - 1; s++) {
						if (t >= stops[s][0] && t <= stops[s+1][0]) {
							lo = stops[s]; hi = stops[s+1]; break;
						}
					}
					const range = hi[0] - lo[0];
					const f = range < 1e-9 ? 0 : (t - lo[0]) / range;
					lut[i] = [
						Math.round(lo[1][0] + (hi[1][0] - lo[1][0]) * f),
						Math.round(lo[1][1] + (hi[1][1] - lo[1][1]) * f),
						Math.round(lo[1][2] + (hi[1][2] - lo[1][2]) * f),
					];
				}
				return lut;
			}

			const COLORMAPS = {
				inferno: makeInfernoLUT(),
				plasma:  makePlasmaLUT(),
				viridis: makeViridisLUT(),
				turbo:   makeTurboLUT(),
			};

			// ── Status helpers ───────────────────────────────────
			function setStatus(state, text) {
				modelStatus.className = 'model-status ' + state;
				modelStatusTxt.textContent = text;
			}

			function showError(msg) {
				errorToast.textContent = '⚠ ' + msg;
				errorToast.classList.add('visible');
				setTimeout(() => errorToast.classList.remove('visible'), 5000);
			}

			// ── Model Loading ────────────────────────────────────
			async function loadModel() {
				if (session || modelLoading) return;
				modelLoading = true;
				setStatus('loading', 'Loading...');
				loadBar.classList.add('visible');
				loadBarText.textContent = 'Checking model weights cache…';
				loadBarFill.style.width = '5%';

				try {
					// Detect ORT
					if (typeof ort === 'undefined') {
						throw new Error('ONNX Runtime Web not available. Check your connection.');
					}

					// Cache Storage caching
					const cacheName = 'dape-model-cache';
					const cache = await caches.open(cacheName);
					let resp = await cache.match(MODEL_DATA_URL);
					
					if (resp) {
						console.log('[d-Ape] Model weights found in Cache Storage.');
						loadBarText.textContent = 'Loading weights from cache…';
					} else {
						console.log('[d-Ape] Model weights cache miss. Downloading from network...');
						loadBarText.textContent = 'Downloading model weights (~73 MB)…';
						const fetchResp = await fetch(MODEL_DATA_URL);
						if (!fetchResp.ok) throw new Error(`Failed to fetch model weights: ${fetchResp.statusText}`);
						
						// Store clone in Cache Storage
						await cache.put(MODEL_DATA_URL, fetchResp.clone());
						resp = fetchResp;
					}

					const total   = parseInt(resp.headers.get('content-length') || '0');
					const reader  = resp.body.getReader();
					const chunks  = [];
					let received  = 0;
					while (true) {
						const { done, value } = await reader.read();
						if (done) break;
						chunks.push(value);
						received += value.length;
						const pct = total > 0 ? Math.min(95, 15 + (received / total) * 70) : 50;
						loadBarFill.style.width = pct + '%';
						const mbLoaded = (received / 1048576).toFixed(1);
						const mbTotal  = total > 0 ? (total / 1048576).toFixed(1) : '?';
						loadBarText.textContent = `Loading data: ${mbLoaded} / ${mbTotal} MB`;
					}

					// ORT Web externalData.data must be a Uint8Array — not a blob URL.
					// Concatenate all streamed chunks into one contiguous buffer.
					const totalBytes = chunks.reduce((s, c) => s + c.length, 0);
					const weightsBuffer = new Uint8Array(totalBytes);
					let offset = 0;
					for (const chunk of chunks) {
						weightsBuffer.set(chunk, offset);
						offset += chunk.length;
					}

					// WebGL might support execution provider initialization but fail on large model graph creation
					// or external weights loader. We use a try-create loop to auto-fallback from WebGL to WASM.
					const backendsToTry = [];
					try {
						const testCanvas = document.createElement('canvas');
						const gl = testCanvas.getContext('webgl2') || testCanvas.getContext('webgl');
						if (gl) backendsToTry.push('webgl');
					} catch (_) {}
					backendsToTry.push('wasm');

					let loadedBackend = 'wasm';
					let lastError = null;

					console.log(`[d-Ape] Downloaded weights size: ${totalBytes} bytes. Expected total: ${total} bytes.`);
					loadBarText.textContent = `Downloaded ${totalBytes} bytes. Initializing session...`;

					for (const backend of backendsToTry) {
						try {
							console.log(`[d-Ape] Trying to create session with backend: ${backend}`);
							if (backendLabel) {
								backendLabel.textContent = backend.toUpperCase();
							}
							loadBarText.textContent = `Initializing session (${backend.toUpperCase()})...`;

							const opts = {
								executionProviders: [backend],
								graphOptimizationLevel: 'all',
								externalData: [
									{ path: 'monolithic_dape_web.onnx.data', data: weightsBuffer }
								],
							};

							session = await ort.InferenceSession.create(MODEL_URL, opts);
							loadedBackend = backend;
							lastError = null;
							console.log(`[d-Ape] Session created successfully using backend: ${backend}`);
							break;
						} catch (e) {
							console.warn(`[d-Ape] Backend ${backend} initialization failed:`, e);
							lastError = e;
						}
					}

					if (lastError) {
						throw new Error(`All backends failed. Last error: ${lastError.message}`);
					}

					// Update UI with final working backend
					if (backendLabel) {
						backendLabel.textContent = loadedBackend.toUpperCase();
					}

					// ── Discover actual input shape from model metadata ──
					try {
						const firstInputName = session.inputNames[0];
						const meta = session.inputMetadata
							? session.inputMetadata[firstInputName]
							: null;
						if (meta && meta.dims && meta.dims.length === 4) {
							// Use dims directly; replace dynamic -1 with known defaults
							modelInputDims = meta.dims.map((d, i) => {
								if (d > 0) return d;
								const defaults = [1, 3, IMG_H, IMG_W];
								return defaults[i];
							});
						} else {
							// Fallback: keep default [1,3,H,W]
							modelInputDims = [1, 3, IMG_H, IMG_W];
						}
					} catch (_) {
						modelInputDims = [1, 3, IMG_H, IMG_W];
					}
					console.log('[d-Ape] inputNames:', session.inputNames);
					console.log('[d-Ape] outputNames:', session.outputNames);
					console.log('[d-Ape] resolved modelInputDims:', modelInputDims);
					console.log('[d-Ape] inputMetadata:', session.inputMetadata);

					loadBarFill.style.width = '100%';
					loadBarText.textContent = `Model ready (${loadedBackend.toUpperCase()})!`;
					setTimeout(() => loadBar.classList.remove('visible'), 1200);

					setStatus('ready', `Ready (${loadedBackend.toUpperCase()})`);
					updateRunBtn();

				} catch (err) {
					console.error('[d-Ape] Model load error:', err);
					setStatus('error', 'Load Failed');
					loadBarText.textContent = 'Error: ' + err.message;
					showError('Model load failed: ' + err.message);
					modelLoading = false;
				}
			}

			// ── Image preprocessing ──────────────────────────────
			// nCh: number of input channels expected by the model (3 or 4)
			// If 4, channel 3 is a zero-padded HOG plane (model was exported with use_hog=True
			// but HOG logic removed — we feed zeros for that channel, which is safe because
			// HogProjector uses zero-init weights so it contributes nothing at inference).
			function imageToTensor(imgEl, nCh) {
				nCh = nCh || 3;
				// Draw image to offscreen canvas at target size
				const offscreen = document.createElement('canvas');
				offscreen.width  = IMG_W;
				offscreen.height = IMG_H;
				const ctx = offscreen.getContext('2d');
				ctx.drawImage(imgEl, 0, 0, IMG_W, IMG_H);
				const { data } = ctx.getImageData(0, 0, IMG_W, IMG_H);

				// NCHW float32 [1, nCh, H, W] normalized
				const tensor = new Float32Array(nCh * IMG_H * IMG_W);
				for (let y = 0; y < IMG_H; y++) {
					for (let x = 0; x < IMG_W; x++) {
						const idx4 = (y * IMG_W + x) * 4;
						const idx  = y * IMG_W + x;
						tensor[0 * IMG_H * IMG_W + idx] = (data[idx4 + 0] / 255 - MEAN[0]) / STD[0];
						tensor[1 * IMG_H * IMG_W + idx] = (data[idx4 + 1] / 255 - MEAN[1]) / STD[1];
						tensor[2 * IMG_H * IMG_W + idx] = (data[idx4 + 2] / 255 - MEAN[2]) / STD[2];
						// Channel 3 (HOG): zeros — HogProjector has zero-init weights so no effect
						if (nCh >= 4) tensor[3 * IMG_H * IMG_W + idx] = 0.0;
					}
				}
				return tensor;
			}

			function makeMirrorImage(imgEl) {
				const offscreen = document.createElement('canvas');
				offscreen.width  = IMG_W;
				offscreen.height = IMG_H;
				const ctx = offscreen.getContext('2d');
				ctx.translate(IMG_W, 0);
				ctx.scale(-1, 1);
				ctx.drawImage(imgEl, 0, 0, IMG_W, IMG_H);
				return offscreen;
			}

			// ── Disparity → Depth conversion ────────────────────
			function dispToDepth(disp) {
				const minDisp = 1.0 / MAX_DEPTH;
				const maxDisp = 1.0 / MIN_DEPTH;
				const depth = new Float32Array(disp.length);
				for (let i = 0; i < disp.length; i++) {
					const scaledDisp = minDisp + (maxDisp - minDisp) * disp[i];
					depth[i] = 1.0 / Math.max(scaledDisp, 1e-6);
				}
				return depth;
			}

			// ── Colorize disparity map ───────────────────────────
			function colorizeDisp(disp, lut, w, h) {
				const imgData = new Uint8ClampedArray(w * h * 4);
				let dmin = Infinity, dmax = -Infinity;
				for (let i = 0; i < disp.length; i++) {
					if (disp[i] < dmin) dmin = disp[i];
					if (disp[i] > dmax) dmax = disp[i];
				}
				const range = Math.max(dmax - dmin, 1e-8);
				for (let i = 0; i < disp.length; i++) {
					const t = (disp[i] - dmin) / range;
					
					let r, g, b;
					if (activeVizMode === 'topographic') {
						// Topographic mode: Quantize into 12 discrete bands
						const levels = 12;
						const band = Math.floor(t * levels) / levels;
						
						// Draw sharp dark contour boundaries
						const factor = t * levels;
						const distToBoundary = Math.abs(factor - Math.round(factor));
						const isBoundary = distToBoundary < 0.08;
						
						const c = lut[Math.min(255, Math.round(band * 255))];
						if (isBoundary) {
							r = 0;
							g = 0;
							b = 0;
						} else {
							r = c[0];
							g = c[1];
							b = c[2];
						}
					} else {
						// Regression mode: Smooth gradient
						const idx = Math.min(255, Math.round(t * 255));
						const c = lut[idx];
						r = c[0];
						g = c[1];
						b = c[2];
					}

					imgData[i * 4 + 0] = r;
					imgData[i * 4 + 1] = g;
					imgData[i * 4 + 2] = b;
					imgData[i * 4 + 3] = 255;
				}
				return imgData;
			}

			// ── Render to output canvas ──────────────────────────
			function renderOutput(disp, srcImg, w, h) {
				w = w || IMG_W;
				h = h || IMG_H;
				
				const ctx = outputCanvas.getContext('2d');
				const lut = COLORMAPS[activeColormap];
				const colored = colorizeDisp(disp, lut, w, h);

				// Render the colorized depth map onto an offscreen canvas at native model output resolution
				const offscreen = document.createElement('canvas');
				offscreen.width = w;
				offscreen.height = h;
				const oCtx = offscreen.getContext('2d');
				const imgData = new ImageData(colored, w, h);
				oCtx.putImageData(imgData, 0, 0);

				ctx.clearRect(0, 0, IMG_W, IMG_H);

				if (lastBlend < 5) {
					// Only depth map - stretch to fit 1024x320
					ctx.drawImage(offscreen, 0, 0, IMG_W, IMG_H);
				} else if (lastBlend > 95) {
					// Only original image
					ctx.drawImage(srcImg, 0, 0, IMG_W, IMG_H);
				} else {
					// Blend: draw original photo first, then overlay colormap using globalAlpha
					ctx.drawImage(srcImg, 0, 0, IMG_W, IMG_H);
					
					ctx.save();
					ctx.globalAlpha = lastBlend / 100;
					ctx.drawImage(offscreen, 0, 0, IMG_W, IMG_H);
					ctx.restore();
				}

				outputEmpty.style.display = 'none';
			}

			// ── Update depth stats ───────────────────────────────
			function updateDepthStats(disp) {
				const depth = dispToDepth(disp);
				let mn = Infinity, mx = -Infinity, sum = 0;
				for (let i = 0; i < depth.length; i++) {
					if (depth[i] < mn) mn = depth[i];
					if (depth[i] > mx) mx = depth[i];
					sum += depth[i];
				}
				const mean = sum / depth.length;
				statMinDepth.textContent  = mn.toFixed(1) + ' m';
				statMaxDepth.textContent  = mx.toFixed(1) + ' m';
				statMeanDepth.textContent = mean.toFixed(1) + ' m';
			}

			// ── Inference ────────────────────────────────────────
			async function runInference() {
				if (!session || !leftImage) return;

				runBtn.classList.add('running');
				runBtn.disabled = true;
				runBtnText.textContent = 'Running...';

				try {
					// Use shape discovered from model metadata
					const [, nCh, inH, inW] = modelInputDims;
					console.log(`[d-Ape] Building tensor: [1, ${nCh}, ${inH}, ${inW}]`);

					const leftData  = imageToTensor(leftImage, nCh);
					const inputLeft = new ort.Tensor('float32', leftData, [1, nCh, inH, inW]);

					// Build feeds based on how many inputs the model expects
					const inputNames = session.inputNames;
					const feeds = {};

					if (inputNames.length === 1) {
						// Single-input export (most likely case after HOG/GNN removal)
						feeds[inputNames[0]] = inputLeft;
					} else {
						// Multi-input: feed left + right (or mirrored) for remaining inputs
						const rightSrc  = (stereoMode && rightImage) ? rightImage : makeMirrorImage(leftImage);
						const rightData = imageToTensor(rightSrc, nCh);
						const inputRight = new ort.Tensor('float32', rightData, [1, nCh, inH, inW]);
						feeds[inputNames[0]] = inputLeft;
						feeds[inputNames[1]] = inputRight;
						// Any remaining inputs (sift_disp, sift_mask, etc.) get zero tensors
						for (let i = 2; i < inputNames.length; i++) {
							const zeroData = new Float32Array(inH * inW);
							feeds[inputNames[i]] = new ort.Tensor('float32', zeroData, [1, inH, inW]);
						}
					}
					console.log('[d-Ape] feeds:', Object.keys(feeds));

					const t0 = performance.now();
					const results = await session.run(feeds);
					const elapsed = (performance.now() - t0).toFixed(0);

					const outNames = session.outputNames;

					// Find the output tensor with the largest data size (corresponds to full-res disp1)
					let disp1Key = outNames[0];
					let maxLen = 0;
					for (const name of outNames) {
						const len = results[name].data.length;
						if (len > maxLen) {
							maxLen = len;
							disp1Key = name;
						}
					}

					const disp = results[disp1Key].data;
					const dims = results[disp1Key].dims; // e.g. [1, 1, outH, outW]
					lastDispW = dims[3];
					lastDispH = dims[2];

					lastDisp = disp;
					renderOutput(disp, leftImage, lastDispW, lastDispH);
					updateDepthStats(disp);

					inferTime.textContent = `${elapsed} ms`;
					inferTime.classList.add('visible');

					dlDepthBtn.disabled = false;
					dlRawBtn.disabled   = false;

				} catch (err) {
					console.error('[d-Ape] Inference error:', err);
					showError('Inference failed: ' + err.message);
				} finally {
					runBtn.classList.remove('running');
					runBtnText.textContent = 'Run Inference →';
					updateRunBtn();
				}
			}

			// ── UI helpers ───────────────────────────────────────
			function updateRunBtn() {
				runBtn.disabled = !(session && leftImage);
			}

			function drawPreview(canvas, emptyDiv, imgEl) {
				canvas.width  = IMG_W;
				canvas.height = IMG_H;
				const ctx = canvas.getContext('2d');
				ctx.drawImage(imgEl, 0, 0, IMG_W, IMG_H);
				emptyDiv.style.display = 'none';
				canvas.style.display = 'block';
			}

			function loadImageFile(file, isLeft) {
				const url = URL.createObjectURL(file);
				const img = new Image();
				img.onload = () => {
					if (isLeft) {
						leftImage = img;
						drawPreview(previewLeft, previewEmptyL, img);
					} else {
						rightImage = img;
						drawPreview(previewRight, previewEmptyR, img);
					}
					updateRunBtn();
				};
				img.src = url;
			}

			function clearState() {
				leftImage  = null;
				rightImage = null;
				lastDisp   = null;
				// Reset previews
				previewEmptyL.style.display = '';
				previewEmptyR.style.display = '';
				const ctxL = previewLeft.getContext('2d');
				ctxL.clearRect(0, 0, previewLeft.width, previewLeft.height);
				const ctxR = previewRight.getContext('2d');
				ctxR.clearRect(0, 0, previewRight.width, previewRight.height);
				// Reset output
				const ctxO = outputCanvas.getContext('2d');
				ctxO.clearRect(0, 0, outputCanvas.width, outputCanvas.height);
				outputEmpty.style.display = '';
				dlDepthBtn.disabled = true;
				dlRawBtn.disabled   = true;
				inferTime.classList.remove('visible');
				statMinDepth.textContent  = '—';
				statMaxDepth.textContent  = '—';
				statMeanDepth.textContent = '—';
				updateRunBtn();
			}

			// ── Sample image ─────────────────────────────────────
			async function loadSampleImage() {
				// Draw a synthetic urban-scene test image (gradient + shapes)
				const offscreen = document.createElement('canvas');
				offscreen.width  = IMG_W;
				offscreen.height = IMG_H;
				const ctx = offscreen.getContext('2d');

				// Sky gradient
				const sky = ctx.createLinearGradient(0, 0, 0, IMG_H * 0.45);
				sky.addColorStop(0, '#87ceeb');
				sky.addColorStop(1, '#c9e8f5');
				ctx.fillStyle = sky;
				ctx.fillRect(0, 0, IMG_W, IMG_H * 0.45);

				// Road
				const road = ctx.createLinearGradient(0, IMG_H * 0.45, 0, IMG_H);
				road.addColorStop(0, '#555');
				road.addColorStop(1, '#333');
				ctx.fillStyle = road;
				ctx.fillRect(0, IMG_H * 0.45, IMG_W, IMG_H);

				// Road markings
				ctx.strokeStyle = '#fff';
				ctx.lineWidth = 4;
				ctx.setLineDash([40, 30]);
				ctx.beginPath();
				ctx.moveTo(IMG_W * 0.5, IMG_H * 0.48);
				ctx.lineTo(IMG_W * 0.5, IMG_H);
				ctx.stroke();
				ctx.setLineDash([]);

				// Buildings (left side)
				const bColors = ['#667788', '#556677', '#445566', '#778899'];
				const bWidths  = [80, 60, 100, 70];
				const bHeights = [100, 130, 90, 120];
				let bx = 20;
				for (let i = 0; i < 4; i++) {
					ctx.fillStyle = bColors[i];
					ctx.fillRect(bx, IMG_H * 0.45 - bHeights[i], bWidths[i], bHeights[i]);
					// Windows
					ctx.fillStyle = '#ffdf8a';
					for (let wy = 0; wy < 3; wy++) {
						for (let wx = 0; wx < 2; wx++) {
							ctx.fillRect(bx + 8 + wx * 28, IMG_H * 0.45 - bHeights[i] + 10 + wy * 30, 14, 12);
						}
					}
					bx += bWidths[i] + 10;
				}

				// Buildings (right side) 
				bx = IMG_W - 340;
				for (let i = 0; i < 4; i++) {
					const bh = bHeights[(i+2)%4];
					ctx.fillStyle = bColors[(i+1)%4];
					ctx.fillRect(bx, IMG_H * 0.45 - bh, bWidths[i], bh);
					ctx.fillStyle = '#ffdf8a';
					for (let wy = 0; wy < 3; wy++) {
						for (let wx = 0; wx < 2; wx++) {
							ctx.fillRect(bx + 8 + wx * 22, IMG_H * 0.45 - bh + 10 + wy * 28, 10, 10);
						}
					}
					bx += bWidths[i] + 8;
				}

				// Tree silhouettes
				for (let i = 0; i < 5; i++) {
					const tx = 60 + i * 200;
					ctx.fillStyle = '#2d5a27';
					ctx.beginPath();
					ctx.arc(tx, IMG_H * 0.45, 22, 0, Math.PI * 2);
					ctx.fill();
					ctx.fillStyle = '#1e3d1b';
					ctx.fillRect(tx - 4, IMG_H * 0.45, 8, 20);
				}

				// Parked car
				ctx.fillStyle = '#c0392b';
				ctx.beginPath();
				ctx.roundRect(200, IMG_H * 0.6, 90, 35, 4);
				ctx.fill();
				ctx.fillStyle = '#85c1e9';
				ctx.fillRect(212, IMG_H * 0.6 + 4, 28, 14);
				ctx.fillRect(244, IMG_H * 0.6 + 4, 26, 14);

				const url = offscreen.toDataURL('image/png');
				const img = new Image();
				img.onload = () => {
					leftImage = img;
					drawPreview(previewLeft, previewEmptyL, img);
					updateRunBtn();
				};
				img.src = url;
			}

			// ── Colormap selection ───────────────────────────────
			document.querySelectorAll('.cm-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					document.querySelectorAll('.cm-btn').forEach(b => b.classList.remove('active'));
					btn.classList.add('active');
					activeColormap = btn.id.replace('cm-', '');
					if (lastDisp && (leftImage || cameraMode)) {
						const src = cameraMode ? previewLeft : leftImage;
						renderOutput(lastDisp, src, lastDispW, lastDispH);
					}
				});
			});

			// ── Blend slider ─────────────────────────────────────
			blendSlider.addEventListener('input', () => {
				lastBlend = parseInt(blendSlider.value);
				blendValue.textContent = lastBlend + '%';
				if (lastDisp && (leftImage || cameraMode)) {
					const src = cameraMode ? previewLeft : leftImage;
					renderOutput(lastDisp, src, lastDispW, lastDispH);
				}
			});

			// ── Visualization Mode Toggles ────────────────────────
			btnVizRegression.addEventListener('click', () => {
				activeVizMode = 'regression';
				btnVizRegression.classList.add('active');
				btnVizTopographic.classList.remove('active');
				if (lastDisp && (leftImage || cameraMode)) {
					const src = cameraMode ? previewLeft : leftImage;
					renderOutput(lastDisp, src, lastDispW, lastDispH);
				}
			});

			btnVizTopographic.addEventListener('click', () => {
				activeVizMode = 'topographic';
				btnVizTopographic.classList.add('active');
				btnVizRegression.classList.remove('active');
				if (lastDisp && (leftImage || cameraMode)) {
					const src = cameraMode ? previewLeft : leftImage;
					renderOutput(lastDisp, src, lastDispW, lastDispH);
				}
			});

			// ── Tab selection and mode switches ─────────────────
			function setMode(mode) {
				stopCamera();
				if (mode === 'single') {
					cameraMode = false;
					stereoMode = false;
					btnSingle.classList.add('active');
					btnStereo.classList.remove('active');
					btnCamera.classList.remove('active');
					uploadLeft.style.display = 'block';
					uploadRight.style.display = 'none';
					cameraControls.style.display = 'none';
					previewRightBox.style.display = 'none';
					previewRow.classList.add('single');
					previewLabelLeft.textContent = 'Image';
					runBtn.style.display = 'flex';
					sampleBtn.style.display = 'inline-block';
					clearBtn.style.display = 'inline-block';
					clearState();
				} else if (mode === 'stereo') {
					cameraMode = false;
					stereoMode = true;
					btnStereo.classList.add('active');
					btnSingle.classList.remove('active');
					btnCamera.classList.remove('active');
					uploadLeft.style.display = 'block';
					uploadRight.style.display = 'block';
					cameraControls.style.display = 'none';
					previewRightBox.style.display = 'block';
					previewRow.classList.remove('single');
					previewLabelLeft.textContent = 'Left';
					runBtn.style.display = 'flex';
					sampleBtn.style.display = 'inline-block';
					clearBtn.style.display = 'inline-block';
					clearState();
				} else if (mode === 'camera') {
					cameraMode = true;
					stereoMode = false;
					btnCamera.classList.add('active');
					btnSingle.classList.remove('active');
					btnStereo.classList.remove('active');
					uploadLeft.style.display = 'none';
					uploadRight.style.display = 'none';
					cameraControls.style.display = 'block';
					previewRightBox.style.display = 'none';
					previewRow.classList.add('single');
					previewLabelLeft.textContent = 'Camera Feed';
					runBtn.style.display = 'none';
					sampleBtn.style.display = 'none';
					clearBtn.style.display = 'none';
					clearState();
					detectCameras();
				}
			}

			btnSingle.addEventListener('click', () => setMode('single'));
			btnStereo.addEventListener('click', () => setMode('stereo'));
			btnCamera.addEventListener('click', () => setMode('camera'));

			// ── Camera API ───────────────────────────────────────
			async function detectCameras() {
				try {
					cameraSelect.innerHTML = '<option value="">Requesting permission...</option>';
					// Force immediate permission check
					const testStream = await navigator.mediaDevices.getUserMedia({ video: true });
					// Stop the test tracks immediately so the indicator light turns off
					testStream.getTracks().forEach(track => track.stop());

					const devices = await navigator.mediaDevices.enumerateDevices();
					const videoDevices = devices.filter(d => d.kind === 'videoinput');
					
					cameraSelect.innerHTML = '';
					if (videoDevices.length === 0) {
						cameraSelect.innerHTML = '<option value="">No cameras found</option>';
						btnCameraToggle.disabled = true;
						return;
					}
					
					videoDevices.forEach((device, index) => {
						const option = document.createElement('option');
						option.value = device.deviceId;
						option.textContent = device.label || `Camera ${index + 1}`;
						cameraSelect.appendChild(option);
					});
					btnCameraToggle.disabled = false;
				} catch (err) {
					console.warn('[d-Ape] Camera detection error:', err);
					cameraSelect.innerHTML = '<option value="">Camera access denied</option>';
					btnCameraToggle.disabled = true;
					showError('Camera access denied: ' + err.message);
				}
			}

			async function startCamera() {
				if (cameraActive) return;
				const deviceId = cameraSelect.value;
				const constraints = {
					video: deviceId ? { deviceId: { exact: deviceId }, width: { ideal: 640 }, height: { ideal: 480 } } : true
				};

				try {
					cameraStream = await navigator.mediaDevices.getUserMedia(constraints);
					cameraVideo.srcObject = cameraStream;
					cameraActive = true;
					btnCameraToggle.textContent = 'Stop Camera';
					btnCameraToggle.style.background = 'var(--bh-danger)';
					
					previewEmptyL.style.display = 'none';
					previewLeft.style.display = 'block';

					cameraLoop();
				} catch (err) {
					console.error('[d-Ape] Error starting camera:', err);
					showError('Could not start camera feed: ' + err.message);
				}
			}

			function stopCamera() {
				cameraActive = false;
				if (cameraAnimFrame) {
					cancelAnimationFrame(cameraAnimFrame);
					cameraAnimFrame = null;
				}
				if (cameraStream) {
					cameraStream.getTracks().forEach(track => track.stop());
					cameraStream = null;
				}
				cameraVideo.srcObject = null;
				btnCameraToggle.textContent = 'Start Camera';
				btnCameraToggle.style.background = '';
				isProcessingCamera = false;
			}

			function cameraLoop() {
				if (!cameraActive) return;

				if (cameraVideo.readyState === cameraVideo.HAVE_ENOUGH_DATA) {
					drawVideoToCanvas(cameraVideo, previewLeft);
					if (session) {
						runLiveCameraInference();
					}
				}
				cameraAnimFrame = requestAnimationFrame(cameraLoop);
			}

			function drawVideoToCanvas(video, canvas) {
				const ctx = canvas.getContext('2d');
				const cw = canvas.width = IMG_W;
				const ch = canvas.height = IMG_H;
				const vw = video.videoWidth;
				const vh = video.videoHeight;
				
				const canvasAspect = cw / ch;
				const videoAspect = vw / vh;
				
				let sx, sy, sw, sh;
				if (videoAspect > canvasAspect) {
					sh = vh;
					sw = vh * canvasAspect;
					sx = (vw - sw) / 2;
					sy = 0;
				} else {
					sw = vw;
					sh = vw / canvasAspect;
					sx = 0;
					sy = (vh - sh) / 2;
				}
				ctx.drawImage(video, sx, sy, sw, sh, 0, 0, cw, ch);
			}

			async function runLiveCameraInference() {
				if (!session || !cameraActive || isProcessingCamera) return;
				isProcessingCamera = true;

				try {
					const [, nCh, inH, inW] = modelInputDims;
					const leftData  = imageToTensor(previewLeft, nCh);
					const inputLeft = new ort.Tensor('float32', leftData, [1, nCh, inH, inW]);

					const inputNames = session.inputNames;
					const feeds = {};

					if (inputNames.length === 1) {
						feeds[inputNames[0]] = inputLeft;
					} else {
						// For camera mode, feed left to both or mirrored
						const rightData = imageToTensor(previewLeft, nCh);
						const inputRight = new ort.Tensor('float32', rightData, [1, nCh, inH, inW]);
						feeds[inputNames[0]] = inputLeft;
						feeds[inputNames[1]] = inputRight;
						for (let i = 2; i < inputNames.length; i++) {
							const zeroData = new Float32Array(inH * inW);
							feeds[inputNames[i]] = new ort.Tensor('float32', zeroData, [1, inH, inW]);
						}
					}

					const t0 = performance.now();
					const results = await session.run(feeds);
					const elapsed = (performance.now() - t0).toFixed(0);

					const outNames = session.outputNames;
					// Find the output tensor with the largest data size (corresponds to full-res disp1)
					let disp1Key = outNames[0];
					let maxLen = 0;
					for (const name of outNames) {
						const len = results[name].data.length;
						if (len > maxLen) {
							maxLen = len;
							disp1Key = name;
						}
					}

					const disp = results[disp1Key].data;
					const dims = results[disp1Key].dims; // e.g. [1, 1, outH, outW]
					lastDispW = dims[3];
					lastDispH = dims[2];

					lastDisp = disp;
					renderOutput(disp, previewLeft, lastDispW, lastDispH);
					updateDepthStats(disp);

					inferTime.textContent = `${elapsed} ms`;
					inferTime.classList.add('visible');

					dlDepthBtn.disabled = false;
					dlRawBtn.disabled   = false;

				} catch (err) {
					console.error('[d-Ape] Realtime inference error:', err);
				} finally {
					isProcessingCamera = false;
				}
			}

			btnRefreshCameras.addEventListener('click', detectCameras);
			btnCameraToggle.addEventListener('click', () => {
				if (cameraActive) {
					stopCamera();
				} else {
					startCamera();
				}
			});

			// ── File upload ──────────────────────────────────────
			function setupDropZone(zone, inputEl, isLeft) {
				zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
				zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
				zone.addEventListener('drop', e => {
					e.preventDefault();
					zone.classList.remove('drag-over');
					const file = e.dataTransfer?.files?.[0];
					if (file && file.type.startsWith('image/')) loadImageFile(file, isLeft);
				});
				inputEl.addEventListener('change', () => {
					const file = inputEl.files?.[0];
					if (file) loadImageFile(file, isLeft);
				});
			}

			setupDropZone(document.getElementById('dropZoneLeft'),  document.getElementById('fileLeft'),  true);
			setupDropZone(document.getElementById('dropZoneRight'), document.getElementById('fileRight'), false);

			// ── Buttons ──────────────────────────────────────────
			runBtn.addEventListener('click', () => runInference());
			sampleBtn.addEventListener('click', loadSampleImage);
			clearBtn.addEventListener('click', () => {
				stopCamera();
				clearState();
			});

			dlDepthBtn.addEventListener('click', () => {
				if (!lastDisp) return;
				const link = document.createElement('a');
				link.download = 'monolithic_dape_depth.png';
				link.href = outputCanvas.toDataURL('image/png');
				link.click();
			});

			dlRawBtn.addEventListener('click', () => {
				if (!lastDisp) return;
				const blob = new Blob([lastDisp.buffer], { type: 'application/octet-stream' });
				const url  = URL.createObjectURL(blob);
				const link = document.createElement('a');
				link.download = 'monolithic_dape_disp1_float32.bin';
				link.href = url;
				link.click();
				setTimeout(() => URL.revokeObjectURL(url), 1000);
			});

			// ── Back button transition ───────────────────────────
			const backBtn = document.getElementById('backBtn');
			if (backBtn) {
				backBtn.addEventListener('click', e => {
					e.preventDefault();
					stopCamera();
					document.body.classList.add('is-exiting');
					setTimeout(() => { window.location.href = backBtn.getAttribute('href'); }, 280);
				});
			}

			// ── Load ORT dynamically, then auto-load model ───────
			// Dynamic injection guarantees ort is defined before loadModel() runs.
			function injectORT(callback) {
				// If already loaded (e.g. hot-reload), just proceed
				if (typeof ort !== 'undefined') { callback(); return; }

				const s = document.createElement('script');
				s.src = 'https://cdn.jsdelivr.net/npm/onnxruntime-web@1.19.2/dist/ort.min.js';
				s.crossOrigin = 'anonymous';

				s.onload = () => {
					console.log('[d-Ape] ORT loaded:', typeof ort);
					callback();
				};

				s.onerror = () => {
					setStatus('error', 'Load Failed');
					showError('Failed to load ONNX Runtime Web from CDN. Check your internet connection.');
				};

				document.head.appendChild(s);
			}

			// Small delay so the page paints first, then fetch ORT + model
			setTimeout(() => injectORT(loadModel), 400);

		})();
		</script>

	</body>
</html>
