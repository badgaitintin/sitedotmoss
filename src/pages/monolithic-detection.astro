		<script>
		// ========================================================
		// ONNX Runtime Web · Monolithic d-Ape Inference Engine
		// ========================================================
		(function () {
			'use strict';

			// ── Config ──────────────────────────────────────────
			const MODEL_URL      = '/onrunmodel/monolithic_dape_web.onnx';
			const MODEL_DATA_URL = '/onrunmodel/monolithic_dape_web.onnx.data';
			const IMG_H = 320;
			const IMG_W = 1024;
