---
// monolithic-detection.astro — Monolithic d-Ape · On-Device Inference · Blackhole Theme
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Monolithic</title>
		<meta
			name="description"
			content="Run Monolithic d-Ape, a self-supervised stereo depth estimation model, entirely in your browser using ONNX Runtime Web. No server required."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Oswald:wght@400;500;600;700&family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<!-- ONNX Runtime Web is loaded dynamically inside the page script to guarantee availability -->
		<style is:global>
			/* ===========================
			   RESET
			=========================== */
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			/* ===========================
			   STREET ART / Y2K GRAFFITI TOKENS
			=========================== */
			:root {
				--g-pink:   #FF2D78;   /* hot pink */
				--g-cyan:   #00E5FF;   /* electric cyan */
				--g-orange: #FF6B00;   /* neon orange */
				--g-yellow: #FFD600;   /* chrome yellow */
				--g-purple: #9B30FF;   /* purple */
				--g-green:  #39FF14;   /* slime green */
				--g-dark:   rgba(10, 8, 18, 0.82);
				--g-panel:  rgba(8, 6, 18, 0.70);
				--g-border: rgba(255,255,255,0.15);
				--g-text:   #F0EAE0;
				--g-muted:  rgba(200, 180, 220, 0.55);
				/* aliases for legacy selectors */
				--bh-text:    var(--g-text);
				--bh-muted:   var(--g-muted);
				--bh-accent:  var(--g-pink);
				--bh-accent2: var(--g-cyan);
				--bh-accent3: var(--g-yellow);
				--bh-danger:  #FF2020;
				--bh-border:  var(--g-border);
			}

			/* ===========================
			   BASE
			=========================== */
			html,
			body {
				width: 100%;
				height: 100vh;
				overflow: hidden;
				background: #08060F;
				font-family: "Space Mono", "Courier New", monospace;
				color: var(--g-text);
				line-height: 1.5;
				margin: 0;
				padding: 0;
				position: relative;
			}

			/* ── VIDEO BACKGROUND ── */
			#bg-video {
				position: fixed;
				inset: 0;
				z-index: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				pointer-events: none;
				opacity: 0.75;
				filter: saturate(1.4) contrast(1.05) brightness(0.8);
			}

			/* Dark vignette + tint on top of video */
			body::before {
				content: "";
				position: fixed;
				inset: 0;
				z-index: 1;
				background:
					radial-gradient(ellipse at 20% 50%, rgba(155, 48, 255, 0.18) 0%, transparent 60%),
					radial-gradient(ellipse at 80% 30%, rgba(0, 229, 255, 0.12) 0%, transparent 55%),
					radial-gradient(ellipse at 60% 80%, rgba(255, 45, 120, 0.14) 0%, transparent 50%),
					linear-gradient(180deg, rgba(8,6,18,0.35) 0%, rgba(8,6,18,0.20) 50%, rgba(8,6,18,0.50) 100%);
				pointer-events: none;
			}

			#pointCloudCanvas {
				display: none;
			}

			a {
				color: var(--g-cyan);
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
				text-decoration-color: var(--g-pink);
				text-underline-offset: 3px;
			}

			.page-wrap {
				position: relative;
				z-index: 2;
				animation: bh-enter 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
				height: 100%;
			}
			@keyframes bh-enter {
				from { opacity: 0; transform: translateY(16px); }
				to   { opacity: 1; transform: translateY(0); }
			}
			body.is-exiting .page-wrap {
				animation: bh-exit 0.25s ease both;
				pointer-events: none;
			}
			@keyframes bh-exit {
				from { opacity: 1; transform: translateY(0); }
				to   { opacity: 0; transform: translateY(16px); }
			}

			/* ===========================
			   LAYOUT CONTAINER
			=========================== */
			.bh-page {
				position: relative;
				z-index: 1;
				max-width: 1200px;
				margin: 0 auto;
				height: 100vh;
				padding: 20px 16px;
				box-sizing: border-box;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			/* ── MAIN CARD — see-through panel ── */
			/* ===========================
			   GAMER ANIMATIONS
			=========================== */

			/* Neon border pulse — pink/cyan alternating */
			@keyframes neon-border-pulse {
				0%   { box-shadow: 0 0 0 1px rgba(0,0,0,0.6), 0 0 35px rgba(255,45,120,0.18), 0 0 70px rgba(0,229,255,0.06), inset 0 0 60px rgba(0,0,0,0.3); }
				50%  { box-shadow: 0 0 0 1px rgba(0,0,0,0.6), 0 0 55px rgba(0,229,255,0.22), 0 0 90px rgba(255,45,120,0.08), inset 0 0 60px rgba(0,0,0,0.3); }
				100% { box-shadow: 0 0 0 1px rgba(0,0,0,0.6), 0 0 35px rgba(255,45,120,0.18), 0 0 70px rgba(0,229,255,0.06), inset 0 0 60px rgba(0,0,0,0.3); }
			}

			/* Scanline sweep across the whole card */
			@keyframes scanline-sweep {
				0%   { transform: translateY(-100%); }
				100% { transform: translateY(200%); }
			}

			/* Glitch shift for title */
			@keyframes glitch-shift {
				0%, 90%, 100% { clip-path: none; transform: none; }
				91% { clip-path: inset(40% 0 30% 0); transform: translate(-3px, 0); }
				93% { clip-path: inset(10% 0 60% 0); transform: translate(3px, 0); }
				95% { clip-path: inset(70% 0 5% 0);  transform: translate(-2px, 0); color: var(--g-cyan); }
				97% { clip-path: inset(25% 0 45% 0); transform: translate(2px, 0); }
			}

			/* Corner tag flicker */
			@keyframes tag-flicker {
				0%, 94%, 100% { opacity: 1; }
				95% { opacity: 0.2; }
				96% { opacity: 1; }
				97% { opacity: 0.5; }
				98% { opacity: 1; }
			}

			/* Neon glow breathe — for sidebar dividers */
			@keyframes glow-breathe-pink {
				0%, 100% { border-right-color: rgba(255,45,120,0.15); }
				50%       { border-right-color: rgba(255,45,120,0.40); }
			}
			@keyframes glow-breathe-cyan {
				0%, 100% { border-left-color: rgba(0,229,255,0.15); }
				50%       { border-left-color: rgba(0,229,255,0.40); }
			}

			/* Viewport cyan top-border pulse */
			@keyframes viewport-glow {
				0%, 100% { border-top-color: var(--g-cyan); box-shadow: inset 0 0 40px rgba(0,0,0,0.5), 0 0 8px rgba(0,229,255,0.08); }
				50%       { border-top-color: var(--g-pink); box-shadow: inset 0 0 40px rgba(0,0,0,0.5), 0 0 20px rgba(255,45,120,0.15); }
			}

			/* Run button idle glow pulse */
			@keyframes btn-idle-glow {
				0%, 100% { box-shadow: 0 0 20px rgba(255,45,120,0.35), 0 0 50px rgba(255,45,120,0.12), inset 0 1px 0 rgba(255,180,210,0.4); }
				50%       { box-shadow: 0 0 30px rgba(255,45,120,0.55), 0 0 70px rgba(255,45,120,0.20), inset 0 1px 0 rgba(255,180,210,0.4); }
			}

			/* Badge blink */
			@keyframes badge-blink {
				0%, 85%, 100% { opacity: 1; }
				90% { opacity: 0.6; }
				92% { opacity: 1; }
			}

			/* Loading bar shimmer */
			@keyframes shimmer {
				0%   { background-position: -200% center; }
				100% { background-position: 200% center; }
			}

			.bh-main-card {
				position: relative;
				/* Key: dark but NOT fully opaque so video shows */
				background: var(--g-dark);
				backdrop-filter: blur(2px) saturate(1.2);
				-webkit-backdrop-filter: blur(2px) saturate(1.2);
				border: 1.5px solid rgba(255,255,255,0.12);
				border-top: 3px solid var(--g-pink);
				border-left: 3px solid var(--g-cyan);
				border-radius: 0px;
				padding: 22px;
				display: flex;
				gap: 22px;
				height: calc(100vh - 64px);
				align-items: stretch;
				box-sizing: border-box;
				overflow: hidden;
				/* Animated neon glow */
				animation: neon-border-pulse 4s ease-in-out infinite;
			}

			/* Scanline sweep overlay — lives inside card via a fixed pseudo child */
			.bh-main-card .scanline-fx {
				position: absolute;
				inset: 0;
				pointer-events: none;
				z-index: 5;
				overflow: hidden;
			}
			.bh-main-card .scanline-fx::after {
				content: '';
				position: absolute;
				left: 0;
				width: 100%;
				height: 60px;
				background: linear-gradient(180deg,
					transparent 0%,
					rgba(0, 229, 255, 0.04) 50%,
					transparent 100%
				);
				animation: scanline-sweep 5s linear infinite;
				top: 0;
			}

			/* Neon corner tag — top-left */
			.bh-main-card::before {
				content: 'MONOLITHIC';
				position: absolute;
				top: -12px;
				left: 20px;
				font-family: "Bebas Neue", sans-serif;
				font-size: 0.65rem;
				letter-spacing: 4px;
				color: var(--g-pink);
				background: #08060F;
				padding: 0 8px;
				z-index: 20;
				pointer-events: none;
				text-shadow: 0 0 10px var(--g-pink);
				animation: tag-flicker 8s ease-in-out infinite;
			}

			/* Neon corner accent — bottom-right, animated width */
			@keyframes corner-grow {
				0%, 100% { width: 50px; opacity: 0.8; }
				50%       { width: 90px; opacity: 1; }
			}
			.bh-main-card::after {
				content: '';
				position: absolute;
				bottom: 0;
				right: 0;
				width: 60px;
				height: 3px;
				background: linear-gradient(90deg, transparent, var(--g-cyan));
				pointer-events: none;
				z-index: 10;
				animation: corner-grow 3s ease-in-out infinite;
			}

			/* ===========================
			   SIDEBARS & WORKSPACE
			=========================== */
			.wbc-series-sidebar {
				width: 230px;
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				gap: 12px;
				border-right: 1px solid rgba(255,45,120,0.2);
				padding-right: 18px;
				overflow-y: auto;
				animation: glow-breathe-pink 4s ease-in-out infinite;
			}
			.wbc-series-sidebar::-webkit-scrollbar { width: 2px; }
			.wbc-series-sidebar::-webkit-scrollbar-track { background: transparent; }
			.wbc-series-sidebar::-webkit-scrollbar-thumb {
				background: var(--g-pink);
				box-shadow: 0 0 6px var(--g-pink);
			}

			.wbc-workspace-canvas {
				flex: 1;
				display: flex;
				flex-direction: column;
				min-width: 0;
				height: 100%;
				overflow: hidden;
				gap: 12px;
				justify-content: space-between;
			}

			.wbc-control-sidebar {
				width: 295px;
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				gap: 10px;
				border-left: 1px solid rgba(0,229,255,0.2);
				padding-left: 18px;
				overflow-y: auto;
				animation: glow-breathe-cyan 4s ease-in-out infinite 2s;
			}
			.wbc-control-sidebar::-webkit-scrollbar { width: 2px; }
			.wbc-control-sidebar::-webkit-scrollbar-track { background: transparent; }
			.wbc-control-sidebar::-webkit-scrollbar-thumb {
				background: var(--g-cyan);
				box-shadow: 0 0 6px var(--g-cyan);
			}

			/* ===========================
			   SERIES BUTTONS
			=========================== */
			.series-btn {
				background: rgba(255,255,255,0.03);
				border: 1px solid rgba(255,255,255,0.08);
				border-left: 3px solid transparent;
				border-radius: 0px;
				padding: 10px 12px;
				display: flex;
				align-items: center;
				gap: 10px;
				cursor: pointer;
				transition: all 0.15s ease;
				position: relative;
				text-align: left;
				width: 100%;
			}
			.series-btn:hover:not(.locked) {
				background: rgba(255,45,120,0.08);
				border-left-color: var(--g-pink);
				border-color: rgba(255,45,120,0.3);
				box-shadow: 0 0 12px rgba(255,45,120,0.08);
			}
			.series-btn.active {
				background: rgba(255,45,120,0.1);
				border-left-color: var(--g-pink);
				border-color: rgba(255,45,120,0.25);
				box-shadow: inset 0 0 20px rgba(255,45,120,0.06), 0 0 10px rgba(255,45,120,0.1);
			}
			.series-btn.active .series-name { color: var(--g-pink); text-shadow: 0 0 8px rgba(255,45,120,0.6); }
			.series-btn.active .series-desc { color: var(--g-cyan); }
			.series-color-bar { display: none; }
			.series-title-wrap { display: flex; flex-direction: column; gap: 2px; }
			.series-name {
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--g-text);
				text-transform: uppercase;
				letter-spacing: 1px;
				font-family: "Bebas Neue", sans-serif;
				font-size: 0.95rem;
			}
			.series-desc {
				font-size: 0.6rem;
				color: var(--g-muted);
				font-family: "Share Tech Mono", monospace;
				letter-spacing: 0.5px;
			}

			/* ===========================
			   HEADER & TITLES
			=========================== */
			.bh-header {
				display: flex;
				flex-direction: column;
				gap: 3px;
			}
			.wbc-back-btn {
				width: fit-content;
				background: transparent;
				border: none;
				color: var(--g-muted);
				display: inline-flex;
				align-items: center;
				gap: 6px;
				cursor: pointer;
				font-size: 0.65rem;
				font-weight: 400;
				text-decoration: none;
				transition: all 0.15s;
				padding: 0;
				margin-bottom: 4px;
				font-family: "Share Tech Mono", monospace;
				text-transform: uppercase;
				letter-spacing: 2px;
			}
			.wbc-back-btn:hover {
				color: var(--g-cyan);
				text-decoration: none;
				text-shadow: 0 0 8px var(--g-cyan);
			}
			.bh-title {
				font-size: 2rem;
				font-weight: 400;
				line-height: 1;
				letter-spacing: 4px;
				margin: 0;
				font-family: "Bebas Neue", sans-serif;
				text-transform: uppercase;
			}
			.title-mono {
				color: var(--g-text);
				/* white chrome-like effect */
				text-shadow:
					0 1px 0 rgba(255,255,255,0.4),
					0 -1px 0 rgba(0,0,0,0.6),
					0 0 20px rgba(255,255,255,0.1);
			}
			.title-dape {
				color: var(--g-pink);
				text-shadow:
					0 0 10px var(--g-pink),
					0 0 30px rgba(255,45,120,0.4);
				animation: glitch-shift 7s ease-in-out infinite;
				display: inline-block;
			}
			.bh-subtitle {
				font-size: 0.6rem;
				color: var(--g-cyan);
				margin: 0;
				font-family: "Share Tech Mono", monospace;
				text-transform: uppercase;
				letter-spacing: 3px;
				text-shadow: 0 0 8px rgba(0,229,255,0.5);
			}

			/* ===========================
			   MODEL STATUS CARD
			=========================== */
			.model-status-card {
				background: rgba(255,255,255,0.03);
				border: 1px solid rgba(255,255,255,0.08);
				border-left: 3px solid var(--g-cyan);
				border-radius: 0px;
				padding: 10px 14px;
				display: flex;
				flex-direction: column;
				gap: 8px;
				box-shadow: 0 0 10px rgba(0,229,255,0.06);
			}
			.status-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.status-label {
				font-size: 0.6rem;
				text-transform: uppercase;
				letter-spacing: 2px;
				color: var(--g-cyan);
				font-weight: 700;
				font-family: "Share Tech Mono", monospace;
				text-shadow: 0 0 6px rgba(0,229,255,0.4);
			}
			.model-status {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				font-family: "Share Tech Mono", monospace;
				font-size: 0.6rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 1.5px;
				color: var(--g-muted);
			}
			.model-status.ready  { color: var(--g-green);  text-shadow: 0 0 8px var(--g-green); }
			.model-status.loading{ color: var(--g-yellow); text-shadow: 0 0 8px var(--g-yellow); }
			.model-status.error  { color: var(--bh-danger); text-shadow: 0 0 8px var(--bh-danger); }

			.status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--g-muted);
				flex-shrink: 0;
			}
			.model-status.ready .status-dot  { background: var(--g-green);  box-shadow: 0 0 8px var(--g-green), 0 0 16px var(--g-green); }
			.model-status.loading .status-dot{ background: var(--g-yellow); animation: pulse-status 0.9s infinite ease-in-out; box-shadow: 0 0 8px var(--g-yellow); }
			.model-status.error .status-dot  { background: var(--bh-danger);}
			@keyframes pulse-status {
				0%, 100% { opacity: 0.3; transform: scale(0.8); }
				50%       { opacity: 1;   transform: scale(1.2); }
			}

			.model-load-bar { display: none; flex-direction: column; gap: 4px; }
			.model-load-bar.visible { display: flex; }
			.load-bar-track {
				height: 3px;
				background: rgba(255,255,255,0.06);
				overflow: hidden;
				position: relative;
			}
			.load-bar-fill {
				height: 100%;
				width: 0%;
				background: linear-gradient(90deg, var(--g-pink), var(--g-cyan));
				transition: width 0.3s;
				box-shadow: 0 0 8px var(--g-pink);
			}
			.load-bar-text {
				font-size: 0.58rem;
				color: var(--g-muted);
				text-align: right;
				font-family: "Share Tech Mono", monospace;
			}

			/* ===========================
			   MODE TOGGLE TABS
			=========================== */
			.mode-toggle {
				background: rgba(0,0,0,0.35);
				border: 1px solid rgba(255,255,255,0.08);
				border-top: 2px solid var(--g-orange);
				border-radius: 0px;
				padding: 2px;
				display: flex;
				gap: 2px;
			}
			.mode-btn {
				flex: 1;
				background: transparent;
				border: none;
				color: var(--g-muted);
				font-family: "Share Tech Mono", monospace;
				font-size: 0.65rem;
				font-weight: 400;
				padding: 7px 8px;
				cursor: pointer;
				transition: all 0.15s ease;
				text-align: center;
				border-radius: 0px;
				text-transform: uppercase;
				letter-spacing: 1.5px;
			}
			.mode-btn:hover {
				color: var(--g-orange);
				background: rgba(255,107,0,0.06);
				text-shadow: 0 0 8px var(--g-orange);
			}
			.mode-btn.active {
				background: var(--g-orange);
				color: #000;
				font-weight: 700;
				box-shadow: 0 0 16px rgba(255,107,0,0.45);
				text-shadow: none;
			}

			/* ===========================
			   UPLOAD ZONES
			=========================== */
			.upload-zone {
				border: 1px dashed rgba(255,255,255,0.15);
				padding: 16px 12px;
				text-align: center;
				background: rgba(255,255,255,0.02);
				cursor: pointer;
				position: relative;
				transition: all 0.15s ease;
				border-radius: 0px;
			}
			.upload-zone:hover {
				border-color: var(--g-pink);
				border-style: solid;
				background: rgba(255,45,120,0.05);
				box-shadow: inset 0 0 20px rgba(255,45,120,0.04), 0 0 10px rgba(255,45,120,0.1);
			}
			.upload-zone input[type=file] {
				position: absolute;
				inset: 0;
				opacity: 0;
				cursor: pointer;
			}
			.upload-icon {
				width: 20px;
				height: 20px;
				stroke: var(--g-pink);
				margin: 0 auto 8px;
				display: block;
				filter: drop-shadow(0 0 4px var(--g-pink));
			}
			.upload-label {
				font-size: 0.68rem;
				color: var(--g-muted);
				line-height: 1.4;
				font-family: "Share Tech Mono", monospace;
				text-transform: uppercase;
				letter-spacing: 1px;
			}

			/* ===========================
			   BUTTONS
			=========================== */
			.run-btn {
				width: 100%;
				padding: 12px 16px;
				background: linear-gradient(135deg, var(--g-pink) 0%, #C4006A 100%);
				border: none;
				border-top: 2px solid #FF80B0;
				border-radius: 0px;
				color: #fff;
				font-family: "Bebas Neue", sans-serif;
				font-size: 1.15rem;
				font-weight: 400;
				letter-spacing: 5px;
				text-transform: uppercase;
				cursor: pointer;
