---
// monolithic-detection.astro — Monolithic Detection · Blackhole Theme
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Monolithic Deep-Learning — Custom Deep Learning models built from scratch."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Coral+Pixels&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Libre+Barcode+128+Text&family=Trirong:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
			rel="stylesheet"
		/>
		<style>
			/* ===========================
			   RESET
			=========================== */
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			/* ===========================
			   BLACKHOLE TOKEN SYSTEM
			=========================== */
			:root {
				--bh-void: #000000;
				--bh-deep: #07080a;
				--bh-surface: #0d0f12;
				--bh-card: #111318;
				--bh-border: rgba(255, 255, 255, 0.07);
				--bh-border-hi: rgba(255, 255, 255, 0.14);
				--bh-text: #e8eaf0;
				--bh-muted: #6b7280;
				--bh-accent: #818cf8; /* slate blue */
				--bh-accent2: #a78bfa; /* violet */
				--bh-accent3: #34d399; /* emerald (gap badges) */
				--bh-danger: #f87171;
				--bh-glow: transparent;
				--bh-glow-sm: transparent;
			}

			/* ===========================
			   BASE
			=========================== */
			html,
			body {
				width: 100%;
				min-height: 100vh;
				background: #000;
				font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
				color: var(--bh-text);
				line-height: 1.6;
			}

			a {
				color: var(--bh-accent);
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}

			/* ===========================
			   PAGE TRANSITION
			=========================== */
			.page-wrap {
				animation: bh-enter 0.5s cubic-bezier(0.1, 0.9, 0.2, 1) both;
			}
			@keyframes bh-enter {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			body.is-exiting .page-wrap {
				animation: bh-exit 0.28s cubic-bezier(0.4, 0, 1, 1) both;
				pointer-events: none;
			}
			@keyframes bh-exit {
				from {
					opacity: 1;
					transform: translateY(0);
				}
				to {
					opacity: 0;
					transform: translateY(20px);
				}
			}

			/* ===========================
			   ENERGY BURST BACKGROUND
			   — Radial gradient from bright center
			     to void, fixed behind all content
			=========================== */
			/* ===========================
			   FLUID ORB BACKGROUND
			   — Scattered atmospheric orbs fading
			     and drifting slowly, scroll-linked
			=========================== */
			.bh-bg {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 0;
				overflow: hidden;
				background: #000;
			}

			/* Theme Containers */
			.bh-bg-theme {
				position: absolute;
				inset: 0;
				will-change: filter;
				filter: invert(var(--scroll-invert, 0));
				isolation: isolate;
			}

			.bh-glow-orb {
				position: absolute;
				border-radius: 50%;
				mix-blend-mode: screen;
				will-change: transform, border-radius;
			}

			/* RGB Orbs (Red, Green, Blue) - Positioned closer and animated to overlap */
			.bh-glow-orb--1 {
				width: 500px;
				height: 500px;
				top: 10%;
				left: 15%;
				filter: blur(75px);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.55) 0%, rgba(239, 68, 68, 0.8) 30%, rgba(185, 28, 28, 0.25) 70%, rgba(0, 0, 0, 0) 100%);
				animation: drift-1 28s infinite ease-in-out, morph-1 16s infinite ease-in-out;
			}
			.bh-glow-orb--2 {
				width: 380px;
				height: 380px;
				top: 25%;
				left: 45%;
				filter: blur(65px);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.6) 0%, rgba(34, 197, 94, 0.8) 30%, rgba(21, 128, 61, 0.2) 70%, rgba(0, 0, 0, 0) 100%);
				animation: drift-2 24s infinite ease-in-out, morph-2 12s infinite ease-in-out;
			}
			.bh-glow-orb--3 {
				width: 300px;
				height: 300px;
				bottom: 15%;
				left: 30%;
				filter: blur(55px);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.6) 0%, rgba(59, 130, 246, 0.8) 30%, rgba(29, 78, 216, 0.25) 70%, rgba(0, 0, 0, 0) 100%);
				animation: drift-3 20s infinite ease-in-out, morph-3 10s infinite ease-in-out;
			}

			@keyframes drift-1 {
				0%, 100% { transform: translate(0, 0) scale(1); }
				33% { transform: translate(200px, 120px) scale(1.1); }
				66% { transform: translate(-100px, -50px) scale(0.9); }
			}

			@keyframes drift-2 {
				0%, 100% { transform: translate(0, 0) scale(1); }
				33% { transform: translate(-250px, 150px) scale(0.9); }
				66% { transform: translate(150px, -100px) scale(1.1); }
			}

			@keyframes drift-3 {
				0%, 100% { transform: translate(0, 0) scale(1); }
				33% { transform: translate(120px, -200px) scale(1.15); }
				66% { transform: translate(-180px, 100px) scale(0.85); }
			}

			@keyframes morph-1 {
				0%, 100% { border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%; }
				33% { border-radius: 70% 30% 52% 48% / 60% 40% 60% 40%; }
				66% { border-radius: 50% 50% 35% 65% / 40% 60% 40% 60%; }
			}

			@keyframes morph-2 {
				0%, 100% { border-radius: 50% 50% 30% 70% / 50% 60% 40% 50%; }
				33% { border-radius: 40% 60% 60% 40% / 40% 50% 50% 60%; }
				66% { border-radius: 60% 40% 40% 60% / 60% 40% 60% 40%; }
			}

			@keyframes morph-3 {
				0%, 100% { border-radius: 38% 62% 40% 60% / 53% 48% 52% 47%; }
				33% { border-radius: 65% 35% 62% 38% / 45% 55% 40% 60%; }
				66% { border-radius: 48% 52% 35% 65% / 60% 40% 55% 45%; }
			}

			/* Shared vignette overlay fading to solid black at the outer boundaries */
			.bh-vignette {
				position: absolute;
				inset: 0;
				z-index: 4;
				background: radial-gradient(
					ellipse 100% 100% at 50% 50%,
					transparent 30%,
					rgba(0, 0, 0, 0.45) 70%,
					rgba(0, 0, 0, 0.96) 100%
				);
			}

			.bh-bubbles {
				position: absolute;
				inset: 0;
				z-index: 3; /* above blue/orange gradients, below vignette */
				pointer-events: none;
				overflow: hidden;
			}

			.bh-bubble {
				position: absolute;
				bottom: -60px;
				left: var(--left);
				width: var(--size);
				height: var(--size);
				opacity: 0;
				background: radial-gradient(
					circle at 30% 30%,
					rgba(255, 255, 255, 0.08) 0%,
					rgba(255, 255, 255, 0.01) 70%
				);
				border: 1px solid rgba(255, 255, 255, 0.09);
				border-radius: 50%;
				box-shadow:
					inset 0 2px 4px rgba(255, 255, 255, 0.15),
					0 2px 10px rgba(0, 0, 0, 0.3);
				animation: float-up var(--duration) infinite linear;
				animation-delay: var(--delay);
				will-change: transform, opacity;
			}

			@keyframes float-up {
				0% {
					transform: translateY(0) translateX(0) scale(0.8);
					opacity: 0;
				}
				10% {
					opacity: var(--opacity);
				}
				90% {
					opacity: var(--opacity);
				}
				100% {
					transform: translateY(-110vh) translateX(var(--sway))
						scale(1.1);
					opacity: 0;
				}
			}

			/* ===========================
			   LAYOUT CONTAINER
			=========================== */
			.bh-page {
				position: relative;
				z-index: 1;
				max-width: 860px;
				margin: 0 auto;
				padding: 48px 24px 80px;
				box-sizing: border-box;
			}

			/* ===========================
			   TOP NAV BAR
			=========================== */
			.bh-topbar {
				display: flex;
				align-items: center;
				gap: 16px;
				margin-bottom: 24px;
			}

			.bh-back {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 7px 14px;
				border: 1px solid var(--bh-border-hi);
				border-radius: 4px;
				font-size: 0.82rem;
				font-weight: 500;
				color: var(--bh-muted);
				background: var(--bh-card);
				transition:
					color 0.2s,
					border-color 0.2s,
					background 0.2s;
				cursor: pointer;
			}
			.bh-back:hover {
				color: var(--bh-text);
				border-color: var(--bh-accent);
				background: rgba(124, 156, 255, 0.06);
				text-decoration: none;
			}

			.bh-breadcrumb {
				font-size: 0.78rem;
				color: var(--bh-muted);
				letter-spacing: 0.3px;
			}
			.bh-breadcrumb span {
				color: var(--bh-text);
				font-weight: 500;
			}

			/* Apply Google Sans to all content sections starting from 00 downwards */
			.bh-content-scroll {
				font-family: "Google Sans", sans-serif;
			}

			/* Style SVG flowcharts with Google Sans */
			.bh-diag-svg text {
				font-family: "Google Sans", sans-serif;
			}

			/* ===========================
			   HEADER & SCROLL LAYOUT
			=========================== */
			.bh-header {
				display: flex;
				flex-direction: column;
				gap: 24px;
				margin-bottom: 48px;
				width: 100%;
			}

			@media (min-width: 900px) {
				.bh-page {
					max-width: 1100px !important;
					width: 100%;
					padding: 60px 40px 120px !important;
					display: flex;
					flex-direction: column;
					margin: 0 auto !important;
				}

				.bh-topbar {
					margin-bottom: 32px;
				}

				.bh-header {
					display: grid;
					grid-template-columns: auto 1fr;
					gap: 64px;
					align-items: stretch;
					flex-shrink: 0;
					margin-bottom: 72px;
				}

				.bh-header-right {
					display: flex;
					flex-direction: column;
					justify-content: flex-start;
					align-items: stretch;
				}

				.bh-header-right .bh-summary {
					text-align: justify;
					text-justify: inter-character;
					text-align-last: justify;
					margin: 0;
					font-size: 0.85rem;
					line-height: 2.0;
					max-width: 100%;
				}

				.bh-title {
					font-size: clamp(2.2rem, 4vw, 3.2rem) !important;
					align-items: flex-start !important;
					justify-content: space-between !important;
					text-align: left !important;
					display: flex;
					flex-direction: column;
					margin: 0;
					height: 109px;
				}

				.bh-content-scroll {
					display: flex;
					flex-direction: column;
					gap: 80px;
					overflow-x: visible;
					overflow-y: visible;
					flex-grow: 0;
					padding-bottom: 0;
					align-items: stretch;
				}

				.bh-section {
					margin-bottom: 0 !important;
					display: flex;
					flex-direction: column;
					width: 100% !important;
				}

				.bh-divider {
					display: block !important;
					height: 1px;
					background: linear-gradient(
						to right,
						transparent,
						rgba(255, 255, 255, 0.08),
						transparent
					);
					margin: 100px 0;
				}
			}

			/* ===========================
			   HERO SECTION
			=========================== */
			.bh-hero {
				margin-bottom: 80px;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}

			.bh-eyebrow {
				font-size: 0.72rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 2px;
				color: var(--bh-accent);
				margin-bottom: 20px;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
				width: 100%;
			}
			.bh-eyebrow::before {
				content: "";
				display: block;
				width: 60px;
				height: 1px;
				background: linear-gradient(
					to left,
					var(--bh-accent),
					transparent
				);
			}
			.bh-eyebrow::after {
				content: "";
				display: block;
				width: 60px;
				height: 1px;
				background: linear-gradient(
					to right,
					var(--bh-accent),
					transparent
				);
			}

			.bh-title {
				font-size: clamp(2.8rem, 7vw, 5rem);
				font-weight: 900;
				line-height: 1.1;
				letter-spacing: -1px;
				margin-bottom: 16px;
				color: #fff;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 4px;
			}

			.title-monolithic,
			.title-deep-learning {
				font-family: "Google Sans", sans-serif;
				background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			.bh-subtitle {
				font-family: "Google Sans", sans-serif;
				font-size: 0.95rem;
				color: rgba(255, 255, 255, 0.75);
				font-weight: 400;
				margin-bottom: 28px;
				line-height: 1.5;
				letter-spacing: 0.3px;
			}

			.bh-summary {
				font-family: "Google Sans", sans-serif;
				font-size: 0.88rem;
				color: rgba(255, 255, 255, 0.8);
				line-height: 1.8;
				max-width: 620px;
				margin-bottom: 32px;
				margin-left: auto;
				margin-right: auto;
				font-weight: 400;
			}

			.bh-summary strong {
				color: #ffffff !important;
				font-weight: 600;
			}

			.bh-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				justify-content: center;
			}

			.bh-tag {
				padding: 4px 12px;
				border: 1px solid var(--bh-border-hi);
				border-radius: 0;
				font-size: 0.73rem;
				font-weight: 600;
				color: var(--bh-muted);
				background: var(--bh-card);
				letter-spacing: 0.3px;
				transition:
					border-color 0.2s,
					color 0.2s;
			}
			.bh-tag:hover {
				border-color: var(--bh-accent);
				color: var(--bh-accent);
			}

			/* ===========================
			   SECTION WRAPPER
			=========================== */
			.bh-section {
				margin-bottom: 80px;
				scroll-margin-top: 48px;
			}

			.bh-section-head {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 6px;
				margin-bottom: 32px;
			}

			.bh-section-num {
				font-size: 0.85rem;
				font-weight: 600;
				color: var(--bh-accent);
				font-variant-numeric: tabular-nums;
				text-transform: uppercase;
				letter-spacing: 0.15em;
				opacity: 0.9;
			}

			.bh-section-title {
				font-size: clamp(1.8rem, 4vw, 2.4rem);
				font-weight: 700;
				color: #fff;
				letter-spacing: -0.02em;
				line-height: 1.25;
			}

			.bh-section-line {
				display: none;
			}

			.bh-prose {
				font-size: 1.15rem;
				color: #d1d5db;
				line-height: 1.65;
				margin-bottom: 32px;
				font-weight: 400;
			}

			.bh-prose strong {
				color: #ffffff;
				font-weight: 600;
			}

			/* ===========================
			   ARCHITECTURE DIAGRAM
			=========================== */
			.bh-diag-wrap {
				background: rgba(22, 22, 23, 0.45);
				backdrop-filter: blur(24px) saturate(160%);
				-webkit-backdrop-filter: blur(24px) saturate(160%);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 0;
				padding: 40px 28px;
				overflow-x: auto;
				scrollbar-width: thin;
				scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
				margin-bottom: 40px;
			}

			.bh-diag-svg {
				display: block;
				width: 100%;
				height: auto;
				max-width: 760px;
				margin: 0 auto;
			}

			/* ===========================
			   VARIANTS GRID (Section 00)
			=========================== */
			.bh-variants-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 20px;
				margin-bottom: 24px;
			}

			
			
			/* ===========================
			   ROAD TIMELINE STYLES (2D PIXEL CITY STREET)
			=========================== */

			/* ── Wrapper that holds BOTH scene AND card, removing any gap ── */
			.scene-card-wrapper {
				position: relative;
				margin: 30px 0;
				border: 3px solid #2a2c3e;
				box-shadow: 8px 8px 0px #000;
				overflow: hidden;
				image-rendering: pixelated;
			}

			.road-container {
				position: relative;
				width: 100%;
				height: 280px;
				overflow: hidden;
				/* Sky background */
				background: linear-gradient(180deg,
					#7ec8e3 0%,   #7ec8e3 40px,
					#9dd7ed 40px, #9dd7ed 90px,
					#bde8f5 90px, #bde8f5 130px
				);
			}

			/* Clouds */
			.px-cloud {
				position: absolute;
				background: #fff;
				border-radius: 999px;
				opacity: 0.9;
			}
			.px-cloud::before, .px-cloud::after {
				content: '';
				position: absolute;
				background: #fff;
				border-radius: 50%;
			}
			.px-cloud--1 { left: 5%;  top: 12px; width: 72px; height: 20px; }
			.px-cloud--1::before { width: 36px; height: 36px; top: -20px; left: 10px; }
			.px-cloud--1::after  { width: 26px; height: 26px; top: -14px; left: 36px; }
			.px-cloud--2 { left: 34%; top: 6px;  width: 56px; height: 16px; }
			.px-cloud--2::before { width: 28px; height: 28px; top: -16px; left: 8px; }
			.px-cloud--2::after  { width: 20px; height: 20px; top: -10px; left: 28px; }
			.px-cloud--3 { left: 58%; top: 18px; width: 64px; height: 18px; }
			.px-cloud--3::before { width: 32px; height: 32px; top: -18px; left: 10px; }
			.px-cloud--3::after  { width: 22px; height: 22px; top: -12px; left: 34px; }
			.px-cloud--4 { left: 80%; top: 8px;  width: 52px; height: 14px; }
			.px-cloud--4::before { width: 26px; height: 26px; top: -14px; left: 8px; }
			.px-cloud--4::after  { width: 18px; height: 18px; top: -8px; left: 26px; }

			/* Buildings strip */
			.buildings-strip {
				position: absolute;
				bottom: 60px;   /* road top = 280-60 = 220 */
				left: 0; right: 0;
				height: 200px;
				display: flex;
				align-items: flex-end;
				gap: 0;
			}

			/* Pixel trees behind buildings */
			.bg-tree {
				position: absolute;
				bottom: 60px;
				z-index: 5;
				filter: drop-shadow(3px 3px 2px rgba(0,0,0,0.25));
			}

			/* Street lamp */
			.street-lamp {
				position: absolute;
				bottom: 60px;   /* sits on pavement */
				z-index: 20;
			}

			/* Back pavement: 220 → 235px (from bottom: 60→45px) */
			.back-pavement {
				position: absolute;
				left: 0; right: 0;
				bottom: 45px;
				height: 15px;
				background: linear-gradient(180deg, #9ca3af 0%, #6b7280 100%);
				border-top: 2px solid #4b5563;
			}

			/* Road: 235 → 270px (from bottom: 45→10px) */
			.road-strip {
				position: absolute;
				left: 0; right: 0;
				bottom: 10px;
				height: 35px;
				background: #374151;
				border-top: 3px solid #1f2937;
			}

			/* Lane dashes */
			.lane-dashes {
				position: absolute;
				top: 50%;
				left: 0; right: 0;
				height: 3px;
				transform: translateY(-50%);
				background: repeating-linear-gradient(90deg,
					transparent 0px, transparent 18px,
					#fff 18px, #fff 36px
				);
				opacity: 0.5;
			}

			/* Crosswalk */
			.crosswalk {
				position: absolute;
				right: 15%;
				top: 0; bottom: 0;
				width: 36px;
				background: repeating-linear-gradient(180deg,
					#fff 0px, #fff 5px,
					transparent 5px, transparent 9px
				);
				opacity: 0.55;
			}

			/* Front kerb: 270 → 280px (bottom: 10→0px) */
			.front-kerb {
				position: absolute;
				left: 0; right: 0;
				bottom: 0;
				height: 10px;
				background: linear-gradient(180deg, #cbd5e1 0%, #94a3b8 100%);
				border-top: 2px solid #64748b;
			}

			/* Milestone signs on road */
			.road-milestone {
				position: absolute;
				bottom: 8px;
				transform: translateX(-50%);
				display: flex;
				flex-direction: column;
				align-items: center;
				cursor: pointer;
				z-index: 30;
				transition: transform 0.2s;
			}
			.road-milestone:hover { transform: translateX(-50%) scale(1.08); }

			.milestone-pin {
				width: 4px;
				height: 28px;
				background: #94a3b8;
				position: relative;
				transition: all 0.25s;
			}
			.milestone-pin::before {
				content: '';
				position: absolute;
				top: -4px; left: -8px;
				width: 20px; height: 6px;
				background: #64748b;
				border-radius: 1px;
			}
			.road-milestone.active .milestone-pin { background: var(--accent-color); }
			.road-milestone.active .milestone-pin::before { background: var(--accent-color); }

			.milestone-label {
				position: absolute;
				bottom: 38px;
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 1px;
				text-transform: uppercase;
				color: rgba(255,255,255,0.5);
				background: rgba(10,10,16,0.75);
				backdrop-filter: blur(6px);
				border: 1px solid rgba(255,255,255,0.08);
				padding: 2px 7px;
				border-radius: 3px;
				white-space: nowrap;
				transition: color 0.2s, border-color 0.2s;
			}
			.road-milestone.active .milestone-label {
				color: var(--accent-color);
				border-color: rgba(var(--accent-rgb), 0.4);
			}

			/* Walker on road */
			.road-walker {
				position: absolute;
				bottom: 10px;
				z-index: 25;
				transition: left 1.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s;
				pointer-events: none;
				width: 44px;
				height: 52px;
				transform: translateX(-50%) scaleX(1);
				filter: drop-shadow(3px 3px 2px rgba(0,0,0,0.4));
			}

			.walker-svg { display: block; width: 100%; height: 100%; }

			.road-walker.is-walking .walker-leg-l { animation: swing-leg-l 0.4s infinite steps(2); transform-origin: 16px 36px; }
			.road-walker.is-walking .walker-leg-r { animation: swing-leg-r 0.4s infinite steps(2); transform-origin: 24px 36px; }
			.road-walker.is-walking .walker-svg   { animation: walker-bob  0.2s infinite steps(2); }
			.road-walker.is-walking .walker-arm-l { animation: swing-arm-l 0.4s infinite steps(2); transform-origin: 10px 22px; }
			.road-walker.is-walking .walker-arm-r { animation: swing-arm-r 0.4s infinite steps(2); transform-origin: 32px 22px; }

			@keyframes swing-leg-l { 0%,100% { transform: rotate(-30deg); } 50% { transform: rotate(30deg); } }
			@keyframes swing-leg-r { 0%,100% { transform: rotate(30deg); }  50% { transform: rotate(-30deg); } }
			@keyframes swing-arm-l { 0%,100% { transform: rotate(25deg); }  50% { transform: rotate(-25deg); } }
			@keyframes swing-arm-r { 0%,100% { transform: rotate(-25deg); } 50% { transform: rotate(25deg); } }
			@keyframes walker-bob  { 0%,100% { transform: translateY(0); }   50% { transform: translateY(-4px); } }

			/* Car on road */
			.road-car {
				position: absolute;
				bottom: 10px;
				z-index: 18;
				opacity: 0;
				width: 72px;
				height: 40px;
				filter: drop-shadow(2px 4px 4px rgba(0,0,0,0.5));
			}
			.road-car.drive { animation: car-drive 3.5s linear; }
			@keyframes car-drive {
				0%   { left: -90px; opacity: 0; }
				5%   { opacity: 1; }
				95%  { opacity: 1; }
				100% { left: calc(100% + 90px); opacity: 0; }
			}

			/* ── Evolution Panels: no gap ── */
			.evolution-panels-window {
				position: relative;
				width: 100%;
				margin-top: 0;
				overflow: hidden;
				background: #0c0d12;
			}

			.evolution-panels-track {
				display: flex;
				width: 300%;
				transition: transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.evolution-panel {
				width: 33.3333%;
				flex-shrink: 0;
				background: #0c0d12;
				padding: 32px;
				position: relative;
				box-sizing: border-box;
				border-right: 1px solid #1d212f;
			}
			.evolution-panel::before {
				content: '';
				position: absolute;
				inset: 8px;
				border: 1px solid #1d2535;
				pointer-events: none;
			}

			.evolution-panel--det  { --accent-color: #f59e0b; --accent-rgb: 245,158,11;  --card-glow: rgba(245,158,11,0.1);  --badge-color-rgb: 245,158,11; }
			.evolution-panel--dape { --accent-color: #8b5cf6; --accent-rgb: 139,92,246;  --card-glow: rgba(139,92,246,0.1);  --badge-color-rgb: 139,92,246; }
			.evolution-panel--soon { --accent-color: #06b6d4; --accent-rgb: 6,182,212;   --card-glow: rgba(6,182,212,0.1);   --badge-color-rgb: 6,182,212; }

			.card-glow {
				position: absolute;
				top: 0; left: 0; right: 0; height: 100px;
				background: radial-gradient(100px circle at 50% 0px, var(--card-glow), transparent 70%);
				pointer-events: none; z-index: 1;
			}

			.panel-layout { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 36px; align-items: center; position: relative; z-index: 2; }
			.panel-main   { display: flex; flex-direction: column; gap: 14px; }

			.panel-title { font-size: 2rem; font-weight: 800; color: #fff; letter-spacing: -0.5px; line-height: 1.1; }
			.panel-desc  { font-size: 0.88rem; color: rgba(255,255,255,0.65); line-height: 1.6; }

			.panel-side {
				background: rgba(255,255,255,0.02);
				border: 1px solid rgba(255,255,255,0.06);
				padding: 20px; border-radius: 4px;
				box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
			}

			.bh-variant-badge {
				align-self: flex-start; padding: 3px 10px;
				font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
				background: rgba(var(--badge-color-rgb), 0.1); color: var(--accent-color);
				border: 1px solid rgba(var(--badge-color-rgb), 0.25); border-radius: 20px; margin-bottom: 4px;
			}

			.bh-variant-spec-list { list-style: none; display: flex; flex-direction: column; gap: 10px; font-size: 0.78rem; color: #cbd5e1; }
			.bh-variant-spec-item { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed #1e2235; padding-bottom: 8px; }
			.bh-variant-spec-item:last-child { border-bottom: none; padding-bottom: 0; }
			.bh-variant-spec-label { color: rgba(255,255,255,0.38); text-transform: uppercase; font-size: 0.64rem; letter-spacing: 0.5px; }
			.bh-variant-spec-value { font-weight: 500; color: rgba(255,255,255,0.9); }

			.status-dot { display: inline-block; width: 6px; height: 6px; background: currentColor; border-radius: 50%; margin-right: 8px; vertical-align: middle; position: relative; }
			.status-dot::after { content: ''; position: absolute; inset: 0; border-radius: 50%; background: currentColor; animation: status-pulse 1.8s infinite ease-in-out; }
			@keyframes status-pulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(2.6); opacity: 0; } }

			@media (max-width: 768px) { .panel-layout { grid-template-columns: 1fr; gap: 20px; } .panel-title { font-size: 1.6rem; } }

			/* ===========================
			   RESPONSIVE
			=========================== */
			@media (max-width: 850px) {
				.bh-journey-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.bh-gaps-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 700px) {
				.bh-page {
					padding: 32px 16px 80px;
				}

				.bh-title {
					font-size: 2.4rem;
					letter-spacing: -1px;
				}

				.bh-grid {
					grid-template-columns: 1fr;
					gap: 16px;
				}

				.bh-charts {
					grid-template-columns: 1fr;
					gap: 16px;
				}

				.bh-topbar {
					margin-bottom: 32px;
				}

				.bh-breadcrumb {
					display: none;
				}
			}

			@media (max-width: 600px) {
				.bh-journey-grid {
					grid-template-columns: 1fr;
					gap: 16px;
				}
				.bh-gaps-grid {
					grid-template-columns: 1fr;
					gap: 16px;
				}
			}

			@media (max-width: 480px) {
				.bh-table th,
				.bh-table td {
					padding: 12px 14px;
					font-size: 0.78rem;
				}

				.bh-gap-item {
					flex-direction: column;
					gap: 12px;
				}
			}
		</style>
	</head>

