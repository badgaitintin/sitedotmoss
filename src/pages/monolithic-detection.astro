---
// monolithic-detection.astro — Monolithic d-Ape · On-Device Inference · Blackhole Theme
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Monolithic d-Ape — On-Device Depth Estimation</title>
		<meta
			name="description"
			content="Run Monolithic d-Ape, a self-supervised stereo depth estimation model, entirely in your browser using ONNX Runtime Web. No server required."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&display=swap"
			rel="stylesheet"
		/>
		<!-- ONNX Runtime Web is loaded dynamically inside the page script to guarantee availability -->
		<style is:global>
			/* ===========================
			   RESET
			=========================== */
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			/* ===========================
			   BLACKHOLE TOKEN SYSTEM (Frutiger Aero / Light Theme)
			=========================== */
			:root {
				--bh-void: #ffffff;
				--bh-deep: #f9fafb;
				--bh-surface: #f3f4f6;
				--bh-card: #ffffff;
				--bh-border: rgba(0, 0, 0, 0.08);
				--bh-border-hi: rgba(0, 0, 0, 0.16);
				--bh-text: #1f2937;
				--bh-muted: #6b7280;
				--bh-accent: #f97316; /* NextWBC Orange */
				--bh-accent2: #ea580c; /* NextWBC Darker Orange */
				--bh-accent3: #10b981; /* emerald */
				--bh-danger: #ef4444;
				--bh-glow: transparent;
				--bh-glow-sm: transparent;
			}

			/* ===========================
			   BASE
			=========================== */
			html,
			body {
				width: 100%;
				height: 100vh;
				overflow: hidden;
				background: transparent;
				font-family: "Google Sans Flex", "Google Sans", "Helvetica Neue", sans-serif;
				color: var(--bh-text);
				line-height: 1.5;
				margin: 0;
				padding: 0;
				position: relative;
			}

			body::before {
				content: "";
				position: fixed;
				inset: -40px;
				z-index: -1;
				background-image: url('/frutiger-aero-wallpaper-i-whipped-up-in-a-few-hours-hoping-v0-jcaq7gsamypc1.webp');
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				filter: blur(24px);
				background-color: rgba(255, 255, 255, 0.1);
				background-blend-mode: overlay;
			}

			a {
				color: var(--bh-accent);
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}

			.page-wrap {
				animation: bh-enter 0.5s cubic-bezier(0.1, 0.9, 0.2, 1) both;
				height: 100%;
			}
			@keyframes bh-enter {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			body.is-exiting .page-wrap {
				animation: bh-exit 0.28s cubic-bezier(0.4, 0, 1, 1) both;
				pointer-events: none;
			}
			@keyframes bh-exit {
				from {
					opacity: 1;
					transform: translateY(0);
				}
				to {
					opacity: 0;
					transform: translateY(20px);
				}
			}

			/* ===========================
			   LAYOUT CONTAINER
			=========================== */
			.bh-page {
				position: relative;
				z-index: 1;
				max-width: 1200px;
				margin: 0 auto;
				height: 100vh;
				padding: 20px 16px;
				box-sizing: border-box;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.bh-main-card {
				position: relative;
				background: rgba(255, 255, 255, 0.88);
				backdrop-filter: blur(48px);
				-webkit-backdrop-filter: blur(48px);
				border: 1px solid rgba(0, 0, 0, 0.05);
				border-radius: 0px;
				padding: 24px;
				box-shadow: 0 32px 80px rgba(0, 0, 0, 0.08), 0 0 32px rgba(0, 0, 0, 0.02);
				display: flex;
				gap: 24px;
				height: calc(100vh - 40px);
				align-items: stretch;
				box-sizing: border-box;
				overflow: hidden;
			}

			/* ===========================
			   SIDEBAR & WORKSPACE
			=========================== */
			.wbc-sidebar {
				width: 300px;
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				gap: 16px;
				border-right: 1px solid var(--bh-border);
				padding-right: 24px;
				overflow-y: auto;
			}
			.wbc-sidebar::-webkit-scrollbar {
				width: 4px;
			}
			.wbc-sidebar::-webkit-scrollbar-track {
				background: transparent;
			}
			.wbc-sidebar::-webkit-scrollbar-thumb {
				background: rgba(0, 0, 0, 0.08);
				border-radius: 0px;
			}

			.wbc-workspace {
				flex: 1;
				display: flex;
				flex-direction: column;
				min-width: 0;
				height: 100%;
				overflow: hidden;
				gap: 16px;
				justify-content: space-between;
			}

			/* ===========================
			   HEADER & TITLES
			=========================== */
			.bh-header {
				display: flex;
				flex-direction: column;
				gap: 6px;
			}
			.wbc-back-btn {
				width: fit-content;
				background: transparent;
				border: none;
				color: var(--bh-muted);
				display: inline-flex;
				align-items: center;
				gap: 6px;
				cursor: pointer;
				font-size: 0.8rem;
				font-weight: 500;
				text-decoration: none;
				transition: color 0.2s;
				padding: 0;
				margin-bottom: 4px;
			}
			.wbc-back-btn:hover {
				color: var(--bh-accent);
				text-decoration: none;
			}
			.bh-title {
				font-size: 1.45rem;
				font-weight: 700;
				line-height: 1.2;
				letter-spacing: -0.5px;
				margin: 0;
			}
			.title-mono {
				color: var(--bh-text);
			}
			.title-dape {
				color: #7c3aed; /* Kept purple exclusively for d-Ape */
			}
			.bh-subtitle {
				font-size: 0.8rem;
				color: var(--bh-muted);
				margin: 0;
			}

			/* ===========================
			   MODEL STATUS BAR
			=========================== */
			.model-status-card {
				background: rgba(0,0,0,0.02);
				border: 1px solid var(--bh-border);
				padding: 12px;
				display: flex;
				flex-direction: column;
				gap: 8px;
			}
			.status-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.status-label {
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				color: var(--bh-muted);
				font-weight: 600;
			}
			.model-status {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				font-family: inherit;
				font-size: 0.72rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				color: var(--bh-muted);
			}
			.model-status.ready { color: var(--bh-accent3); }
			.model-status.loading { color: var(--bh-accent); }
			.model-status.error { color: var(--bh-danger); }
			
			.status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--bh-muted);
			}
			.model-status.ready .status-dot { background: var(--bh-accent3); box-shadow: 0 0 8px var(--bh-accent3); }
			.model-status.loading .status-dot { background: var(--bh-accent); animation: pulse-status 1.2s infinite ease-in-out; }
			.model-status.error .status-dot { background: var(--bh-danger); }
			@keyframes pulse-status {
				0%, 100% { opacity: 0.4; }
				50% { opacity: 1; }
			}

			.model-load-bar {
				display: none;
				flex-direction: column;
				gap: 4px;
			}
			.model-load-bar.visible {
				display: flex;
			}
			.load-bar-track {
				height: 4px;
				background: rgba(0,0,0,0.06);
				overflow: hidden;
			}
			.load-bar-fill {
				height: 100%;
				width: 0%;
				background: var(--bh-accent);
				transition: width 0.3s;
			}
			.load-bar-text {
				font-size: 0.65rem;
				color: var(--bh-muted);
				text-align: right;
			}

			/* ===========================
			   MODE TOGGLE TABS
			=========================== */
			.mode-toggle {
				background: rgba(0,0,0,0.03);
				border: 1px solid var(--bh-border);
				padding: 2px;
				display: flex;
				gap: 2px;
			}
			.mode-btn {
				flex: 1;
				background: transparent;
				border: none;
				color: var(--bh-muted);
				font-family: inherit;
				font-size: 0.74rem;
				font-weight: 500;
				padding: 8px 6px;
				cursor: pointer;
				transition: all 0.2s;
				text-align: center;
			}
			.mode-btn:hover {
				color: var(--bh-text);
			}
			.mode-btn.active {
				background: var(--bh-card);
				color: var(--bh-accent);
				box-shadow: 0 2px 6px rgba(0,0,0,0.04);
				font-weight: 600;
			}

			/* ===========================
			   UPLOAD ZONES
			=========================== */
			.upload-zone {
				border: 2px dashed rgba(0,0,0,0.1);
				padding: 20px 16px;
				text-align: center;
				background: rgba(0,0,0,0.01);
				cursor: pointer;
				position: relative;
				transition: all 0.2s;
			}
			.upload-zone:hover {
				border-color: var(--bh-accent);
				background: rgba(0,0,0,0.03);
			}
			.upload-zone input[type=file] {
				position: absolute;
				inset: 0;
				opacity: 0;
				cursor: pointer;
			}
			.upload-icon {
				width: 24px;
				height: 24px;
				stroke: var(--bh-muted);
				margin: 0 auto 8px;
				display: block;
			}
			.upload-label {
				font-size: 0.75rem;
				color: var(--bh-text);
				line-height: 1.4;
			}

			/* ===========================
			   BUTTONS
			=========================== */
			.run-btn {
				width: 100%;
				padding: 11px 16px;
				background: linear-gradient(135deg, var(--bh-accent) 0%, var(--bh-accent2) 100%);
				border: none;
				color: #fff;
				font-family: inherit;
				font-size: 0.8rem;
				font-weight: 600;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 8px;
				transition: opacity 0.2s, transform 0.2s;
				box-shadow: 0 4px 12px rgba(249, 115, 22, 0.18);
			}
			.run-btn:hover {
				opacity: 0.95;
				transform: translateY(-1px);
			}
			.run-btn:active {
				transform: translateY(0);
			}
			.run-btn:disabled {
				opacity: 0.4;
				cursor: not-allowed;
				transform: none;
				box-shadow: none;
			}
			.run-btn .spinner {
				width: 14px;
				height: 14px;
				border: 2px solid rgba(255,255,255,0.3);
				border-top-color: #fff;
				border-radius: 50%;
				animation: spin 0.7s linear infinite;
				display: none;
			}
			.run-btn.running .spinner { display: block; }
			.run-btn.running .run-arrow { display: none; }
			@keyframes spin { to { transform: rotate(360deg); } }

			.sample-row {
				display: flex;
				gap: 8px;
			}
			.sample-btn {
				flex: 1;
				padding: 8px 10px;
				background: rgba(0,0,0,0.02);
				border: 1px solid var(--bh-border);
				color: var(--bh-muted);
				font-size: 0.7rem;
				font-weight: 600;
				cursor: pointer;
				font-family: inherit;
				transition: all 0.2s;
				text-align: center;
			}
			.sample-btn:hover {
				border-color: var(--bh-accent);
				color: var(--bh-accent);
				background: rgba(0,0,0,0.04);
			}

			/* ===========================
			   WORKSPACE & VIEWPORTS
			=========================== */
			.workspace-canvasses {
				display: flex;
				flex-direction: column;
				gap: 12px;
				flex: 1;
				min-height: 0;
				justify-content: center;
			}

			.viewport-container {
				width: 100%;
				max-width: 1024px;
				margin: 0 auto;
				background: rgba(0,0,0,0.02);
				border: 1px solid var(--bh-border);
				position: relative;
				flex: 1;
				min-height: 0;
				max-height: 220px;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
			}
			
			.viewport-container.single-preview {
				max-height: 220px;
			}

			.viewport-container canvas {
				max-width: 100%;
				max-height: 100%;
				object-fit: contain;
				display: block;
			}
			
			.preview-empty {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--bh-muted);
				font-size: 0.78rem;
				background: rgba(0,0,0,0.01);
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}
			
			.viewport-badge {
				position: absolute;
				top: 8px;
				left: 8px;
				z-index: 2;
				font-size: 0.6rem;
				font-weight: 700;
				background: rgba(255, 255, 255, 0.9);
				color: var(--bh-text);
				padding: 3px 6px;
				letter-spacing: 0.5px;
				text-transform: uppercase;
				border: 1px solid var(--bh-border);
				backdrop-filter: blur(4px);
			}

			.preview-row {
				display: flex;
				gap: 12px;
				width: 100%;
				height: 100%;
			}
			.preview-row.single .preview-box:last-child {
				display: none;
			}
			.preview-box {
				flex: 1;
				height: 100%;
				position: relative;
				display: flex;
				align-items: center;
				justify-content: center;
				min-width: 0;
			}

			/* ===========================
			   WORKSPACE CONTROLS (Middle Bar)
			=========================== */
			.workspace-controls {
				display: flex;
				flex-direction: column;
				gap: 12px;
				background: rgba(0,0,0,0.01);
				border: 1px solid var(--bh-border);
				padding: 12px 16px;
			}

			.colormap-row {
				margin-bottom: 0 !important;
			}
			.cm-btn {
				width: 32px;
				height: 24px;
				border-radius: 4px;
				border: 2px solid transparent;
				cursor: pointer;
				transition: border-color 0.2s;
			}
			.cm-btn.active { border-color: var(--bh-text); }
			.cm-inferno { background: linear-gradient(90deg, #000004, #1b0c41, #4a0c4e, #781c6d, #a52c60, #cf4446, #ed6925, #fb9b06, #f7d03c, #fcffa4); }
			.cm-plasma  { background: linear-gradient(90deg, #0d0887, #46039f, #7201a8, #9c179e, #bd3786, #d8576b, #ed7953, #fb9f3a, #fdcb26, #f0f921); }
			.cm-viridis { background: linear-gradient(90deg, #440154, #3b528b, #21918c, #5ec962, #fde725); }
			.cm-turbo   { background: linear-gradient(90deg, #30123b, #4145ab, #4675ed, #39a7f5, #1dd1d4, #37f6ac, #95f95a, #e9f53a, #febb2b, #f56918, #c52a18, #7a0403); }

			.slider-row {
				display: flex;
				align-items: center;
				gap: 12px;
			}
			.slider-label {
				font-size: 0.68rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				color: var(--bh-muted);
				white-space: nowrap;
				min-width: 50px;
			}
			input[type=range] {
				flex: 1;
				-webkit-appearance: none;
				height: 4px;
				background: rgba(0,0,0,0.06);
				outline: none;
			}
			input[type=range]::-webkit-slider-thumb {
				-webkit-appearance: none;
				width: 14px;
				height: 14px;
				border-radius: 50%;
				background: var(--bh-accent);
				cursor: pointer;
				box-shadow: 0 1px 4px rgba(0,0,0,0.15);
			}

			/* ===========================
			   FOOTER PANEL (Stats & Downloads)
			=========================== */
			.workspace-footer {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px;
				border-top: 1px solid var(--bh-border);
				padding-top: 12px;
			}

			.depth-stats {
				display: flex;
				gap: 16px;
			}
			.depth-stat {
				display: flex;
				flex-direction: column;
				gap: 2px;
			}
			.depth-stat-label {
				font-size: 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				color: var(--bh-muted);
				font-weight: 500;
			}
			.depth-stat-val {
				font-family: inherit;
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--bh-text);
			}
			.depth-stat-val.accent { color: var(--bh-accent); }

			.actions-row {
				display: flex;
				gap: 8px;
			}
			.dl-btn {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				padding: 7px 12px;
				background: rgba(0,0,0,0.02);
				border: 1px solid var(--bh-border);
				color: var(--bh-text);
				font-size: 0.72rem;
				font-weight: 600;
				cursor: pointer;
				font-family: inherit;
				transition: all 0.2s;
			}
			.dl-btn:hover {
				background: rgba(0,0,0,0.04);
				border-color: var(--bh-accent);
				color: var(--bh-accent);
			}
			.dl-btn:disabled { opacity: 0.3; cursor: not-allowed; }

			.infer-time {
				font-size: 0.72rem;
				color: var(--bh-muted);
				padding: 2px 6px;
				background: rgba(0,0,0,0.03);
				border: 1px solid var(--bh-border);
				display: none;
			}
			.infer-time.visible { display: inline-block; }

			.error-toast {
				position: fixed;
				bottom: 24px;
				right: 24px;
				background: rgba(239, 68, 68, 0.08);
				border: 1px solid rgba(239, 68, 68, 0.2);
				padding: 12px 18px;
				color: var(--bh-danger);
				font-size: 0.8rem;
				font-weight: 500;
				z-index: 1000;
				max-width: 360px;
				backdrop-filter: blur(12px);
				display: none;
			}
		</style>
	</head>

	<body>
		<!-- Error Toast -->
		<div class="error-toast" id="errorToast" role="alert"></div>

		<div class="page-wrap">
			<main class="bh-page">
				<div class="bh-main-card">
					<!-- SIDEBAR CONTROLS -->
					<aside class="wbc-sidebar">
						<header class="bh-header">
							<a href="/" class="wbc-back-btn" id="backBtn">
								<svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 12L4 7l5-5"/>
								</svg>
								Back
							</a>
							<h2 class="bh-title">
								<span class="title-mono">Monolithic</span>
								<span class="title-dape">d-Ape</span>
							</h2>
							<p class="bh-subtitle">On-Device Depth Estimation</p>
						</header>

						<!-- Model Load Status Card -->
						<div class="model-status-card">
							<div class="status-row">
								<span class="status-label">Model Status</span>
								<div class="model-status idle" id="modelStatus">
									<span class="status-dot"></span>
									<span id="modelStatusText">Not Loaded</span>
								</div>
							</div>
							<div class="model-load-bar" id="loadBar">
								<div class="load-bar-track">
									<div class="load-bar-fill" id="loadBarFill"></div>
								</div>
								<div class="load-bar-text" id="loadBarText">Initializing...</div>
							</div>
						</div>

						<!-- Mode Select Tabs -->
						<div class="mode-toggle">
							<button class="mode-btn active" id="btnSingle" type="button">Single</button>
							<button class="mode-btn" id="btnStereo" type="button">Stereo</button>
							<button class="mode-btn" id="btnCamera" type="button">Live Camera</button>
						</div>

						<!-- Camera input selections -->
						<div id="cameraControls" style="display:none;">
							<div style="display:flex; gap:8px; margin-bottom:8px;">
								<select id="cameraSelect" style="flex:1; background:#ffffff; color:var(--bh-text); border:1px solid var(--bh-border); padding:6px 10px; font-family:inherit; font-size:0.75rem;" aria-label="Select camera">
									<option value="">Detecting cameras...</option>
