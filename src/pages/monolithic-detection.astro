		<!-- Close page-wrap -->

		<script>
			// ── Interactive Road Timeline Logic ──
			(function() {
				const milestones = document.querySelectorAll('.road-milestone');
				const walker = document.getElementById('roadWalker');
				const track = document.getElementById('panelsTrack');
				const car = document.getElementById('roadCar');
				let currentIndex = 0;

				if (!walker || milestones.length === 0 || !track) return;

				milestones.forEach((milestone) => {
					milestone.addEventListener('click', () => {
						const nextIndex = parseInt(milestone.getAttribute('data-index'), 10);
						if (nextIndex === currentIndex) return;

						const nextLeft = milestone.style.left;
						const nextAccent = milestone.getAttribute('data-accent');

						// Flip walker direction depending on movement
						let flipX = 1;
						if (nextIndex < currentIndex) {
							flipX = -1; // face left
						} else {
							flipX = 1;  // face right
						}

						// Trigger walking animation classes
						walker.classList.add('is-walking');
						
						// Move and flip the walker sprite (no scaling or vertical displacement needed)
						walker.style.left = nextLeft;
						walker.style.transform = `translateX(-50%) scaleX(${flipX})`;
						
						// Transition active accent color variable
						walker.style.setProperty('--accent-color', nextAccent);

						// Switch active classes on milestones
						milestones[currentIndex].classList.remove('active');
						milestone.classList.add('active');

						// Shift the cards track horizontally
						const translatePct = -33.3333 * nextIndex;
						track.style.transform = `translateX(${translatePct}%)`;

						// Remove walking animation once reached destination (1.2s transition time)
						setTimeout(() => {
							walker.classList.remove('is-walking');
						}, 1200);

						currentIndex = nextIndex;
					});
				});

				// Drive the pixel car automatically every 10 seconds
				if (car) {
					function launchCar() {
						car.classList.add('drive');
						setTimeout(() => {
							car.classList.remove('drive');
						}, 3000);
					}
					// Launch once at start
					setTimeout(launchCar, 2000);
					// Set loop every 10s
					setInterval(launchCar, 10000);
				}
			})();

			// ── Page exit transition ──// ── Page exit transition ──
			const backBtn = document.getElementById("backBtn");
			if (backBtn) {
				backBtn.addEventListener("click", (e) => {
					e.preventDefault();
					document.body.classList.add("is-exiting");
					setTimeout(() => {
						window.location.href = backBtn.getAttribute("href");
					}, 280);
				});
			}

			// ── Dynamic Fluid Bubble Generator ──
			const bgContainer = document.querySelector(".bh-bg");
			if (bgContainer) {
				const bubblesContainer = document.createElement("div");
				bubblesContainer.className = "bh-bubbles";
				bgContainer.appendChild(bubblesContainer);

				const bubbleCount = 20;
				for (let i = 0; i < bubbleCount; i++) {
					const bubble = document.createElement("div");
					bubble.className = "bh-bubble";

					const size = Math.random() * 40 + 10; // 10px to 50px
					const left = Math.random() * 100; // 0% to 100%
					const delay = Math.random() * 12; // 0s to 12s delay
					const duration = Math.random() * 12 + 8; // 8s to 20s speed
					const sway =
						(Math.random() * 60 + 20) *
						(Math.random() > 0.5 ? 1 : -1); // sway left or right
					const opacity = Math.random() * 0.12 + 0.04; // subtle aesthetic

					bubble.style.setProperty("--size", `${size}px`);
					bubble.style.setProperty("--left", `${left}%`);
					bubble.style.setProperty("--delay", `${delay}s`);
					bubble.style.setProperty("--duration", `${duration}s`);
					bubble.style.setProperty("--sway", `${sway}px`);
					bubble.style.setProperty("--opacity", opacity.toString());

					bubblesContainer.appendChild(bubble);
				}
			}
		</script>
