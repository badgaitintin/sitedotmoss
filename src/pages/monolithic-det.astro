---
// monolithic-det.astro — Monolithic Det · Blackhole Theme
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Monolithic Det — Custom Swin Transformer + FCOS Object Detector built from scratch in PyTorch."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Coral+Pixels&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Libre+Barcode+128+Text&family=Trirong:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
			rel="stylesheet"
		/>
		<style>
			/* ===========================
			   RESET
			=========================== */
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			/* ===========================
			   BLACKHOLE TOKEN SYSTEM
			=========================== */
			:root {
				--bh-void: #000000;
				--bh-deep: #07080a;
				--bh-surface: #0d0f12;
				--bh-card: #111318;
				--bh-border: rgba(255, 255, 255, 0.07);
				--bh-border-hi: rgba(255, 255, 255, 0.14);
				--bh-text: #e8eaf0;
				--bh-muted: #6b7280;
				--bh-accent: #818cf8; /* slate blue */
				--bh-accent2: #a78bfa; /* violet */
				--bh-accent3: #34d399; /* emerald (gap badges) */
				--bh-danger: #f87171;
				--bh-glow: transparent;
				--bh-glow-sm: transparent;
			}

			/* ===========================
			   BASE
			=========================== */
			html,
			body {
				width: 100%;
				min-height: 100vh;
				background: #000;
				font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
				color: var(--bh-text);
				line-height: 1.6;
			}

			a {
				color: var(--bh-accent);
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}

			/* ===========================
			   PAGE TRANSITION
			=========================== */
			.page-wrap {
				animation: bh-enter 0.5s cubic-bezier(0.1, 0.9, 0.2, 1) both;
			}
			@keyframes bh-enter {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			body.is-exiting .page-wrap {
				animation: bh-exit 0.28s cubic-bezier(0.4, 0, 1, 1) both;
				pointer-events: none;
			}
			@keyframes bh-exit {
				from {
					opacity: 1;
					transform: translateY(0);
				}
				to {
					opacity: 0;
					transform: translateY(20px);
				}
			}

			/* ===========================
			   ENERGY BURST BACKGROUND
			   — Radial gradient from bright center
			     to void, fixed behind all content
			=========================== */
			/* ===========================
			   FLUID ORB BACKGROUND
			   — Scattered atmospheric orbs fading
			     and drifting slowly, scroll-linked
			=========================== */
			.bh-bg {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 0;
				overflow: hidden;
				background: #000;
			}

			/* Theme Containers */
			.bh-bg-theme {
				position: absolute;
				inset: 0;
				will-change: filter;
				filter: invert(var(--scroll-invert, 0));
				isolation: isolate;
			}

			.bh-glow-orb {
				position: absolute;
				border-radius: 50%;
				mix-blend-mode: screen;
				will-change: transform, border-radius;
			}

			/* RGB Orbs (Red, Green, Blue) - Positioned closer and animated to overlap */
			.bh-glow-orb--1 {
				width: 500px;
				height: 500px;
				top: 10%;
				left: 15%;
				filter: blur(75px);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.55) 0%, rgba(239, 68, 68, 0.8) 30%, rgba(185, 28, 28, 0.25) 70%, rgba(0, 0, 0, 0) 100%);
				animation: drift-1 28s infinite ease-in-out, morph-1 16s infinite ease-in-out;
			}
			.bh-glow-orb--2 {
				width: 380px;
				height: 380px;
				top: 25%;
				left: 45%;
				filter: blur(65px);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.6) 0%, rgba(34, 197, 94, 0.8) 30%, rgba(21, 128, 61, 0.2) 70%, rgba(0, 0, 0, 0) 100%);
				animation: drift-2 24s infinite ease-in-out, morph-2 12s infinite ease-in-out;
			}
			.bh-glow-orb--3 {
				width: 300px;
				height: 300px;
				bottom: 15%;
				left: 30%;
				filter: blur(55px);
				background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.6) 0%, rgba(59, 130, 246, 0.8) 30%, rgba(29, 78, 216, 0.25) 70%, rgba(0, 0, 0, 0) 100%);
				animation: drift-3 20s infinite ease-in-out, morph-3 10s infinite ease-in-out;
			}

			@keyframes drift-1 {
				0%, 100% { transform: translate(0, 0) scale(1); }
				33% { transform: translate(200px, 120px) scale(1.1); }
				66% { transform: translate(-100px, -50px) scale(0.9); }
			}

			@keyframes drift-2 {
				0%, 100% { transform: translate(0, 0) scale(1); }
				33% { transform: translate(-250px, 150px) scale(0.9); }
				66% { transform: translate(150px, -100px) scale(1.1); }
			}

			@keyframes drift-3 {
				0%, 100% { transform: translate(0, 0) scale(1); }
				33% { transform: translate(120px, -200px) scale(1.15); }
				66% { transform: translate(-180px, 100px) scale(0.85); }
			}

			@keyframes morph-1 {
				0%, 100% { border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%; }
				33% { border-radius: 70% 30% 52% 48% / 60% 40% 60% 40%; }
				66% { border-radius: 50% 50% 35% 65% / 40% 60% 40% 60%; }
			}

			@keyframes morph-2 {
				0%, 100% { border-radius: 50% 50% 30% 70% / 50% 60% 40% 50%; }
				33% { border-radius: 40% 60% 60% 40% / 40% 50% 50% 60%; }
				66% { border-radius: 60% 40% 40% 60% / 60% 40% 60% 40%; }
			}

			@keyframes morph-3 {
				0%, 100% { border-radius: 38% 62% 40% 60% / 53% 48% 52% 47%; }
				33% { border-radius: 65% 35% 62% 38% / 45% 55% 40% 60%; }
				66% { border-radius: 48% 52% 35% 65% / 60% 40% 55% 45%; }
			}

			/* Shared vignette overlay fading to solid black at the outer boundaries */
			.bh-vignette {
				position: absolute;
				inset: 0;
				z-index: 4;
				background: radial-gradient(
					ellipse 100% 100% at 50% 50%,
					transparent 30%,
					rgba(0, 0, 0, 0.45) 70%,
					rgba(0, 0, 0, 0.96) 100%
				);
			}

			.bh-bubbles {
				position: absolute;
				inset: 0;
				z-index: 3; /* above blue/orange gradients, below vignette */
				pointer-events: none;
				overflow: hidden;
			}

			.bh-bubble {
				position: absolute;
				bottom: -60px;
				left: var(--left);
				width: var(--size);
				height: var(--size);
				opacity: 0;
				background: radial-gradient(
					circle at 30% 30%,
					rgba(255, 255, 255, 0.08) 0%,
					rgba(255, 255, 255, 0.01) 70%
				);
				border: 1px solid rgba(255, 255, 255, 0.09);
				border-radius: 50%;
				box-shadow:
					inset 0 2px 4px rgba(255, 255, 255, 0.15),
					0 2px 10px rgba(0, 0, 0, 0.3);
				animation: float-up var(--duration) infinite linear;
				animation-delay: var(--delay);
				will-change: transform, opacity;
			}

			@keyframes float-up {
				0% {
					transform: translateY(0) translateX(0) scale(0.8);
					opacity: 0;
				}
				10% {
					opacity: var(--opacity);
				}
				90% {
					opacity: var(--opacity);
				}
				100% {
					transform: translateY(-110vh) translateX(var(--sway))
						scale(1.1);
					opacity: 0;
				}
			}

			/* ===========================
			   LAYOUT CONTAINER
			=========================== */
			.bh-page {
				position: relative;
				z-index: 1;
				max-width: 860px;
				margin: 0 auto;
				padding: 48px 24px 80px;
				box-sizing: border-box;
			}

			/* ===========================
			   TOP NAV BAR
			=========================== */
			.bh-topbar {
				display: flex;
				align-items: center;
				gap: 16px;
				margin-bottom: 24px;
			}

			.bh-back {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 7px 14px;
				border: 1px solid var(--bh-border-hi);
				border-radius: 4px;
				font-size: 0.82rem;
				font-weight: 500;
				color: var(--bh-muted);
				background: var(--bh-card);
				transition:
					color 0.2s,
					border-color 0.2s,
					background 0.2s;
				cursor: pointer;
			}
			.bh-back:hover {
				color: var(--bh-text);
				border-color: var(--bh-accent);
				background: rgba(124, 156, 255, 0.06);
				text-decoration: none;
			}

			.bh-breadcrumb {
				font-size: 0.78rem;
				color: var(--bh-muted);
				letter-spacing: 0.3px;
			}
			.bh-breadcrumb span {
				color: var(--bh-text);
				font-weight: 500;
			}

			/* Apply Google Sans to all content sections starting from 00 downwards */
			.bh-content-scroll {
				font-family: "Google Sans", sans-serif;
			}

			/* Style SVG flowcharts with Google Sans */
			.bh-diag-svg text {
				font-family: "Google Sans", sans-serif;
			}

			/* ===========================
			   HEADER & SCROLL LAYOUT
			=========================== */
			.bh-header {
				display: flex;
				flex-direction: column;
				gap: 24px;
				margin-bottom: 48px;
				width: 100%;
			}

			@media (min-width: 900px) {
				.bh-page {
					max-width: 1100px !important;
					width: 100%;
					padding: 60px 40px 120px !important;
					display: flex;
					flex-direction: column;
					margin: 0 auto !important;
				}

				.bh-topbar {
					margin-bottom: 32px;
				}

				.bh-header {
					display: grid;
					grid-template-columns: auto 1fr;
					gap: 64px;
					align-items: flex-start;
					flex-shrink: 0;
					margin-bottom: 72px;
				}

				.bh-header-right {
					display: flex;
					justify-content: flex-end;
				}

				.bh-header-right .bh-summary {
					text-align: right;
					margin: 0 0 0 auto;
					font-size: 0.92rem;
					line-height: 1.75;
					max-width: 720px;
				}

				.bh-title {
					font-size: clamp(2.2rem, 4vw, 3.2rem) !important;
					justify-content: flex-start !important;
					text-align: left !important;
				}

				.bh-content-scroll {
					display: flex;
					flex-direction: column;
					gap: 80px;
					overflow-x: visible;
					overflow-y: visible;
					flex-grow: 0;
					padding-bottom: 0;
					align-items: stretch;
				}

				.bh-section {
					margin-bottom: 0 !important;
					display: flex;
					flex-direction: column;
					width: 100% !important;
				}

				.bh-divider {
					display: block !important;
					height: 1px;
					background: linear-gradient(
						to right,
						transparent,
						rgba(255, 255, 255, 0.08),
						transparent
					);
					margin: 100px 0;
				}
			}

			/* ===========================
			   HERO SECTION
			=========================== */
			.bh-hero {
				margin-bottom: 80px;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}

			.bh-eyebrow {
				font-size: 0.72rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 2px;
				color: var(--bh-accent);
				margin-bottom: 20px;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
				width: 100%;
			}
			.bh-eyebrow::before {
				content: "";
				display: block;
				width: 60px;
				height: 1px;
				background: linear-gradient(
					to left,
					var(--bh-accent),
					transparent
				);
			}
			.bh-eyebrow::after {
				content: "";
				display: block;
				width: 60px;
				height: 1px;
				background: linear-gradient(
					to right,
					var(--bh-accent),
					transparent
				);
			}

			.bh-title {
				font-size: clamp(2.8rem, 7vw, 5rem);
				font-weight: 900;
				line-height: 1.1;
				letter-spacing: -1px;
				margin-bottom: 16px;
				color: #fff;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-wrap: wrap;
				gap: 16px;
			}

			.title-monolithic {
				font-family: "Google Sans", sans-serif;
				background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			.title-det {
				font-family: "Coral Pixels", sans-serif;
				font-size: 1.1em;
				font-weight: normal;
			}

			.bh-subtitle {
				font-family: "Google Sans", sans-serif;
				font-size: 0.95rem;
				color: rgba(255, 255, 255, 0.75);
				font-weight: 400;
				margin-bottom: 28px;
				line-height: 1.5;
				letter-spacing: 0.3px;
			}

			.bh-summary {
				font-family: "Google Sans", sans-serif;
				font-size: 0.88rem;
				color: rgba(255, 255, 255, 0.8);
				line-height: 1.8;
				max-width: 620px;
				margin-bottom: 32px;
				margin-left: auto;
				margin-right: auto;
				font-weight: 400;
			}

			.bh-summary strong {
				color: #ffffff !important;
				font-weight: 600;
			}

			.bh-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				justify-content: center;
			}

			.bh-tag {
				padding: 4px 12px;
				border: 1px solid var(--bh-border-hi);
				border-radius: 0;
				font-size: 0.73rem;
				font-weight: 600;
				color: var(--bh-muted);
				background: var(--bh-card);
				letter-spacing: 0.3px;
				transition:
					border-color 0.2s,
					color 0.2s;
			}
			.bh-tag:hover {
				border-color: var(--bh-accent);
				color: var(--bh-accent);
			}

			/* ===========================
			   SECTION WRAPPER
			=========================== */
			.bh-section {
				margin-bottom: 80px;
				scroll-margin-top: 48px;
			}

			.bh-section-head {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 6px;
				margin-bottom: 32px;
			}

			.bh-section-num {
				font-size: 0.85rem;
				font-weight: 600;
				color: var(--bh-accent);
				font-variant-numeric: tabular-nums;
				text-transform: uppercase;
				letter-spacing: 0.15em;
				opacity: 0.9;
			}

			.bh-section-title {
				font-size: clamp(1.8rem, 4vw, 2.4rem);
				font-weight: 700;
				color: #fff;
				letter-spacing: -0.02em;
				line-height: 1.25;
			}

			.bh-section-line {
				display: none;
			}

			.bh-prose {
				font-size: 1.15rem;
				color: #d1d5db;
				line-height: 1.65;
				margin-bottom: 32px;
				font-weight: 400;
			}

			.bh-prose strong {
				color: #ffffff;
				font-weight: 600;
			}

			/* ===========================
			   ARCHITECTURE DIAGRAM
			=========================== */
			.bh-diag-wrap {
				background: rgba(22, 22, 23, 0.45);
				backdrop-filter: blur(24px) saturate(160%);
				-webkit-backdrop-filter: blur(24px) saturate(160%);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 0;
				padding: 40px 28px;
				overflow-x: auto;
				scrollbar-width: thin;
				scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
				margin-bottom: 40px;
			}

			.bh-diag-svg {
				display: block;
				width: 100%;
				height: auto;
				max-width: 760px;
				margin: 0 auto;
			}

			/* ===========================
			   VARIANTS GRID (Section 00)
			=========================== */
			.bh-variants-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 20px;
				margin-bottom: 24px;
			}

			.bh-variant-card {
				background: rgba(22, 22, 23, 0.45);
				backdrop-filter: blur(24px) saturate(160%);
				-webkit-backdrop-filter: blur(24px) saturate(160%);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 0;
				padding: 24px;
				transition: border-color 0.25s, background-color 0.25s, transform 0.25s, box-shadow 0.25s;
				position: relative;
				display: flex;
				flex-direction: column;
				gap: 12px;
			}

			.bh-variant-card:hover {
				background: rgba(28, 28, 30, 0.6);
				border-color: var(--card-glow, rgba(255, 255, 255, 0.16));
				transform: translateY(-4px);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 20px var(--card-glow-soft, transparent);
			}

			.bh-variant-card--nano {
				--card-glow: rgba(52, 211, 153, 0.4);
				--card-glow-soft: rgba(52, 211, 153, 0.08);
				--accent-color: #34d399;
			}
			.bh-variant-card--macro {
				--card-glow: rgba(99, 102, 241, 0.4);
				--card-glow-soft: rgba(99, 102, 241, 0.08);
				--accent-color: #6366f1;
			}
			.bh-variant-card--small {
				--card-glow: rgba(129, 140, 248, 0.45);
				--card-glow-soft: rgba(129, 140, 248, 0.1);
				--accent-color: var(--bh-accent);
				border-color: rgba(129, 140, 248, 0.25);
			}
			.bh-variant-card--medium {
				--card-glow: rgba(244, 63, 94, 0.4);
				--card-glow-soft: rgba(244, 63, 94, 0.08);
				--accent-color: #f43f5e;
			}

			.bh-variant-badge {
				align-self: flex-start;
				padding: 2px 8px;
				font-size: 0.65rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				background: rgba(255, 255, 255, 0.05);
				color: var(--bh-muted);
				border: 1px solid rgba(255, 255, 255, 0.1);
			}

			.bh-variant-card--small .bh-variant-badge {
				background: rgba(129, 140, 248, 0.15);
				color: var(--bh-accent);
				border-color: rgba(129, 140, 248, 0.3);
			}

			.bh-variant-name {
				font-size: 1.3rem;
				font-weight: 700;
				color: #fff;
			}

			.bh-variant-spec-list {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 8px;
				font-size: 0.8rem;
				color: #cbd5e1;
				margin-top: 8px;
			}

			.bh-variant-spec-item {
				display: flex;
				justify-content: space-between;
			}

			.bh-variant-spec-label {
				color: var(--bh-muted);
			}

			.bh-variant-spec-value {
				font-weight: 500;
				color: #f5f5f7;
			}

			.bh-variant-bar-bg {
				width: 100%;
				height: 4px;
				background: rgba(255, 255, 255, 0.08);
				margin-top: auto;
				position: relative;
			}

			.bh-variant-bar-fill {
				height: 100%;
				background: var(--accent-color, #fff);
				box-shadow: 0 0 8px var(--accent-color);
			}

			@media (max-width: 950px) {
				.bh-variants-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 500px) {
				.bh-variants-grid {
					grid-template-columns: 1fr;
				}
			}

			/* ===========================
			   SPEC CARDS GRID
			=========================== */
			.bh-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
			}

			.bh-card {
				background: rgba(22, 22, 23, 0.45);
				backdrop-filter: blur(24px) saturate(160%);
				-webkit-backdrop-filter: blur(24px) saturate(160%);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 0;
				padding: 28px;
				transition:
					border-color 0.25s,
					background-color 0.25s,
					transform 0.25s;
			}
			.bh-card:hover {
				background: rgba(28, 28, 30, 0.6);
				border-color: rgba(255, 255, 255, 0.16);
