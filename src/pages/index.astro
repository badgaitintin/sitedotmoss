		<script>
			/* Drag-to-scroll for the tile strip */
			(function() {
				const el = document.getElementById('tileScroll');
				if (!el) return;

				let isDown = false;
				let startX;
				let scrollLeft;

				el.addEventListener('mousedown', (e) => {
					// Only enable drag-to-scroll if the scroll container has horizontal overflow
					if (el.scrollWidth <= el.clientWidth) return;

					isDown = true;
					el.classList.add('is-dragging');
					startX = e.pageX - el.offsetLeft;
					scrollLeft = el.scrollLeft;
					e.preventDefault();
				});

				el.addEventListener('mouseleave', () => {
					isDown = false;
					el.classList.remove('is-dragging');
				});

				el.addEventListener('mouseup', () => {
					isDown = false;
					el.classList.remove('is-dragging');
				});

				el.addEventListener('mousemove', (e) => {
					if (!isDown) return;
					e.preventDefault();
					const x = e.pageX - el.offsetLeft;
					const walk = (x - startX) * 1.4; /* drag speed multiplier */
					el.scrollLeft = scrollLeft - walk;
				});
			})();

			/* Toggle legend info box on mobile/tablet */
			(function() {
				const toggleBtn = document.getElementById('annotationToggle');
				const legend = document.querySelector('.wf-annotation');
				if (!toggleBtn || !legend) return;

				toggleBtn.addEventListener('click', () => {
					legend.classList.toggle('is-visible');
					if (legend.classList.contains('is-visible')) {
						toggleBtn.textContent = '×';
					} else {
						toggleBtn.textContent = '?';
					}
				});
			})();

			/* Assign tile and group indexes for staggered transition delay */
			(function() {
				const tiles = document.querySelectorAll('.tile');
				tiles.forEach((tile, index) => {
					tile.style.setProperty('--tile-index', index);
				});

				const groups = document.querySelectorAll('.tile-group');
				groups.forEach((group, index) => {
					group.style.setProperty('--group-index', index);
				});
			})();

			/* Intercept clicks on same-origin internal page links for turnstile exit animation */
			(function() {
				const screen = document.querySelector('.metro-screen');
				if (!screen) return;

				screen.addEventListener('click', (e) => {
					// Find nearest <a> parent
					const link = e.target.closest('a');
					if (!link) return;

					const href = link.getAttribute('href');
					const target = link.getAttribute('target');

					// Intercept internal relative/same-origin links in the same tab, not downloads
					if (
						href && 
						!href.startsWith('#') && 
						!href.startsWith('javascript:') && 
						target !== '_blank' && 
						!link.hasAttribute('download')
					) {
						try {
							const url = new URL(href, window.location.origin);
							if (url.origin === window.location.origin) {
								e.preventDefault();
								screen.classList.add('is-exiting');

								// Wait for the exit animation to finish before navigating
								setTimeout(() => {
									window.location.href = href;
								}, 500);
							}
						} catch (err) {
							// fallback
						}
					}
				});
			})();
		</script>

