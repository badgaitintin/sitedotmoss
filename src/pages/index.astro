---
import '@fontsource/google-sans-flex';
import AboutModal from '../components/AboutModal.astro';

// Get the current date/time
const now = new Date();
const currentDate = now.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const currentDay = now.getDate();
const dayName = now.toLocaleDateString('en-US', { weekday: 'long' });
const monthYear = now.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }).toUpperCase();

// For calendar grid
const year = now.getFullYear();
const month = now.getMonth();
const firstDay = new Date(year, month, 1).getDay();
const daysInMonth = new Date(year, month + 1, 0).getDate();
const calDays: (number|null)[] = [];
for (let i = 0; i < firstDay; i++) calDays.push(null);
for (let i = 1; i <= daysInMonth; i++) calDays.push(i);

const ICONS = {
  brain: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>`,
  paint: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 18.5a6 6 0 0 0-6-6"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><circle cx="12" cy="12" r="1"/></svg>`,
  fire: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  cv: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 15h6"/><path d="M9 11h6"/></svg>`,
  brush: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"/><path d="M7.07 14.94C5.79 16.3 5 18.09 5 20a5 5 0 0 0 10 0c0-1.9-.79-3.69-2.07-5.06l-5.86.06z"/></svg>`,
  book: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>`,
  folder: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>`,
  link: `<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>`,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="site(.)moss — A personal portfolio and dashboard by Tinnaphop Sonsang." />
    <title>site(.)moss</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Outer wrapper -->
    <div class="page-root">

      <!-- === HEADER === -->
      <header class="site-header">
        <h1 class="site-logo">site(.)moss</h1>
      </header>

      <!-- === DASHBOARD SCROLL AREA === -->
      <div class="dashboard-scroll">
        <main class="dashboard-grid">

          <!-- ─────────────────────────── -->
          <!-- GROUP 1: LIFE AT A GLANCE   -->
          <!-- ─────────────────────────── -->
          <section class="tile-group">
            <h2 class="group-label">Life at a glance</h2>
            <div class="tile-grid">

              <!-- Clock 2×2 -->
              <div class="tile t-2x2" id="tile-clock">
                <div class="clock-face" id="clock-face">
                  <svg class="clock-svg" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="48" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
                    <line id="hour-hand" x1="50" y1="50" x2="50" y2="22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    <line id="min-hand" x1="50" y1="50" x2="50" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <line id="sec-hand" x1="50" y1="50" x2="50" y2="14" stroke="var(--accent-primary)" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
                    <circle cx="50" cy="50" r="2" fill="currentColor"/>
                  </svg>
                </div>
                <span class="tile-label">CLOCK</span>
              </div>

              <!-- Calendar 2×3 -->
              <div class="tile t-2x3" id="tile-calendar">
                <div class="cal-header">
                  <span class="cal-month">{monthYear}</span>
                </div>
                <div class="cal-grid">
                  {['SUN','MON','TUE','WED','THU','FRI','SAT'].map(d => (
                    <span class="cal-dow">{d}</span>
                  ))}
                  {calDays.map(d => (
                    <span class={`cal-day${d === currentDay ? ' cal-today' : ''}${!d ? ' cal-empty' : ''}`}>
                      {d || ''}
                    </span>
                  ))}
                </div>
                <span class="tile-label">CALENDAR</span>
              </div>

              <!-- CV tile 1×1 -->
              <a href="/cv" class="tile t-1x1 tile-accent-secondary" id="tile-cv-sm">
                <div class="tile-icon-sm" set:html={ICONS.cv} />
              </a>

              <!-- Quote 3×2 with image -->
              <div class="tile t-3x2 tile-has-image" id="tile-quote">
                <div class="tile-bg-img" style="background-image: url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=600&q=70')"></div>
                <div class="tile-bg-overlay"></div>
                <div class="tile-quote-content">
                  <p class="tile-quote-text">"The only way to do great work is to love what you do."</p>
                  <p class="tile-quote-author">— Steve Jobs</p>
                </div>
              </div>

              <!-- Monolithic Detection promo (replacing Ad Tile) -->
              <a href="/monolithic-detection" class="tile t-3x2 tile-dark tile-has-image" id="tile-mono-promo">
                <div class="tile-bg-img" style="background-image: url('https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=600&q=70')"></div>
                <div class="tile-bg-overlay dark-overlay"></div>
                <div class="tile-promo-content">
                  <span class="tile-promo-tag">SPONSORED</span>
                  <h3 class="tile-promo-title">Monolithic Deep Learning</h3>
                  <p class="tile-promo-sub">Custom models built from scratch.</p>
                  <span class="tile-promo-cta">EXPLORE <span class="tile-link-icon" set:html={ICONS.link}></span></span>
                </div>
              </a>

              <!-- About Me 2×1 — opens modal -->
              <button class="tile t-2x1 tile-has-image" id="tile-about" onclick="openAboutModal()">
                <div class="tile-bg-img" style="background-image: url('/IMG_1405.PNG'); background-position: center top;"></div>
                <div class="tile-bg-overlay" style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.05) 55%);"></div>
                <div class="about-tile-text">
                  <span class="about-tile-name">About Me</span>
                  <span class="about-tile-sub">Tinnaphop Sonsang</span>
                </div>
              </button>

            </div>
          </section>

          <!-- ─────────────────────────── -->
          <!-- GROUP 2: AI LAB             -->
          <!-- ─────────────────────────── -->
          <section class="tile-group">
            <h2 class="group-label">AI Lab</h2>
            <div class="tile-grid">

              <!-- Monolithic Detection 2×2 -->
              <a href="/monolithic-detection" class="tile t-2x2 tile-has-image" id="tile-mono-demo">
                <div class="tile-bg-img" style="background-image: url('https://images.unsplash.com/photo-1620712943543-bcc4688e7485?auto=format&fit=crop&w=400&q=70')"></div>
                <div class="tile-bg-overlay"></div>
                <span class="tile-label tile-label-light">MONOLITHIC</span>
              </a>

              <!-- Next WBC 2×1 -->
              <a href="/monolithic-detection" class="tile t-2x1 tile-accent-primary" id="tile-nextwbc">
                <div class="tile-2x1-inner">
                  <div class="tile-icon-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  </div>
                  <div class="tile-2x1-text">
                    <span class="tile-2x1-title">Next WBC</span>
                    <span class="tile-2x1-sub">White Blood Cell</span>
                  </div>
                </div>
              </a>

            </div>
          </section>

          <!-- ─────────────────────────── -->
          <!-- GROUP 3: WORK & FOCUS       -->
          <!-- ─────────────────────────── -->
          <section class="tile-group">
            <h2 class="group-label">Work &amp; Focus</h2>

            <!-- Spotify tile -->
            <div class="spotify-wide" id="tile-spotify">
              <iframe
                src="https://open.spotify.com/embed/album/1CWY6mfnuLlF4BKRLFcUDQ?utm_source=generator&si=93502f090cbc40e4"
                width="100%"
                height="152"
                frameborder="0"
                allowfullscreen
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
              ></iframe>
            </div>

          </section>


        </main>
      </div>
    </div>

    <AboutModal />
  </body>
</html>

<style is:global>
  /* ===========================
     DESIGN TOKENS
  =========================== */
  :root {
    --bg:               #F0EBE4;
    --fg:               #1A1410;
    --tile-bg:          #FFFFFF;
    --tile-border:      rgba(0, 0, 0, 0.08);
    --tile-hover:       #F7F4F0;
    --tile-shadow:      0 2px 8px rgba(0,0,0,0.06);
    --tile-shadow-hover:0 8px 24px rgba(0,0,0,0.12);
    --tile-text:        #1A1410;
    --tile-label-color: rgba(26, 20, 16, 0.55);

    --accent-primary:   #949B7B;   /* sage green */
    --accent-secondary: #B6A691;   /* taupe */
    --accent-primary-soft: rgba(148, 155, 123, 0.45);
    --accent-secondary-soft: rgba(182, 166, 145, 0.4);

    --font: 'DM Sans', 'Google Sans Flex', system-ui, sans-serif;
    --unit: 68px;
    --gap: 6px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  html, body {
    width: 100%;
    min-height: 100vh;
    background: transparent;
    color: var(--fg);
    font-family: var(--font);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    scrollbar-width: none;
    position: relative;
  }

  body::before {
    content: "";
    position: fixed;
    inset: -40px; /* Expands to hide the blurred edges */
    z-index: -1;
    background-image: url('/frutiger-aero-wallpaper-i-whipped-up-in-a-few-hours-hoping-v0-jcaq7gsamypc1.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(24px);
    background-color: rgba(255, 255, 255, 0.1); /* Very light overlay to not wash it out too much */
    background-blend-mode: overlay;
  }

  /* ===========================
     PAGE ROOT
  =========================== */
  .page-root {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 52px 0 48px 0;
    gap: 24px;
  }

  /* ===========================
     HEADER
  =========================== */
  .site-header {
    width: 100%;
    max-width: 100vw;
    padding: 0 56px;
    text-align: center;
    animation: fadeDown 0.9s cubic-bezier(0.1, 0.9, 0.2, 1) both;
  }

  .site-logo {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1;
  }

  /* ===========================
     DASHBOARD SCROLL
  =========================== */
  .dashboard-scroll {
    width: 100%;
    max-width: 100vw;
    padding-left: 56px;
    padding-right: 56px;
    overflow-x: auto;
    overflow-y: hidden;
    -ms-overflow-style: none;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    display: flex;
    justify-content: center;
  }
  .dashboard-scroll::-webkit-scrollbar { display: none; }
  .dashboard-scroll.is-dragging { cursor: grabbing; }

  .dashboard-grid {
    display: flex;
    flex-wrap: nowrap;
    gap: clamp(20px, 4vw, 48px);
    align-items: flex-start;
    width: max-content;
  }

  /* ===========================
     TILE GROUP
  =========================== */
  .tile-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-shrink: 0;
    animation: fadeUp 0.75s cubic-bezier(0.1, 0.9, 0.2, 1) both;
  }
  .tile-group:nth-child(1) { animation-delay: 0.08s; }
  .tile-group:nth-child(2) { animation-delay: 0.16s; }
  .tile-group:nth-child(3) { animation-delay: 0.24s; }

  .group-label {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tile-label-color);
    padding-left: 2px;
  }

  /* ===========================
     TILE GRID
  =========================== */
  .tile-grid {
    display: grid;
    grid-template-rows: repeat(5, var(--unit));
    grid-auto-flow: column dense;
    grid-auto-columns: var(--unit);
    gap: var(--gap);
  }

  /* ===========================
     BASE TILE
  =========================== */
  .tile {
    background: var(--tile-bg);
    border: 1px solid var(--tile-border);
    box-shadow: var(--tile-shadow);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8px;
    cursor: pointer;
    text-decoration: none;
    color: var(--tile-text);
    transition: transform 0.25s cubic-bezier(0.1, 0.9, 0.2, 1),
                box-shadow 0.25s ease,
                border-color 0.25s ease,
                background 0.2s ease;
    transform: translateZ(0);
    will-change: transform;
    backface-visibility: hidden;
  }
  .tile:hover {
    transform: translateY(-3px) scale(1.015);
    box-shadow: var(--tile-shadow-hover);
    border-color: rgba(0,0,0,0.13);
    background: var(--tile-hover);
  }
  .tile:active {
    transform: scale(0.96);
    transition-duration: 0.06s;
    box-shadow: none;
  }

  /* Glow overlay on hover */
  .tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,0.35) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 5;
  }
  .tile:hover::after { opacity: 1; }

  /* ===========================
     TILE SIZES
  =========================== */
  .t-1x1 { grid-column: span 1; grid-row: span 1; }
  .t-1x2 { grid-column: span 1; grid-row: span 2; }
  .t-2x1 { grid-column: span 2; grid-row: span 1; }
  .t-2x2 { grid-column: span 2; grid-row: span 2; }
  .t-2x3 { grid-column: span 2; grid-row: span 3; }
  .t-2x4 { grid-column: span 2; grid-row: span 4; }
  .t-3x2 { grid-column: span 3; grid-row: span 2; }
  .t-3x5 { grid-column: span 3; grid-row: span 5; }

  /* ===========================
     SPOTIFY WIDE STRIP
  =========================== */
  .spotify-wide {
    width: 100%;
    height: auto; /* Let padding and iframe dictate height */
    padding: 12px;
    background: #544081; /* Sampled purple from Madonna's album cover edge */
    border: 1px solid rgba(0,0,0,0.15);
    box-shadow: var(--tile-shadow);
    /* No border-radius -> sharp corners like other tiles */
    flex-shrink: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .spotify-wide:hover {
    transform: translateY(-3px) scale(1.015);
    box-shadow: var(--tile-shadow-hover);
  }
  .spotify-wide iframe {
    width: 100%;
    height: 152px; /* compact horizontal player */
    border: none;
    display: block;
    border-radius: 12px; /* Matches Spotify's internal radius perfectly */
  }


  /* ===========================
     TILE ACCENT VARIANTS
  =========================== */
  .tile-accent-primary   { background: var(--accent-primary-soft); border-color: rgba(148,155,123,0.2); }
  .tile-accent-secondary { background: var(--accent-secondary-soft); border-color: rgba(182,166,145,0.2); }
  .tile-accent-primary-light { background: rgba(148,155,123,0.18); border-color: rgba(148,155,123,0.15); }
  .tile-accent-secondary-light { background: rgba(182,166,145,0.22); border-color: rgba(182,166,145,0.18); }
  .tile-dark { background: #111318; }

  /* ===========================
     TILE LABEL
  =========================== */
  .tile-label {
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tile-label-color);
    position: relative;
    z-index: 2;
    line-height: 1;
    padding-top: 2px;
  }
  .tile-label-light {
    color: rgba(255,255,255,0.75);
  }

  /* ===========================
     TILE BACKGROUNDS (IMAGE)
  =========================== */
  .tile-has-image { background: #333; }
  .tile-bg-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.6s ease;
    z-index: 0;
  }
  .tile:hover .tile-bg-img { transform: scale(1.06); }

  .tile-bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.32);
    z-index: 1;
    transition: background 0.3s ease;
  }
  .tile:hover .tile-bg-overlay { background: rgba(0,0,0,0.22); }
  .dark-overlay { background: rgba(0,0,0,0.55); }
  .tile:hover .dark-overlay { background: rgba(0,0,0,0.45); }

  /* ===========================
     TILE ICONS
  =========================== */
  .tile-icon-sm {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tile-text);
    opacity: 0.7;
    z-index: 2;
    pointer-events: none;
  }
  .tile:hover .tile-icon-sm { opacity: 0.9; }
  .t-1x1 .tile-icon-sm {
    transform: translate(-50%, -50%);
  }

  .tile-icon-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -65%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tile-text);
    opacity: 0.65;
    z-index: 2;
    pointer-events: none;
  }
  .tile:hover .tile-icon-center { opacity: 0.85; }

  /* ===========================
     ABOUT ME TILE TEXT
  =========================== */
  .about-tile-text {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    padding: 16px;
    gap: 4px;
  }
  .about-tile-name {
    font-family: 'Google Sans Flex', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #fff;
    line-height: 1;
  }
  .about-tile-sub {
    font-family: 'Google Sans Flex', sans-serif;
    font-size: 10.5px;
    color: rgba(255,255,255,0.85);
    line-height: 1;
  }

  /* ===========================
     CLOCK TILE
  =========================== */
  .clock-face {
    position: absolute;
    inset: 10px 10px 28px 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
