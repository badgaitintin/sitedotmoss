<script>
  // ── Clock animation ──
  function tickClock() {
    const now = new Date();
    const h = now.getHours() % 12 + now.getMinutes() / 60;
    const m = now.getMinutes() + now.getSeconds() / 60;
    const s = now.getSeconds();
    const hAngle = h * 30;
    const mAngle = m * 6;
    const sAngle = s * 6;

    const setHand = (id: string, angle: number) => {
      const el = document.getElementById(id);
      if (!el) return;
      const cx = 50, cy = 50;
      const rad = (angle - 90) * Math.PI / 180;
      const len = id === 'hour-hand' ? 26 : id === 'min-hand' ? 32 : 34;
      const x2 = cx + Math.cos(rad) * len;
      const y2 = cy + Math.sin(rad) * len;
      el.setAttribute('x2', String(x2));
      el.setAttribute('y2', String(y2));
    };

    setHand('hour-hand', hAngle);
    setHand('min-hand', mAngle);
    setHand('sec-hand', sAngle);
  }
  tickClock();
  setInterval(tickClock, 1000);

  // ── Mouse glow on tiles ──
  document.querySelectorAll<HTMLElement>('.tile').forEach(tile => {
    tile.addEventListener('mousemove', e => {
      const r = tile.getBoundingClientRect();
      const x = ((e.clientX - r.left) / r.width * 100).toFixed(1);
      const y = ((e.clientY - r.top) / r.height * 100).toFixed(1);
      tile.style.setProperty('--mx', `${x}%`);
      tile.style.setProperty('--my', `${y}%`);
    });
  });

  // ── Drag-to-scroll ──
  const scroll = document.querySelector<HTMLElement>('.dashboard-scroll');
  if (scroll) {
    let isDragging = false, startX = 0, scrollLeft = 0;
    scroll.addEventListener('mousedown', e => {
      isDragging = true;
      startX = e.pageX - scroll.offsetLeft;
      scrollLeft = scroll.scrollLeft;
      scroll.classList.add('is-dragging');
    });
    document.addEventListener('mousemove', e => {
      if (!isDragging) return;
      e.preventDefault();
      const x = e.pageX - scroll.offsetLeft;
      scroll.scrollLeft = scrollLeft - (x - startX);
    });
    document.addEventListener('mouseup', () => {
      isDragging = false;
      scroll.classList.remove('is-dragging');
    });
  }


</script>
